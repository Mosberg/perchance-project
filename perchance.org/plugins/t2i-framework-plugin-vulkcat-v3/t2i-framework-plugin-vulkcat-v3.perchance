    }, { once: true });
  }
  window.___openLightbox_FAST = function(clickedCtn) {
    const allCtns = Array.from(document.querySelectorAll("#outputAreaEl_FAST .t2i-image-ctn"));
    let idx = allCtns.indexOf(clickedCtn); if (idx === -1) return;
    const overlay = document.createElement("div");
    overlay.style.cssText = "position:fixed;inset:0;background:rgba(0,0,0,0.90);display:flex;align-items:center;justify-content:center;z-index:99999999;";
    const imgWrap = document.createElement("div");
    imgWrap.style.cssText = "max-width:90vw;max-height:90vh;display:flex;align-items:center;justify-content:center;";
    const img = document.createElement("img");
    img.style.cssText = "max-width:85vw;max-height:85vh;object-fit:contain;border-radius:0;";
    const btnPrev = document.createElement("button");
    btnPrev.innerHTML = "⬅️";
    btnPrev.style.cssText = "background:none;border:none;box-shadow:none;font-size:2.5rem;cursor:pointer;padding:0.5rem;flex-shrink:0;line-height:1;opacity:0.85;";
    const btnNext = document.createElement("button");
    btnNext.innerHTML = "➡️";
    btnNext.style.cssText = "background:none;border:none;box-shadow:none;font-size:2.5rem;cursor:pointer;padding:0.5rem;flex-shrink:0;line-height:1;opacity:0.85;";
    function preloadFromIndex(targetIdx) {
      const ctns = Array.from(document.querySelectorAll("#outputAreaEl_FAST .t2i-image-ctn"));
      const ctn = ctns[targetIdx]; const iframe = ctn ? ctn.querySelector("iframe") : null;
      const dataUrl = iframe?.textToImagePluginOutput?.dataUrl;
      if(!dataUrl) return;
      const pre = new Image();
      pre.src = dataUrl;
    }
    function loadIdx(i) {
      idx = i;
      const ctns = Array.from(document.querySelectorAll("#outputAreaEl_FAST .t2i-image-ctn"));
      const ctn = ctns[idx]; const iframe = ctn ? ctn.querySelector("iframe") : null;
      const dataUrl = iframe?.textToImagePluginOutput?.dataUrl;
      if (dataUrl) { img.src = dataUrl; img.alt = ""; } else { img.src = ""; img.alt = "⏳ Not ready yet"; }
      preloadFromIndex(idx-1); preloadFromIndex(idx+1);
      const total = ctns.length;
      btnPrev.style.opacity = idx <= 0 ? "0.15" : "0.85"; btnPrev.disabled = idx <= 0;
      btnNext.style.opacity = idx >= total - 1 ? "0.15" : "0.85"; btnNext.disabled = idx >= total - 1;
    }
    btnPrev.onclick = function(e) { e.stopPropagation(); if(idx > 0) loadIdx(idx - 1); };
    btnNext.onclick = function(e) { e.stopPropagation(); if(idx < document.querySelectorAll("#outputAreaEl_FAST .t2i-image-ctn").length - 1) loadIdx(idx + 1); };
    const closeBtn = document.createElement("button");
    closeBtn.innerHTML = "✖";
    closeBtn.style.cssText = "position:absolute;top:1rem;right:1.2rem;background:none;border:none;color:#fff;font-size:1.8rem;cursor:pointer;line-height:1;opacity:0.75;box-shadow:none;";
    closeBtn.onmouseover = function(){ closeBtn.style.opacity = "1"; }; closeBtn.onmouseout = function(){ closeBtn.style.opacity = "0.75"; };
    closeBtn.onclick = function() { overlay.remove(); };
