    header2.appendChild(searchInp2);
    const grid2 = document.createElement("div");
    grid2.style.cssText = "display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:0.2rem;padding:0.45rem;overflow-y:auto;flex:1;";
