  function animateImageIntoTarget(args) {
    args = args || {};
    const { imgEl, sourceEl, targetEl, durationMs = 650, wiggle = false } = args;
    const srcRect = sourceEl.getBoundingClientRect(); const tgtRect = targetEl.getBoundingClientRect();
