    try { document.documentElement.innerHTML = blockedHtml; } catch(e) {}
    throw new Error("Blocked: unofficial fork/remix detected.");
  };
  window.___textToImagePlugin_FAST = textToImagePlugin;
  window.___userSettings_FAST = settings;
