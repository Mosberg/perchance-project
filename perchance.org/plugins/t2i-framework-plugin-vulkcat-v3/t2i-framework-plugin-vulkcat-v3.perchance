    localStorage.___t2iLangTo_FAST = "en";
    localStorage.___t2iLangFrom_FAST = "auto";
    localStorage.___t2iStyleMixValue_FAST = "";
    localStorage.___t2iStyleMixExpanded_FAST = "0";
    location.reload();
  };
  window.___closeSettingsPanel_FAST = function() {
    window.___settingsDraft_FAST = null;
    const overlay = document.getElementById("settingsOverlay_FAST");
    if(overlay) overlay.style.display = "none";
  };
  window.___renderSettingsPanel_FAST = function() {
    const panel = document.getElementById("settingsPanel_FAST");
    const overlay = document.getElementById("settingsOverlay_FAST");
    if(!panel) return;
    panel.style.display = "";
    if(overlay) overlay.style.display = "flex";
    const draft = ___getSettingsDraft_FAST();
    const row = function(label, controlHtml) {
      return '<div class="settings-row_FAST"><span>' + label + '</span><div class="settings-row-controls_FAST">' + controlHtml + '</div></div>';
    };
    const enabledSelect = function(onchange, current) {
      return '<select class="settings-select_FAST" onchange="' + onchange + '"><option value="enabled" ' + (current ? 'selected' : '') + '>enabled</option><option value="disabled" ' + (!current ? 'selected' : '') + '>disabled</option></select>';
    };
    const orderRow = function(label, key) {
      const item = draft.promptButtons[key];
      const maxOrder = Object.keys(draft.promptButtons || {}).length || 1;
      const orderOptions = Array.from({ length:maxOrder }, function(_, idx) { const n = idx + 1; return '<option value="' + n + '" ' + (Number(item.order) === n ? 'selected' : '') + '>' + n + '</option>'; }).join('');
      return '<div class="settings-row_FAST settings-order-row_FAST"><span>' + label + '</span><div class="settings-order-controls_FAST"><select class="settings-order-select_FAST" onchange="window.___settingsDraftOrder_FAST(\'' + key + '\',this.value)">' + orderOptions + '</select>' + enabledSelect('window.___settingsDraftEnabled_FAST(\'' + key + '\',this.value===\'enabled\')', item.enabled) + '</div></div>';
    };
    panel.innerHTML = '<div class="settings-card_FAST">'
      + '<div class="settings-title_FAST">🛠️ Settings</div>'
      + row('Set default language', '<button class="settings-link-btn_FAST" onclick="window.___settingsPickLang_FAST(\'page\')">' + window.___t2iGetLangName_FAST(draft.pageLang) + '</button>')
      + row('Set to translate', '<button class="settings-link-btn_FAST" onclick="window.___settingsPickLang_FAST(\'translate\')">' + window.___t2iGetLangName_FAST(draft.translateTo || "en") + '</button>')
      + orderRow('Show Search in prompt', 'search')
      + orderRow('Show Image to prompt', 'imageToPrompt')
      + orderRow('Show Undo/Redo', 'undoRedo')
      + orderRow('Show Translate prompt', 'translator')
      + row('Show Overlay Buttons', enabledSelect('window.___settingsDraftBool_FAST(\'showOverlayButtons\',this.value===\'enabled\')', draft.showOverlayButtons !== false))
      + '<div class="settings-footer_FAST"><button class="settings-action-btn_FAST" onclick="window.___resetSettingsDefaults_FAST()">⚠️ Reset Defaults</button><button class="settings-action-btn_FAST" onclick="window.___saveSettingsPanel_FAST()">💾 Save</button><button class="settings-action-btn_FAST" onclick="window.___closeSettingsPanel_FAST()">✖ Close</button></div>'
      + '</div>';
    window.___applyPageLanguage_FAST(panel);
  };
  window.___applyPageLanguage_FAST = async function(root) {
    root = root || document;
    const lang = (window.___uiPrefs_FAST && window.___uiPrefs_FAST.pageLang) || "en";
    const textTargets = Array.from(root.querySelectorAll ? root.querySelectorAll('#pageTitleEl_FAST, .input-label span, #generateButtonEl_FAST, #privateGalleryCtn_FAST button, #guideBtn_FAST, #videoModeToggleBtn_FAST, #hamburgerBtn_FAST, .sidebar-item-btn_FAST, .settings-title_FAST, .settings-row_FAST span, .settings-link-btn_FAST, .settings-action-btn_FAST, .t2i-modal-title_FAST') : []);
    const placeholderTargets = Array.from(root.querySelectorAll ? root.querySelectorAll('textarea[placeholder], input[placeholder]') : []);
    for(let i = 0; i < textTargets.length; i++) {
      const el = textTargets[i];
      if(!el.dataset.t2iOrigText) el.dataset.t2iOrigText = el.textContent;
      if(lang === "en") { el.textContent = el.dataset.t2iOrigText; continue; }
      try { el.textContent = await window.___t2iTranslate_FAST(el.dataset.t2iOrigText, "auto", lang); } catch(e) {}
    }
    for(let i = 0; i < placeholderTargets.length; i++) {
      const el = placeholderTargets[i];
      if(!el.dataset.t2iOrigPlaceholder) el.dataset.t2iOrigPlaceholder = el.placeholder || "";
      if(!el.dataset.t2iOrigPlaceholder) continue;
      if(lang === "en") { el.placeholder = el.dataset.t2iOrigPlaceholder; continue; }
      try { el.placeholder = await window.___t2iTranslate_FAST(el.dataset.t2iOrigPlaceholder, "auto", lang); } catch(e) {}
    }
  };
  const SYNC_KV_KEY = "___t2i_sync_v1";
  const GALLERY_PRE = "localMediaGallery_.";

  function ___collectSyncPayload_FAST() {
    const payload = {
      v: 2,
      ts: Date.now(),
      imageScale:      localStorage.___imageScale_FAST || "100",
      guidanceScale:   localStorage.___guidanceScale_FAST || "13",
      langFrom:        localStorage.___t2iLangFrom_FAST || "auto",
      langTo:          localStorage.___t2iLangTo_FAST || "en",
      pageLang:        localStorage.___t2iPageLang_FAST || "en",
      uiPrefs:         localStorage.getItem(T2I_UI_PREFS_KEY) || "{}",
      generateCount:   localStorage.generateClickCount || "0",
      scratchpad:      localStorage.getItem("T2I_FAST_scratchpad_pages") || "[\"\"]",
      scratchpadNames: localStorage.getItem("T2I_FAST_scratchpad_page_names") || "[\"1\"]",
      rememberedInputs: {},
      gallerySettings: localStorage.getItem(GALLERY_PRE + "settings") || "{}",
      galleryNames:    localStorage.getItem(GALLERY_PRE + "names") || '["general"]',
      galleryActive:   localStorage[GALLERY_PRE + "activeGalleryName"] || "general",
    };
    for (let i = 0; i < localStorage.length; i++) {
      const k = localStorage.key(i);
      if (k && k.startsWith("rememberedInput_T2I_FAST_")) {
        const inputName = k.replace("rememberedInput_T2I_FAST_", "");
        payload.rememberedInputs[inputName] = localStorage.getItem(k) || "";
      }
    }
    return payload;
  }

  function ___applySyncPayload_FAST(payload) {
    if (!payload || typeof payload !== "object") return;
    if (payload.imageScale)     localStorage.___imageScale_FAST    = payload.imageScale;
    if (payload.guidanceScale)  localStorage.___guidanceScale_FAST  = payload.guidanceScale;
    if (payload.langFrom)       localStorage.___t2iLangFrom_FAST    = payload.langFrom;
    if (payload.langTo)         localStorage.___t2iLangTo_FAST      = payload.langTo;
    if (payload.pageLang)       localStorage.___t2iPageLang_FAST    = payload.pageLang;
    if (payload.uiPrefs)        localStorage.setItem(T2I_UI_PREFS_KEY, payload.uiPrefs);
    if (payload.generateCount)  localStorage.generateClickCount      = payload.generateCount;
    if (payload.scratchpad)     localStorage.setItem("T2I_FAST_scratchpad_pages", payload.scratchpad);
    if (payload.scratchpadNames) localStorage.setItem("T2I_FAST_scratchpad_page_names", payload.scratchpadNames);
    if (payload.rememberedInputs && typeof payload.rememberedInputs === "object") {
      for (const [name, val] of Object.entries(payload.rememberedInputs)) {
        localStorage["rememberedInput_T2I_FAST_" + name] = val;
      }
    }
    if (payload.gallerySettings) localStorage.setItem(GALLERY_PRE + "settings", payload.gallerySettings);
    if (payload.galleryNames)    localStorage.setItem(GALLERY_PRE + "names",    payload.galleryNames);
    if (payload.galleryActive)   localStorage[GALLERY_PRE + "activeGalleryName"] = payload.galleryActive;
  }

  window.___syncPush_FAST = async function(silent) {
    const btn = document.getElementById("syncBtn_FAST");
    try {
      if (btn && !silent) { btn.textContent = "☁️ Cloud …"; btn.disabled = true; }
      const payload = ___collectSyncPayload_FAST();
      await kv["___t2i_sync_v1"].set("sync_data", JSON.stringify(payload));
      if (btn && !silent) {
        btn.textContent = "✅";
        setTimeout(function() { btn.textContent = "☁️ Cloud"; btn.disabled = false; }, 1200);
      } else if (btn) {
        btn.disabled = false;
      }
      console.log("[Sync] Pushed at", new Date().toLocaleTimeString());
    } catch(e) {
      console.warn("[Sync] Push failed:", e);
      if (btn) { btn.textContent = "❌"; btn.disabled = false; setTimeout(function() { btn.textContent = "☁️ Cloud"; }, 2000); }
    }
  };

  window.___syncPull_FAST = async function(silent) {
    const btn = document.getElementById("syncBtn_FAST");
    try {
      if (btn && !silent) { btn.textContent = "☁️ Cloud …"; btn.disabled = true; }
      const raw = await kv["___t2i_sync_v1"].get("sync_data");
      if (!raw) {
        if (btn && !silent) { btn.textContent = "☁️ Cloud (no data yet)"; setTimeout(function() { btn.textContent = "☁️ Cloud"; btn.disabled = false; }, 2000); }
        return;
      }
      const payload = typeof raw === "string" ? JSON.parse(raw) : raw;
      ___applySyncPayload_FAST(payload);
      if (btn && !silent) {
        btn.textContent = "✅ synced";
        setTimeout(function() { btn.textContent = "☁️ Cloud"; btn.disabled = false; location.reload(); }, 1200);
      }
      console.log("[Sync] Pulled at", new Date().toLocaleTimeString(), "ts:", payload.ts ? new Date(payload.ts).toLocaleTimeString() : "?");
    } catch(e) {
      console.warn("[Sync] Pull failed:", e);
      if (btn) { btn.textContent = "❌"; btn.disabled = false; setTimeout(function() { btn.textContent = "☁️ Cloud"; }, 2000); }
    }
  };

  window.___syncAutoLoad_FAST = async function() {
    try {
      const raw = await kv["___t2i_sync_v1"].get("sync_data");
      if (!raw) return;
      const payload = typeof raw === "string" ? JSON.parse(raw) : raw;
      if (!payload || typeof payload !== "object") return;
      const cloudTs = Number(payload.ts) || 0;
      const localTs = Number(localStorage.___syncLastPush_FAST) || 0;
      if (cloudTs > localTs) {
        ___applySyncPayload_FAST(payload);
        localStorage.___syncLastPush_FAST = cloudTs;
        console.log("[Sync] Auto-applied cloud data from", new Date(cloudTs).toLocaleTimeString());
      }
    } catch(e) { console.warn("[Sync] Auto-load failed:", e); }
  };

  let ___syncAutoPushTimer_FAST = null;
  window.___syncScheduleAutoPush_FAST = function() {
    clearTimeout(___syncAutoPushTimer_FAST);
    ___syncAutoPushTimer_FAST = setTimeout(function() {
      localStorage.___syncLastPush_FAST = Date.now();
      window.___syncPush_FAST(true);
    }, 5000);
  };

  let ___syncInitDone_FAST = false;
  (function() {
    const origSet = localStorage.setItem.bind(localStorage);
    localStorage.setItem = function(k, v) {
      origSet(k, v);
      if (___syncInitDone_FAST && !k.startsWith("___syncLastPush") && !k.startsWith(SYNC_KV_KEY)) {
        window.___syncScheduleAutoPush_FAST && window.___syncScheduleAutoPush_FAST();
      }
    };
    window.addEventListener("beforeunload", function() {
      clearTimeout(___syncAutoPushTimer_FAST);
      localStorage.___syncLastPush_FAST = Date.now();
    });
  })();

  window.___syncOpenMenu_FAST = function(btn) {
    if(window.___cloudService_FAST && typeof window.___cloudService_FAST.openModal === "function") {
      window.___cloudService_FAST.openModal(btn);
      return;
    }
    const existing = document.getElementById("cloudFallbackModal_FAST");
    if(existing) { existing.remove(); return; }
    const overlay = document.createElement("div");
    overlay.id = "cloudFallbackModal_FAST";
    overlay.style.cssText = "position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:10000001;display:flex;align-items:center;justify-content:center;";
    overlay.innerHTML = '<div style="width:min(420px,92vw);background:#1d1d1d;border:1px solid #303030;border-radius:6px;color:#ddd;padding:0.7rem;"><div style="display:flex;align-items:center;justify-content:space-between;"><b>☁️ Cloud</b><button style="background:none;border:none;color:#ddd;cursor:pointer;" onclick="this.closest(\'#cloudFallbackModal_FAST\').remove()">✖</button></div><div style="margin-top:0.5rem;font-size:0.84rem;opacity:0.85;">Cloud service is loading. Try again in a moment.</div></div>';
    overlay.onclick = function(e){ if(e.target === overlay) overlay.remove(); };
    document.body.appendChild(overlay);
  };
  if(window.___cloudService_FAST && typeof window.___cloudService_FAST.configure === "function") {
    window.___cloudService_FAST.configure({
      collectState: ___collectSyncPayload_FAST,
      applyState: ___applySyncPayload_FAST,
      perchancePush: window.___syncPush_FAST,
      perchancePull: window.___syncPull_FAST
    });
  }

  window.___togglePin_FAST = function(btn, e) {
    e.stopPropagation(); const ctn = btn.closest(".t2i-image-ctn"); const pinned = ctn.dataset.pinned === "1"; ctn.dataset.pinned = pinned ? "0" : "1";
    btn.querySelector(".pin-outline").style.display = pinned ? "" : "none";
    btn.querySelector(".pin-filled").style.display  = pinned ? "none" : "";
  };
  window.___regenOne_FAST = function(btn, e) {
    if(e) e.stopPropagation();
    const ctn = btn.closest(".t2i-image-ctn"); if(!ctn) return;
    if(ctn.dataset.pinned === "1") return;
    const allCtns = Array.from(document.querySelectorAll("#outputAreaEl_FAST .t2i-image-ctn"));
    const idx = allCtns.indexOf(ctn);
    if(idx < 0 || !window.___t2iTempOptionsList_FAST || !window.___t2iTempOptionsList_FAST[idx]) return;
    const opts = window.___t2iTempOptionsList_FAST[idx];
    const wrap = ctn.querySelector(".t2i-img-wrap") || ctn;
    const iframe = wrap.querySelector("iframe");
    const placeholder = document.createElement("div");
    placeholder.className = "t2i-img-placeholder"; placeholder.dataset.idx = idx;
    if(iframe) iframe.replaceWith(placeholder);
    else { const existing = wrap.querySelector(".t2i-img-placeholder"); if(existing) existing.remove(); wrap.appendChild(placeholder); }
    const pluginResult = window.___textToImagePlugin_FAST(opts);
    if(pluginResult && pluginResult.nodeType) { placeholder.replaceWith(pluginResult); window.___bindScaleForNode_FAST(pluginResult); }
    else if(pluginResult !== undefined && pluginResult !== null) { let tmp = document.createElement("div"); tmp.innerHTML = String(pluginResult); const mounted = tmp.firstChild || tmp; placeholder.replaceWith(mounted); window.___bindScaleForNode_FAST(mounted); }
    else placeholder.remove();
    ctn.dataset.naturalW = "";
  };
  window.___seedFromOverlay_FAST = function(btn, e) {
    e.stopPropagation(); const ctn = btn.closest(".t2i-image-ctn"); const iframe = ctn.querySelector("iframe");
    if(!iframe || !iframe.textToImagePluginOutput) return;
    const seed = iframe.textToImagePluginOutput?.inputs?.seed; if(seed === undefined || seed === null || seed === "") return;
    const seedInput = window.userInputsCtn_FAST ? window.userInputsCtn_FAST.querySelector("input[data-name='seed']") : null; if(!seedInput) return;
    seedInput.value = String(seed); seedInput.oninput({}); seedInput.focus();
  };
  window.t2i_privateGallerySave = async function(btn, imageCtn) {
    try {
      const videoEl = imageCtn ? imageCtn.querySelector("video.t2i-generated-video_FAST") : null;
      if(videoEl && videoEl.src) {
        if(btn.dataset.saved === "1") return;
        btn.disabled = true; btn.dataset.saved = "1";
        const videoBlob = await fetch(videoEl.src).then(function(r){ return r.blob(); });
        const videoInfo = { type:"video", source:"make_video", prompt: "", rate: imageCtn.dataset.rate || "0" };
        await window.t2i_privateGallery.add(videoBlob, { info: videoInfo, fileName: "generated-video.mp4" });
        privateGalleryCtn_FAST.hidden = false;
        return;
      }
      const iframe = imageCtn.querySelector("iframe");
      if(!iframe || !iframe.textToImagePluginOutput) return alert("Wait for the image to finish generating before saving.");
      if(btn.dataset.saved === "1") return; btn.disabled = true; btn.dataset.saved = "1";
      let out = iframe.textToImagePluginOutput; let inputs = (out.inputs || {});
      let imageBlob = await fetch(out.dataUrl).then(function(r){ return r.blob(); });
      const rateVal = imageCtn.dataset.rate || "0";
      const infoPayload = { prompt: (inputs.rawPrompt ?? inputs.prompt ?? ""), negativePrompt: (inputs.rawNegativePrompt ?? ""), seed: (inputs.seed ?? ""), guidanceScale: (inputs.guidanceScale ?? ""), resolution: (inputs.resolution ?? ""), rate: rateVal, style: (inputs.style ?? "") };
      await window.t2i_privateGallery.add(imageBlob, { info: infoPayload });
      privateGalleryCtn_FAST.hidden = false;
      let imgEl2 = document.createElement("img"); imgEl2.src = out.dataUrl;
      animateImageIntoTarget({ imgEl: imgEl2, sourceEl: iframe, targetEl: privateGalleryCtn_FAST.querySelector("button"), durationMs: 650, wiggle: true });
    } catch(e) { console.error(e); btn.disabled = false; btn.dataset.saved = "0"; }
  };
  window.___bindOutputAreaDelegates_FAST = function() {
    const outputArea = document.getElementById("outputAreaEl_FAST");
    if(!outputArea || outputArea.dataset.boundDelegates === "1") return;
    outputArea.dataset.boundDelegates = "1";
  };
  window.___mountGeneratedPlaceholders_FAST = function(placeholders, concurrency) {
    const queue = Array.isArray(placeholders) ? placeholders.slice() : [];
    const limit = Math.max(1, Number(concurrency) || 1);
    let active = 0;
    return new Promise(function(resolve) {
      function pump() {
        while(active < limit && queue.length) {
          const el = queue.shift();
          if(!el || !el.parentNode) continue;
          active++;
          requestAnimationFrame(function() {
            try {
              const idx = Number(el.dataset.idx);
              const pluginResult = window.___textToImagePlugin_FAST(window.___t2iTempOptionsList_FAST[idx]);
              if(pluginResult && pluginResult.nodeType) {
                el.replaceWith(pluginResult);
                window.___bindScaleForNode_FAST(pluginResult);
              } else if(pluginResult !== undefined && pluginResult !== null) {
                let tmp = document.createElement("div");
                tmp.innerHTML = String(pluginResult);
                const mounted = tmp.firstChild || tmp;
                el.replaceWith(mounted);
                window.___bindScaleForNode_FAST(mounted);
              } else {
                el.remove();
              }
            } finally {
              active--;
              if(!queue.length && active === 0) resolve();
              else pump();
            }
          });
        }
        if(!queue.length && active === 0) resolve();
      }
      pump();
    });
  };

  window.___generateButtonClickEvent_FAST = async function() {
    if(typeof clearPerchanceErrors === "function") clearPerchanceErrors();
    generateButtonEl_FAST.textContent = "⬇️ generating... ⬇️"; generateButtonEl_FAST.disabled = true; generateButtonEl_FAST.style.opacity = 0.7;
    setTimeout(function(){ generateButtonEl_FAST.textContent = "✨ generate"; generateButtonEl_FAST.disabled = false; generateButtonEl_FAST.style.opacity = 1; }, 2500);
    let numImages = 6;
    if(!isNaN(Number(settings.numImages?.evaluateItem))) numImages = Number(settings.numImages?.evaluateItem);
    if(isNaN(numImages)) numImages = 6;
    mainColumnEl_FAST.style.maxWidth = (numImages >= 12) ? "100%" : ___T2I_MAIN_MAX_WIDTH_FAST;
    if(!window.___userSettings_FAST.imageButtons) window.___userSettings_FAST.imageButtons = {};
    const SVG_SEED =
      `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="#000" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">` +
        `<path d="M12 22V12"/>` +
        `<path d="M12 12C12 7 8 4 3 5c0 5 3 8 9 7"/>` +
        `<path d="M12 12c0-5 4-8 9-7c0 5-3 8-9 7"/>` +
      `</svg>`;
    const SVG_PIN_OUTLINE =
      `<svg class="pin-outline" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="#000" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">` +
        `<line x1="12" y1="17" x2="12" y2="22"/><path d="M5 17h14"/><path d="M15 5a3 3 0 0 1-3 3 3 3 0 0 1-3-3V3h6v2z"/>` +
        `<path d="M9 8v4a3 3 0 0 0 6 0V8"/>` +
      `</svg>`;
    const SVG_PIN_FILLED =
      `<svg class="pin-filled" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="#000" stroke="#000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">` +
        `<line x1="12" y1="17" x2="12" y2="22"/><path d="M5 17h14"/><path d="M15 5a3 3 0 0 1-3 3 3 3 0 0 1-3-3V3h6v2z"/>` +
        `<path d="M9 8v4a3 3 0 0 0 6 0V8"/>` +
      `</svg>`;
    const SVG_HEART =
      `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="14" height="14" fill="#000"><path d="M47.6 300.4L228.3 469.1c7.5 7 17.4 10.9 27.7 10.9s20.2-3.9 27.7-10.9L464.4 300.4c30.4-28.3 47.6-68 47.6-109.5v-5.8c0-69.9-50.5-129.5-119.4-141C347 36.5 300.6 51.4 268 84L256 96 244 84c-32.6-32.6-79-47.5-124.6-39.9C50.5 55.6 0 115.2 0 185.1v5.8c0 41.5 17.2 81.2 47.6 109.5z"/></svg>`;
    const SVG_REGEN =
      `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="14" height="14" fill="#000"><path d="M105.1 202.6c7.7-21.8 20.2-42.3 37.8-59.8c62.5-62.5 163.8-62.5 226.3 0L386.3 160H336c-17.7 0-32 14.3-32 32s14.3 32 32 32H463.5c0 0 0 0 0 0h.4c17.7 0 32-14.3 32-32V64c0-17.7-14.3-32-32-32s-32 14.3-32 32v51.2L414.4 97.6c-87.5-87.5-229.3-87.5-316.8 0C73.2 122 55.6 150.7 44.8 181.4c-5.9 16.7 2.9 34.9 19.5 40.8s34.9-2.9 40.8-19.5zM39 289.3c-5 1.5-9.8 4.2-13.7 8.2c-4 4-6.7 8.8-8.1 14c-.3 1.2-.6 2.5-.8 3.8c-.3 1.7-.4 3.4-.4 5.1V448c0 17.7 14.3 32 32 32s32-14.3 32-32V396.9l17.6 17.5 0 0c87.5 87.4 229.3 87.4 316.7 0c24.4-24.4 42.1-53.1 52.9-83.7c5.9-16.7-2.9-34.9-19.5-40.8s-34.9 2.9-40.8 19.5c-7.7 21.8-20.2 42.3-37.8 59.8c-62.5 62.5-163.8 62.5-226.3 0l-.1-.1L125.6 352H176c17.7 0 32-14.3 32-32s-14.3-32-32-32H48.4c-1.6 0-3.2 .1-4.8 .3s-3.1 .5-4.6 1z"/></svg>`;
    const overlayBtnsHtml = ___overlayButtonsEnabled_FAST() ? (
      `<button class="img-overlay-btn img-overlay-tl" onclick="window.___seedFromOverlay_FAST(this,event)" title="Use seed">${SVG_SEED}</button>` +
