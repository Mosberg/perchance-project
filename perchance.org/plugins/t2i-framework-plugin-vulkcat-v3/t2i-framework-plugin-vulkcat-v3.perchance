  window.___applyCategoryVisibility_FAST = function() {
    if(window.___isVideoMode_FAST) {
      const userInputs = window.___userSettings_FAST.userInputs;
      for(let name of userInputs.getChildNames) {
        const spec = userInputs[name];
        const block = ___getInputDisplayBlock_FAST(spec && spec._element);
        if(!block) continue;
        const keep = name === "scratchpad" || name === "askAi" || name === "translator";
        block.style.display = keep ? "" : "none";
      }
      const settingsPanelVideo = document.getElementById("settingsPanel_FAST");
      if(settingsPanelVideo) settingsPanelVideo.style.display = "none";
      return;
    }
    const current = window.___currentT2IMode_FAST;
    const category = (window.___categoryBar_FAST.items || []).find(function(item) { return item.id === current; });
    const isSettings = !!(category && category.isSettings);
    const userInputs = window.___userSettings_FAST.userInputs;
    for(let name of userInputs.getChildNames) {
      const spec = userInputs[name];
      const block = ___getInputDisplayBlock_FAST(spec && spec._element);
      if(!block) continue;
      const visibleByRule = block.dataset.ruleVisibleFast !== "0";
      const visibleByPrefs = ___isInputVisibleByPrefs_FAST(name);
      const categoryId = String(block.dataset.categoryId || ___cfgVal_FAST(spec && spec.category) || spec.___categoryId_FAST || "");
      const visibleByCategory = !isSettings;
      block.style.display = (visibleByRule && visibleByPrefs && visibleByCategory) ? "" : "none";
    }
  };
  window.___toggleSidebar_FAST = function() {
    const sidebar = document.getElementById("leftSidebar_FAST");
    if(!sidebar) return;
    sidebar.dataset.open = sidebar.dataset.open === "1" ? "0" : "1";
  };
  window.___loadVideoRuntime_FAST = function() {
