    const header = document.createElement("div");
    header.style.cssText = "padding:0.45rem 0.65rem;display:flex;align-items:center;justify-content:center;gap:0.4rem;flex-shrink:0;position:relative;";
    const titleEl = document.createElement("span");
    titleEl.className = "t2i-modal-title_FAST";
