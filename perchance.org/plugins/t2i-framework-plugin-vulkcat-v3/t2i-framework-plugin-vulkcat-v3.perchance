      grid.style.cssText = "display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:0.45rem;padding:0.55rem;overflow-y:auto;flex:1;align-content:start;";
      const activeChannel = channelSel.value;
      const query = searchEl.value.trim().toLowerCase();
