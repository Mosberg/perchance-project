    row.style.cssText = "display:flex;gap:0.4rem;width:100%;margin-top:0.35rem;";
    const leftBtn = document.createElement("button");
    const mainBtn = document.createElement("button");
    const rightBtn = document.createElement("button");
    leftBtn.style.cssText = rightBtn.style.cssText = "flex:0 0 6.4rem;padding:0.3rem 0.4rem;cursor:pointer;font-size:0.86rem;";
    mainBtn.style.cssText = "flex:1;padding:0.3rem 0.6rem;cursor:pointer;font-size:0.9rem;";
    function renderActionState() {
      const center = actions[idx];
      const left = actions[(idx + 2) % actions.length];
      const right = actions[(idx + 1) % actions.length];
      leftBtn.textContent = "◀ " + left.icon;
      rightBtn.textContent = right.icon + " ▶️";
      mainBtn.textContent = center.icon + " " + center.label;
      localStorage.setItem(actionKey, String(idx));
    }
    leftBtn.onclick = function(){ idx = (idx + 2) % actions.length; renderActionState(); };
    rightBtn.onclick = function(){ idx = (idx + 1) % actions.length; renderActionState(); };
    mainBtn.onclick = function() {
      const text = outputTa.value.trim();
      if(!text) return;
      Promise.resolve(actions[idx].run(text)).then(function(){
        const old = mainBtn.textContent;
        mainBtn.textContent = "✅ Done";
        setTimeout(function(){ mainBtn.textContent = old; }, 900);
      });
    };
