      Object.keys(out.promptButtons).forEach(function(key) {
        if(saved.promptButtons[key] && typeof saved.promptButtons[key] === "object") {
          if(saved.promptButtons[key].order !== undefined) out.promptButtons[key].order = Number(saved.promptButtons[key].order) || out.promptButtons[key].order;
          if(saved.promptButtons[key].enabled !== undefined) out.promptButtons[key].enabled = !!saved.promptButtons[key].enabled;
        }
      });
    }
    return out;
  }
  window.___loadUiPrefs_FAST = function() {
