        const cell = document.createElement("div");
        cell.style.cssText = "display:flex;align-items:center;justify-content:center;padding:0.35rem 0.25rem;border-radius:3px;cursor:pointer;background:var(--box-color,#2a2a2a);font-size:0.75rem;text-align:center;min-height:2.2rem;";
        cell.textContent = name;
        cell.title = code;
        cell.onmouseover = function(){ cell.style.background = "#3a3a3a"; };
        cell.onmouseout = function(){ cell.style.background = "var(--box-color,#2a2a2a)"; };
        cell.onclick = function(){ resolve2({ name: name, code: code }); };
        frag2.appendChild(cell);
      });
      grid2.appendChild(frag2);
    }
    renderLangList("");
