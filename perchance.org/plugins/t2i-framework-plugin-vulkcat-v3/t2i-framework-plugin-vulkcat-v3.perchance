        const parsed = ___parseEmojiLabel_FAST(entry.label);
        const cell = document.createElement("div");
        cell.style.cssText = "display:flex;flex-direction:column;align-items:center;justify-content:center;padding:0.55rem 0.3rem;border-radius:3px;cursor:pointer;background:var(--box-color,#2a2a2a);font-size:0.74rem;text-align:center;gap:0.16rem;min-height:5.2rem;";
        const emojiEl = document.createElement("span");
        emojiEl.style.cssText = "font-size:1.25rem;line-height:1;";
        emojiEl.textContent = parsed.emoji || "🪐";
        const nameEl = document.createElement("span");
        nameEl.style.cssText = "word-break:break-word;line-height:1.2;";
        nameEl.textContent = parsed.text || entry.label;
        cell.append(emojiEl, nameEl);
        cell.onmouseover = function(){ cell.style.background = "#3a3a3a"; };
        cell.onmouseout = function(){ cell.style.background = "var(--box-color,#2a2a2a)"; };
