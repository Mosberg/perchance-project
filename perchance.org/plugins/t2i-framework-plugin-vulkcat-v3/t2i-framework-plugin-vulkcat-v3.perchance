  window.___ensureVideoGeneratorEmbed_FAST = async function() {
    const host = document.getElementById("videoGeneratorEmbedHost_FAST");
    if(!host) return;
    if(host.dataset.ready === "1" && host.querySelector("iframe")) return;
    host.dataset.ready = "0";
    host.innerHTML = '<div style="padding:0.65rem;text-align:center;opacity:0.85;">Loading embedded video generator...</div>';
    try {
      host.innerHTML = "";
      const frame = document.createElement("iframe");
      frame.src = ___VIDEO_GENERATOR_SRC_FAST;
      frame.id = "videoGeneratorApp_FAST";
      frame.loading = "lazy";
      frame.referrerPolicy = "no-referrer";
      frame.allow = "clipboard-write; autoplay; fullscreen";
      frame.title = "Embedded video generator";
      host.appendChild(frame);
      host.dataset.ready = "1";
    } catch(err) {
      host.innerHTML = '<div style="padding:0.65rem;text-align:center;opacity:0.85;">Could not load embedded generator. <a href="' + ___VIDEO_GENERATOR_SRC_FAST + '" target="_blank" rel="noopener noreferrer">Open generator</a>.</div>';
      host.dataset.ready = "0";
    }
  };
  window.___videoFlow_FAST = { token: 0, state: "idle", retries: 0, maxRetries: 2, pollTimer: null, timeouts: [], listeners: [] };
  window.___setVideoFlowState_FAST = function(nextState, msg, progressPct) {
    const flow = window.___videoFlow_FAST;
    flow.state = nextState;
    const hint = document.getElementById("videoUploadHint_FAST");
    const bar = document.getElementById("videoFlowBar_FAST");
    if(hint) { hint.style.display = ""; hint.textContent = msg || ""; }
    if(bar) bar.style.width = Math.max(0, Math.min(100, Number(progressPct) || 0)) + "%";
    console.log("[T2I_FAST][VIDEO]", nextState, msg || "");
  };
  window.___cleanupVideoFlow_FAST = function(token) {
    const flow = window.___videoFlow_FAST;
    if(token && flow.token !== token) return;
    if(flow.pollTimer) { clearInterval(flow.pollTimer); flow.pollTimer = null; }
    flow.timeouts.forEach(function(t){ clearTimeout(t); });
    flow.timeouts = [];
    flow.listeners.forEach(function(l){ try { l.target.removeEventListener(l.event, l.handler); } catch(e){} });
    flow.listeners = [];
  };
  window.___overlayVideoOnCard_FAST = function(ctn, videoSrc) {
    if(!ctn || !videoSrc) return;
    const wrap = ctn.querySelector(".t2i-img-wrap");
    if(!wrap) return;
    let existing = wrap.querySelector("video.t2i-generated-video_FAST");
    if(existing) existing.remove();
    const vid = document.createElement("video");
    vid.className = "t2i-generated-video_FAST";
    vid.src = videoSrc;
    vid.autoplay = true;
    vid.loop = true;
    vid.muted = true;
    vid.playsInline = true;
    vid.controls = true;
    vid.style.cssText = "position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:7;background:#000;";
    wrap.style.position = "relative";
    wrap.appendChild(vid);
    ctn.dataset.videoSrcFast = videoSrc;
  };
  window.___attemptVideoAutoUpload_FAST = async function(imageSrc) {
    // Note: direct DOM automation inside cross-origin/sandboxed iframes is blocked by browser security.
    // We use best-effort clipboard + postMessage + polling fallback without claiming guaranteed auto-upload.
    const frame = document.getElementById("videoGeneratorApp_FAST");
    const hint = document.getElementById("videoUploadHint_FAST");
    const payload = { type:"T2I_FAST_VIDEO_UPLOAD", imageSrc:imageSrc, ts:Date.now() };
    let clipboardOk = false;
    try {
      const res = await fetch(imageSrc);
      const blob = await res.blob();
      if(navigator.clipboard && window.ClipboardItem) {
        await navigator.clipboard.write([new ClipboardItem({ [blob.type || "image/png"]: blob })]);
        clipboardOk = true;
      }
    } catch(err) {
      console.warn("[T2I_FAST][VIDEO] clipboard step failed", err);
    }
    try {
      if(frame && frame.contentWindow) frame.contentWindow.postMessage(payload, "*");
    } catch(err) {
      console.warn("[T2I_FAST][VIDEO] postMessage blocked", err);
    }
    if(frame) {
      try { frame.focus(); } catch(e) {}
    }
    if(hint && !clipboardOk) {
      hint.textContent = "Auto-upload limitado por sandbox/cross-origin. Se intentó postMessage/clipboard; usa Ctrl+V dentro del iframe si es necesario.";
    }
  };
  window.___setVideoMode_FAST = function(enabled) {
    window.___isVideoMode_FAST = !!enabled;
    if(window.___isVideoMode_FAST) document.body.setAttribute("data-video-mode-fast", "1");
    else document.body.removeAttribute("data-video-mode-fast");
    const btn = document.getElementById("videoModeToggleBtn_FAST");
    const videoPanel = document.getElementById("videoModePanel_FAST");
    const output = document.getElementById("outputAreaEl_FAST");
    const imageScale = document.getElementById("imageScaleRow_FAST");
    if(btn) btn.textContent = enabled ? "✏️ Image Mode" : "🎬 Video Mode";
    if(videoPanel) videoPanel.style.display = enabled ? "" : "none";
    if(output) output.style.display = "";
