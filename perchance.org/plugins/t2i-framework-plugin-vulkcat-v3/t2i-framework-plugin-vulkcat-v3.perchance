  }
  window.___imageScale_FAST = Number(localStorage.___imageScale_FAST || 100);
  function _scaleOneCtn(ctn, pct) {
    if (!ctn.dataset.naturalW || ctn.dataset.naturalW === "0" || ctn.dataset.naturalW === "") {
      const iframe = ctn.querySelector(".t2i-img-wrap iframe, iframe");
      if (iframe) {
        const w = iframe.offsetWidth || parseInt(iframe.width) || parseInt(iframe.style.width) || 0;
        if (w > 0) ctn.dataset.naturalW = w;
      }
    }
    const natural = parseInt(ctn.dataset.naturalW || "0");
    if (!natural) return;
