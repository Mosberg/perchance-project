    if(___videoGradioRuntimePromise_FAST) return ___videoGradioRuntimePromise_FAST;
    ___videoGradioRuntimePromise_FAST = new Promise(function(resolve, reject) {
      const existing = document.querySelector('script[data-video-gradio-runtime-fast="1"]');
      if(existing) {
        existing.addEventListener("load", function(){ resolve(); }, { once:true });
        existing.addEventListener("error", function(){ reject(new Error("Failed loading Gradio runtime")); }, { once:true });
        return;
      }
      const script = document.createElement("script");
      script.type = "module";
      script.src = ___VIDEO_GRADIO_RUNTIME_FAST;
      script.dataset.videoGradioRuntimeFast = "1";
