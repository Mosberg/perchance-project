      { icon:"🗒️", label:"Send Notepad", run:function(text){ const scratchEl = window.userInputsCtn_FAST ? window.userInputsCtn_FAST.querySelector("textarea[data-name='scratchpad']") : null; if(!scratchEl) return Promise.resolve(); appendTranslatedText(scratchEl, text, "notepad"); return Promise.resolve(); }}
