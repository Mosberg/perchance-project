    }
    document.addEventListener("keydown", escHandler);
    overlay.append(btnPrev, imgWrap, btnNext, closeBtn);
    imgWrap.appendChild(img);
    document.body.appendChild(overlay);
    loadIdx(idx);
  };
  window.___toggleRatePopup_FAST = function(btn, e) {
