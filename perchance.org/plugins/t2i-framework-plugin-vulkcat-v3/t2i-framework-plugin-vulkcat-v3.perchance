// plugin name: generator-framework-vulkcat-v3
kv = {import:kv-plugin}
textToImagePlugin = {import:text-to-image-plugin}
selectLeaf = {import:select-leaf-plugin}
aiText = {import:ai-text-plugin}
styleManagerPlugin = {import:style-manager-plugin-vulkcat}
cloudServicePlugin = {import:cloud-service-vulkcat}
createMediaGalleryPlugin = {import:private-gallery-framework-vulkcat}

promptTemplatePanel = {import:templates-framework-vulkcat}

$output(settings) =>
  if(!window.input) window.input = {};

  if(!window.t2i) {
    window.t2i = {};
    window.t2i.defaultText = {
      promptTip: `Tip: You can write text like &lcub;blue|red|green&rcub; and a random one will be chosen for each image.\n\nClick the info icon on an image to see the prompt that was used.\n\nAdd brackets around text (like this) or ((even more)) to get the AI to pay more attention to it.`,
      negativePromptTip: `Important: If, for example, you don't want the image to have blue in it, just write "blue" in this box. Don't write "no blue"!`,
      scratchpadTip: `A little notepad for you to keep good prompts and stuff.`,
    };
    window.t2i.handyText = window.t2i.defaultText;
  }
  if(!settings.imageOptions) settings.imageOptions = {};
  if(!settings.imageOptions.style) settings.imageOptions.style = "";

  if(!settings.promptTemplateConfig) settings.promptTemplateConfig = {};
  if(settings.promptTemplateConfig.title === undefined) settings.promptTemplateConfig.title = "Character Prompt Builder";
  if(settings.promptTemplateConfig.storageKey === undefined) settings.promptTemplateConfig.storageKey = "prompt_template_plugin_vulkcat_v1";
  if(!settings.promptTemplateConfig.html) settings.promptTemplateConfig.html = promptTemplatePanel;
  function ___initImportedPlugin_FAST(pluginRef) {
    try {
      if(typeof pluginRef === "function") return pluginRef();
      if(pluginRef && typeof pluginRef.evaluateItem === "function") return pluginRef.evaluateItem();
      if(pluginRef && pluginRef.evaluateItem !== undefined) return pluginRef.evaluateItem;
      return pluginRef;
    } catch(e) { return null; }
  }
  ___initImportedPlugin_FAST(styleManagerPlugin);
  ___initImportedPlugin_FAST(cloudServicePlugin);
  function ___getEl_FAST(sel, root) {
    return (root || document).querySelector(sel);
  }
  function ___getAll_FAST(sel, root) {
    return Array.from((root || document).querySelectorAll(sel));
  }
  function ___runInitHealthChecks_FAST() {
    const warnings = [];
    if(!window.___openStyleManager_FAST) warnings.push("style-manager hook missing");
    if(!(window.___cloudService_FAST && typeof window.___cloudService_FAST.openModal === "function")) warnings.push("cloud-service hook missing");
    if(typeof (window.___textToImagePlugin_FAST || window.textToImagePlugin || window.t2i_textToImage) !== "function") warnings.push("text-to-image hook missing");
    if(warnings.length) console.warn("[T2I_FAST init health]", warnings.join(" | "));
    return warnings;
  }
  window.___t2iInitHealth_FAST = ___runInitHealthChecks_FAST;
  ___runInitHealthChecks_FAST();

  function ___cfgKeys_FAST(obj) {
    return ___cfgEntries_FAST(obj).map(function(entry) { return entry.key; });
  }
  function ___cfgSelectAll_FAST(obj) {
    if(!obj) return [];
    if(obj.selectAll && typeof obj.selectAll[Symbol.iterator] === "function") return Array.from(obj.selectAll);
    if(obj.getAllKeys && typeof obj.getAllKeys[Symbol.iterator] === "function") {
      return Array.from(obj.getAllKeys).map(function(key) { return obj[key]; }).filter(Boolean);
    }
    return [];
  }
  function ___cfgEntries_FAST(obj) {
    if(!obj) return [];
    if(typeof obj !== "object") return [];
    if(obj.evaluateItem !== undefined && !(obj.selectAll || obj.getAllKeys || obj.getChildNames)) return [];
    if(obj.getChildNames && typeof obj.getChildNames[Symbol.iterator] === "function") {
      return Array.from(obj.getChildNames).map(function(key) { return { key: String(key), value: obj[key] }; }).filter(function(entry){ return entry.value !== undefined; });
    }
    if(obj.getAllKeys && typeof obj.getAllKeys[Symbol.iterator] === "function") {
      return Array.from(obj.getAllKeys).map(function(key) { return { key: String(key), value: obj[key] }; }).filter(function(entry){ return entry.value !== undefined; });
    }
    const selected = ___cfgSelectAll_FAST(obj);
    if(selected.length) {
      return selected.map(function(child, idx) {
        const key = String(child?.getName || child?.name || child?.label?.evaluateItem || ("item" + idx));
        return { key: key, value: child };
      }).filter(function(entry){ return entry.value !== undefined; });
    }
    return Object.keys(obj).filter(function(key){ return key !== "getChildNames" && key !== "selectAll"; }).map(function(key){ return { key: key, value: obj[key] }; });
  }
  function ___cfgVal_FAST(val) {
    return (val && typeof val === "object" && val.evaluateItem !== undefined) ? val.evaluateItem : val;
  }

  function ___sentenceCase_FAST(name) {
    const txt = String(name || "").replace(/([a-z])([A-Z])/g, "$1 $2").replace(/[_-]+/g, " ").trim();
    return txt ? (txt.charAt(0).toUpperCase() + txt.slice(1)) : "";
  }
  function ___looksLikeInput_FAST(rawItem) {
    if(!rawItem || typeof rawItem !== "object") return false;
    const keys = ___cfgKeys_FAST(rawItem);
    return keys.some(function(key) {
      return ["type","options","examples","random","randomAppend","modifiers","channels","parseVariables","foldToggleState","takesUpFullRow","remember","useVariables","modifierUpdates","height","width"].includes(key);
    });
  }
  function ___createInputSpec_FAST(name, rawItem) {
    const spec = { getName: name, name: name };
    ___cfgEntries_FAST(rawItem).forEach(function(entry) {
      spec[entry.key] = entry.value;
    });
    if(spec.label === undefined) spec.label = ___sentenceCase_FAST(name);
    return spec;
  }
  function ___walkInputNodes_FAST(node, visit, parentCategoryId) {
    if(!node || typeof node !== "object") return;
    ___cfgEntries_FAST(node).forEach(function(entry) {
      if(!entry || !entry.value) return;
      if(___looksLikeInput_FAST(entry.value)) {
        visit(entry.key, entry.value, parentCategoryId || "");
        return;
      }
      ___walkInputNodes_FAST(entry.value, visit, parentCategoryId || "");
    });
  }
  function ___normalizeCategoryBar_FAST(rawBar) {
    const out = { width: "fit-content", items: [], looseInputs: [] };
    if(rawBar && ___cfgVal_FAST(rawBar.width)) out.width = String(___cfgVal_FAST(rawBar.width));
    const metaKeys = { width:1, label:1, id:1, special:1, settingsOnly:1 };
    ___cfgEntries_FAST(rawBar).forEach(function(entry) {
      const key = entry.key;
      const item = entry.value;
      if(key === "width") return;
      if(!item) return;
      if(___looksLikeInput_FAST(item)) {
        out.looseInputs.push({ name: key, raw: item });
        return;
      }
      const label = String(___cfgVal_FAST(item.label) || ___sentenceCase_FAST(key));
      const id = String(___cfgVal_FAST(item.mode ?? item.id) || ___slugCategoryId_FAST(label, key));
      const isSettings = ___cfgVal_FAST(item.special) === true || ___cfgVal_FAST(item.settingsOnly) === true || id === "settings" || /settings/i.test(key) || /settings/i.test(label);
      const inputKeys = [];
      if(!isSettings) {
        ___cfgEntries_FAST(item).forEach(function(childEntry) {
          if(metaKeys[childEntry.key]) return;
          if(___looksLikeInput_FAST(childEntry.value)) inputKeys.push(childEntry.key);
        });
      }
      out.items.push({ keyName: key, id: id, label: label, isSettings: isSettings, inputKeys: inputKeys, raw: item });
    });
    if(!out.items.length) {
      out.items = [
        { keyName:"image", id:"image", label:"🎨 Image", isSettings:false, inputKeys:[], raw:null },
        { keyName:"prompt", id:"prompt", label:"✏️ Prompt", isSettings:false, inputKeys:[], raw:null },
        { keyName:"img2img", id:"img2img", label:"🎭 Img2Img", isSettings:false, inputKeys:[], raw:null },
        { keyName:"settings", id:"settings", label:"🛠️ Settings", isSettings:true, inputKeys:[], raw:null }
      ];
    }
    return out;
  }
  window.___categoryBar_FAST = ___normalizeCategoryBar_FAST(settings.categoryBar || null);
  window.___categoryBar_FAST.items = (window.___categoryBar_FAST.items || []).filter(function(item){ return String(item.id || "") !== "template"; });
  (function() {
    const originalInputs = settings.userInputs || { getChildNames: [], selectAll: [] };
    const categoryIds = new Set(window.___categoryBar_FAST.items.map(function(category) { return String(category.id || ""); }));
    function resolveInputCategoryId(rawItem, fallbackCategoryId) {
      const rawId = rawItem ? ___cfgVal_FAST(rawItem.category) : undefined;
      const normalized = rawId === undefined || rawId === null || rawId === "" ? "" : String(rawId);
      if(normalized && categoryIds.has(normalized)) return normalized;
      return fallbackCategoryId || "";
    }
    ___cfgEntries_FAST(originalInputs).forEach(function(entry) {
      if(!entry || !entry.value) return;
      entry.value.___categoryId_FAST = resolveInputCategoryId(entry.value, "");
    });
    settings.userInputs = originalInputs;
  })();
  function ___defaultInputValue_FAST(name, spec) {
    const type = String(___cfgVal_FAST(spec.type) || "");
    if(name === "seed") return "-1";
    if(type === "paragraph" || type === "text") {
      if(name === "numImages") return "6";
      if(name === "guidanceScale") return "13";
      return "";
    }
    if(type === "number-stepper") {
      if(name === "numImages") return "6";
      if(name === "guidanceScale") return "13";
      const min = Number(___cfgVal_FAST(spec.min) || 1);
      return String(min);
    }
    if(type === "gradio") return "";
    if(type === "select" || type === "visual-select") {
      const optionKeys = ___cfgKeys_FAST(spec.options).filter(function(key) { return !String(key).startsWith("meta:"); });
      if(name === "artStyle" || name === "style") {
        if(optionKeys.length && spec.options && spec.options[optionKeys[0]]) {
          const opt = spec.options[optionKeys[0]];
          if(opt && opt.getName === undefined) opt.getName = optionKeys[0];
          if(opt && opt.name === undefined) opt.name = optionKeys[0];
          if(opt && opt.prompt === undefined) opt.prompt = "";
          if(opt && opt.negative === undefined) opt.negative = "";
          if(opt && opt.negativePrompt === undefined) opt.negativePrompt = opt.negative;
          return opt;
        }
        return { getName:"Style", name:"Style", prompt:"", negative:"", negativePrompt:"" };
      }
      if(name === "numImages") return optionKeys.includes("6") ? "6" : (optionKeys[0] || "6");
      if(name === "shape" || name === "resolution") return optionKeys[0] || "Square";
      return optionKeys[0] || "";
    }
    return "";
  }
  settings.userInputs.getChildNames.forEach(function(name) {
    if(window.input[name] === undefined) window.input[name] = ___defaultInputValue_FAST(name, settings.userInputs[name]);
    settings.userInputs[name].value = window.input[name];
  });
  const ___T2I_OFFICIAL_HOST_URL_FAST = "https://perchance.org/better-generator-vulkcat-v2";
  const ___T2I_OFFICIAL_HOST_EDIT_URL_FAST = "https://perchance.org/better-generator-vulkcat-v2#edit";
  const ___T2I_OFFICIAL_PLUGIN_URL_FAST = "https://perchance.org/t2i-framework-plugin-vulkcat-v3";
  const ___T2I_OFFICIAL_PLUGIN_EDIT_URL_FAST = "https://perchance.org/t2i-framework-plugin-vulkcat-v3#edit";
  const ___T2I_OFFICIAL_HOST_V3_URL_FAST = "https://perchance.org/better-generator-vulkcat-v3";
  const ___T2I_OFFICIAL_HOST_V3_EDIT_URL_FAST = "https://perchance.org/better-generator-vulkcat-v3#edit";
  const ___T2I_SCRATCHPAD_PLACEHOLDER_FAST = "𝗖𝘂𝘀𝘁𝗼𝗺 𝗦𝘆𝗻𝘁𝗮𝘅:\nDefine variables like:\nTEXT1 = Hello World!\nin scratchpad and use them in prompts with [TEXT1] to display Hello World! in final result prompt.\n\n𝗖𝗵𝗮𝗶𝗻𝗲𝗱 𝗥𝗲𝗳𝗲𝗿𝗲𝗻𝗰𝗲𝘀:\nFor example, set\nA = 1\nin the scratchpad, and\nB = [A], 2\non the next line. Then, placing [B] in the prompt box will display 1, 2 in the result prompt.\n*(𝘝𝘢𝘳𝘪𝘢𝘣𝘭𝘦𝘴 𝘮𝘶𝘴𝘵 𝘣𝘦 𝘶𝘱𝘱𝘦𝘳𝘤𝘢𝘴𝘦, 𝘤𝘢𝘯𝘯𝘰𝘵 𝘣𝘦 𝘯𝘶𝘮𝘦𝘳𝘪𝘤-𝘰𝘯𝘭𝘺, 𝘢𝘯𝘥 𝘦𝘢𝘤𝘩 𝘴𝘺𝘯𝘵𝘢𝘹 𝘥𝘦𝘧𝘪𝘯𝘪𝘵𝘪𝘰𝘯 𝘴𝘩𝘰𝘶𝘭𝘥 𝘣𝘦 𝘰𝘯 𝘢 𝘯𝘦𝘸 𝘭𝘪𝘯𝘦.)\n\n𝗜𝗻𝘀𝗲𝗿𝘁 𝗢𝘃𝗲𝗿𝗿𝗶𝗱𝗲:\nYou can use\nDESCRIPTION =\nin scratchpad to set a replacement text for the random example insert button ⤶ in the prompt box.\nExample: Set\nDESCRIPTION = [B], 3, [TEXT1]\nwill insert 1, 2, 3, Hello World! in prompt box when clicking ⤶";
  const ___VIDEO_GENERATOR_SRC_FAST = "https://r3gm-wan2-2-fp8da-aoti-preview2.hf.space";
  const ___VIDEO_GRADIO_RUNTIME_FAST = "https://gradio.s3-us-west-2.amazonaws.com/6.0.1/gradio.js";
  /* MAIN GENERATOR MAX WIDTH - adjust here (use px value like "860px" or "940px") */
  const ___T2I_MAIN_MAX_WIDTH_FAST = "820px";
  let ___videoGradioRuntimePromise_FAST = null;
  function ___normalizeUrlBase_FAST(url) {
    return String(url || "").split("#")[0].split("?")[0];
  }
  function ___slugFromUrl_FAST(url) {
    const clean = ___normalizeUrlBase_FAST(url);
    const noProto = clean.replace("https://", "").replace("http://", "");
    const parts = noProto.split("/");
    return parts.length > 1 ? String(parts[1] || "").toLowerCase() : "";
  }
  function ___slugFromGeneratorName_FAST(name) {
    const raw = String(name || "").trim();
    if(!raw) return "";
    if(raw.indexOf("://") !== -1) return ___slugFromUrl_FAST(raw);
    if(raw.charAt(0) === "/") return ___slugFromUrl_FAST("https://perchance.org" + raw);
    return raw.split("/")[0].split("?")[0].split("#")[0].toLowerCase();
  }
  window.___isOfficialVulkcatUrl_FAST = function(url) {
    const current = ___normalizeUrlBase_FAST(url || location.href);
    return current === ___normalizeUrlBase_FAST(___T2I_OFFICIAL_HOST_URL_FAST)
      || current === ___normalizeUrlBase_FAST(___T2I_OFFICIAL_HOST_EDIT_URL_FAST)
      || current === ___normalizeUrlBase_FAST(___T2I_OFFICIAL_PLUGIN_URL_FAST)
      || current === ___normalizeUrlBase_FAST(___T2I_OFFICIAL_PLUGIN_EDIT_URL_FAST)
      || current === ___normalizeUrlBase_FAST(___T2I_OFFICIAL_HOST_V3_URL_FAST)
      || current === ___normalizeUrlBase_FAST(___T2I_OFFICIAL_HOST_V3_EDIT_URL_FAST);
  };
  window.___isOfficialVulkcatExecution_FAST = function() {
    const normalizedCurrent = ___normalizeUrlBase_FAST(location.href);
    const runtimeSlug = ___slugFromUrl_FAST(location.href);
    const generatorSlug = ___slugFromGeneratorName_FAST(window.generatorName);
    const exactAllowed = normalizedCurrent === ___normalizeUrlBase_FAST(___T2I_OFFICIAL_HOST_URL_FAST)
      || normalizedCurrent === ___normalizeUrlBase_FAST(___T2I_OFFICIAL_HOST_EDIT_URL_FAST)
      || normalizedCurrent === ___normalizeUrlBase_FAST(___T2I_OFFICIAL_PLUGIN_URL_FAST)
      || normalizedCurrent === ___normalizeUrlBase_FAST(___T2I_OFFICIAL_PLUGIN_EDIT_URL_FAST)
      || normalizedCurrent === ___normalizeUrlBase_FAST(___T2I_OFFICIAL_HOST_V3_URL_FAST)
      || normalizedCurrent === ___normalizeUrlBase_FAST(___T2I_OFFICIAL_HOST_V3_EDIT_URL_FAST);
    const isOfficialHost = location.hostname === "perchance.org" || location.hostname.endsWith(".perchance.org");
    const isHttps = location.protocol === "https:";
    const runtimeAllowed = runtimeSlug === "better-generator-vulkcat-v2" || runtimeSlug === "better-generator-vulkcat-v3" || runtimeSlug === "t2i-framework-plugin-vulkcat-v3";
    const generatorAllowed = !generatorSlug || generatorSlug === "better-generator-vulkcat-v2" || generatorSlug === "better-generator-vulkcat-v3" || generatorSlug === "t2i-framework-plugin-vulkcat-v3";
    return isHttps && isOfficialHost && (exactAllowed || (runtimeAllowed && generatorAllowed));
  };
  window.___renderForkBlockHtml_FAST = function() {
    return '<div id="___forkBlockOverlay_FAST" style="position:fixed;inset:0;background:#000;color:#ff5656;display:flex;align-items:center;justify-content:center;padding:1.5rem;box-sizing:border-box;text-align:center;font-family:system-ui,sans-serif;z-index:2147483647;">'
