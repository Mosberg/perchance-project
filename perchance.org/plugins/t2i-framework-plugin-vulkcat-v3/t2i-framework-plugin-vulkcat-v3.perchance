  window.___uiPrefs_FAST = window.___loadUiPrefs_FAST();
  function ___getPromptButtonDefs_FAST() {
    const prefs = (window.___uiPrefs_FAST && window.___uiPrefs_FAST.promptButtons) || ___defaultUiPrefs_FAST().promptButtons;
    return [
      { key:"search", emoji:"🔎", title:"Search in prompt", action:"window.___promptSearchToggle_FAST(this)" },
      { key:"imageToPrompt", emoji:"🖼️", title:"Image to Prompt", action:"window.___openImageToPromptModal_FAST(this)" },
      { key:"undoRedo", emoji:"🌊", title:"Undo / Redo", action:"window.___toggleUndoRedoPanel_FAST(this)" },
