    const clearBtn = document.createElement("button");
    clearBtn.type = "button";
    clearBtn.textContent = "✖️";
    clearBtn.style.cssText = "background:none;border:none;box-shadow:none;padding:0;cursor:pointer;font-size:1rem;line-height:1;color:inherit;display:none;position:absolute;left:0.65rem;top:0.5rem;";
    const maxBtn = document.createElement("button");
