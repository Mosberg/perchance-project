  window.___translatePrompt_FAST = async function(btn) {
    const promptEl = window.userInputsCtn_FAST ? window.userInputsCtn_FAST.querySelector("textarea[data-name='description'], textarea[data-name='prompt']") : null;
    if(!promptEl) return;
    const fullText = promptEl.value; if(!fullText.trim()) return;
    const start = Number(promptEl.selectionStart || 0);
    const end = Number(promptEl.selectionEnd || 0);
    const hasSelection = end > start;
    const text = hasSelection ? fullText.slice(start, end) : fullText.trim();
    if(!text.trim()) return;
    const targetLang = window.___t2iLangTo_FAST || "en";
    const origText = btn.textContent;
    btn.textContent = "⏳"; btn.disabled = true;
    const translated = await window.___t2iTranslate_FAST(text, "auto", targetLang);
    if(hasSelection) {
      promptEl.value = fullText.slice(0, start) + translated + fullText.slice(end);
      promptEl.selectionStart = start;
      promptEl.selectionEnd = start + translated.length;
    } else {
      promptEl.value = translated;
    }
    promptEl.oninput({});
    btn.textContent = origText; btn.disabled = false;
  };
