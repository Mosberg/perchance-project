  window.___syncOpenFromSidebar_FAST = function(btn) {
    window.___toggleSidebar_FAST();
    window.___syncOpenMenu_FAST(btn || document.getElementById("hamburgerBtn_FAST"));
  };
  window.___openSettingsModal_FAST = function() {
    window.___toggleSidebar_FAST();
    window.___renderSettingsPanel_FAST();
  };
  window.___refreshSidebarLiveActivity_FAST = function() {
    return;
  };
  window.___initSidebarResize_FAST = function() {
    const sidebar = document.getElementById("leftSidebar_FAST");
    const handle = document.getElementById("sidebarResizeHandle_FAST");
    if(!sidebar || !handle || handle.dataset.boundFast === "1") return;
    handle.dataset.boundFast = "1";
    const minW = 210;
    const saved = Number(localStorage.___sidebarWidth_FAST || 270);
    const clampWidth = function(val) {
      const maxW = Math.max(280, Math.floor(window.innerWidth * 0.7));
      return Math.max(minW, Math.min(maxW, Number(val) || 270));
    };
    sidebar.style.width = clampWidth(saved) + "px";
    const onMove = function(ev) {
      const w = clampWidth(ev.clientX || 0);
      sidebar.style.width = w + "px";
      localStorage.___sidebarWidth_FAST = String(w);
    };
    const onUp = function() {
      document.removeEventListener("mousemove", onMove);
      document.removeEventListener("mouseup", onUp);
      document.body.classList.remove("sidebar-resizing_FAST");
    };
    handle.addEventListener("mousedown", function(ev) {
      ev.preventDefault();
      document.body.classList.add("sidebar-resizing_FAST");
      document.addEventListener("mousemove", onMove);
      document.addEventListener("mouseup", onUp);
    });
    window.addEventListener("resize", function() {
      sidebar.style.width = clampWidth(sidebar.offsetWidth) + "px";
    });
  };
  window.___resolveGeneratedImageSrcFromCtn_FAST = function(ctn) {
    if(!ctn || !ctn.querySelector) return "";
    const img = ctn.querySelector("img");
    if(img && img.src) return img.src;
    const iframe = ctn.querySelector("iframe");
    const dataUrl = iframe && iframe.textToImagePluginOutput ? iframe.textToImagePluginOutput.dataUrl : "";
    return dataUrl || "";
