      return '<div style="color:#ff6b6b;padding:1rem;">Failed to render Prompt Template Plugin: ' + String(e.message) + '</div>';
    }
    if(Array.isArray(htmlContent)) htmlContent = htmlContent.join("");
    return String(htmlContent || "");
  };

