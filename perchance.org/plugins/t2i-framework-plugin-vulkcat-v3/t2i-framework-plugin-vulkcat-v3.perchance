      .prompt-search-bar button \{ min-width:1.9rem;height:1.9rem;border:none;border-radius:3px;cursor:pointer; \}
      .t2i-under-each-image-ctn .private-save-button \{ opacity: 0.55; \}
      .t2i-under-each-image-ctn .private-save-button:hover \{ opacity: 1; \}
      /* Rate popup */
      .t2i-heart-btn.rated \{ background: #e53935 !important; \}
      .heart-rate-display \{ pointer-events: none; font-size: 11px; font-weight: bold; line-height: 1; display:flex;align-items:center;justify-content:center; \}
      .t2i-image-ctn \{ position: relative; flex-shrink: 0; box-sizing: border-box; margin: 0; display: flex; flex-direction: column; cursor: default; \}
      iframe.text-to-image-plugin-image-iframe \{ max-width: 100%; border-radius: 0; \}
      .t2i-image-ctn iframe \{ display: block; width: 100% !important; max-width: 100%; height: auto; flex: 1 1 auto; border-radius: 0; \}
      .t2i-image-ctn img \{ display: block; width: 100%; height: auto; border-radius: 0; \}
      .img-overlay-btn \{ position: absolute; width: 26px; height: 26px; border-radius: 50%; background: #ffffff; border: none; box-shadow: none; cursor: pointer; display: flex; align-items: center; justify-content: center; padding: 0; opacity: 0; z-index: 10; line-height: 1; \}
      .t2i-img-wrap:hover .img-overlay-btn \{ opacity: 1; \}
      .img-overlay-btn svg \{ pointer-events: none; \}
      .img-overlay-tl \{ top:  2px; left:  2px; \}
      .img-overlay-tr \{ top:  2px; right: 2px; \}
      .img-overlay-bl \{ bottom: 2px; left:  2px; \}
      .img-overlay-br \{ bottom: 2px; right: 2px; \}
      .t2i-img-wrap \{ overflow: hidden; \}
      .t2i-rate-popup \{ pointer-events: auto; \}
      .t2i-image-ctn[data-pinned="1"] .t2i-img-wrap \{ outline: 2px solid #e08020; \}
      .t2i-image-ctn[data-pinned="1"] .img-overlay-tr \{ opacity: 1; background: #e08020; \}
      /* Translator */
      .input-ctn[data-fold-toggle-state='hidden'] .t2i-translator-ui \{ display: none !important; \}
      .input-ctn[data-fold-toggle-state='shown']  .t2i-translator-ui \{ display: flex !important; flex-direction: column; \}
      #outputAreaEl_FAST \{ display: flex; flex-wrap: wrap; justify-content: center; align-items: flex-start; padding: 0; gap: 8px; min-height: 2rem; margin-top: 0; \}
      .t2i-under-each-image-ctn \{ font-size: 0.75rem; line-height: 1; flex-shrink: 0; padding-top: 0.3rem; \}
      .image-scale-row \{ display: flex; align-items: center; justify-content: center; gap: 0.2rem; margin-bottom: 0.3rem; \}
      .style-picker-btn \{ min-height:1.72rem; height:1.72rem; color:inherit; border:none; border-radius:3px; box-sizing:border-box; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; display:block; \}
      .input-type-select select \{ height:1.72rem; min-height:1.72rem; line-height:1.72rem; padding:0 0.5rem; box-sizing:border-box; \}
      .style-picker-row_FAST \{ width: 100%; display:flex; align-items:stretch; gap:0.25rem; \}
      .style-picker-row_FAST .style-picker-btn \{ flex:1; min-height:1.72rem; height:1.72rem; \}
      .settings-card_FAST \{ width:min(500px,100%); margin:0 auto; background:var(--box-color,#2a2a2a); border-radius:5px; padding:0.6rem 0.75rem; box-sizing:border-box; \}
      .settings-title_FAST \{ font-size:1rem; font-weight:600; text-align:center; margin-bottom:0.65rem; \}
      .settings-row_FAST \{ display:flex; align-items:center; justify-content:space-between; gap:0.6rem; padding:0.45rem 0; border-bottom:1px solid rgba(255,255,255,0.06); \}
      .settings-row_FAST span \{ font-size:0.9rem; \}
      .settings-row-controls_FAST,.settings-order-controls_FAST \{ display:flex; align-items:center; gap:0.35rem; \}
      .settings-select_FAST,.settings-order-select_FAST \{ height:1.9rem; box-sizing:border-box; font-size:0.88rem; \}
      .settings-order-select_FAST \{ width:3.4rem; \}
      .settings-link-btn_FAST,.settings-action-btn_FAST \{ border:none; border-radius:3px; cursor:pointer; padding:0.32rem 0.72rem; font-size:0.9rem; color:inherit; \}
      .settings-footer_FAST \{ display:flex; flex-wrap:wrap; justify-content:center; gap:0.6rem; padding-top:0.9rem; \}
      .floating-bottom-btn_FAST \{ pointer-events:auto; cursor:pointer; border:none; border-radius:3px; padding:0.2rem 0.5rem; font-size:0.82rem; white-space:nowrap; color:inherit; \}
      #hamburgerBtn_FAST \{ position:fixed; top:0.45rem; left:0.45rem; z-index:100000000; pointer-events:auto; cursor:pointer; border:none; border-radius:4px; background:#2a2a2a; color:inherit; padding:0.18rem 0.55rem; font-size:1.1rem; \}
      #leftSidebar_FAST \{ position:fixed; top:0; left:0; bottom:0; width:270px; min-width:210px; max-width:70vw; overflow-x:hidden; overflow-y:auto; background:#1d1d1d; border-right:1px solid #303030; z-index:10000; transform:translateX(-104%); transition:transform 0.2s ease; padding:2.6rem 0.7rem 0.9rem; box-sizing:border-box; text-align:center; \}
      #leftSidebar_FAST[data-open="1"] \{ transform:translateX(0); \}
      .sidebar-resize-handle_FAST \{ position:absolute; top:0; right:0; width:10px; height:100%; cursor:ew-resize; background:transparent; \}
      .sidebar-resize-handle_FAST:hover \{ background:rgba(255,255,255,0.08); \}
      body.sidebar-resizing_FAST \{ user-select:none; cursor:ew-resize; \}
      .sidebar-line_FAST \{ width:100%; display:flex; justify-content:center; gap:0.5rem; flex-wrap:wrap; margin-bottom:0.5rem; \}
      .sidebar-chip_FAST \{ flex:1 1 0; min-width:0; background:#2a2a2a; border-radius:4px; padding:0.2rem 0.5rem; font-size:0.82rem; text-align:center; \}
      .sidebar-item-btn_FAST \{ width:100%; border:none; border-radius:4px; padding:0.36rem 0.5rem; background:#2a2a2a; color:inherit; cursor:pointer; margin-bottom:0.45rem; \}
      .sidebar-divider_FAST \{ height:1px; background:#313131; margin:0.65rem 0; \}
      #settingsOverlay_FAST \{ position:fixed; inset:0; background:rgba(0,0,0,0.55); z-index:10002; display:none; align-items:center; justify-content:center; padding:1rem; box-sizing:border-box; \}
      #videoModePanel_FAST \{ display:none; margin:0.35rem auto 0.85rem; width:min(980px,100%); \}
      #videoModePanel_FAST gradio-app \{ display:block; width:100%; min-height:700px; margin-bottom:0.65rem; \}
      #videoModePanel_FAST iframe \{ width:100%; min-height:700px; border:0; border-radius:6px; background:#000; \}
      .video-flow-progress_FAST \{ width:min(360px,100%); height:6px; background:#2d2d2d; border-radius:999px; margin:0.25rem auto 0.5rem; overflow:hidden; \}
      .video-flow-progress_FAST > div \{ width:0%; height:100%; background:linear-gradient(90deg,#e08020,#f2b35b); transition:width 220ms ease; \}
      body[data-video-mode-fast="1"] #videoModePanel_FAST \{ display:block !important; \}
      body[data-video-mode-fast="1"] #imageScaleRow_FAST \{ display:none !important; \}
      .t2i-modal-image-to-prompt_FAST[data-maximized="1"] \{ width:min(96vw,1500px) !important; height:min(92vh,1100px) !important; \}
      @media (max-width: 980px) \{
        #userInputsCtn_FAST \{ padding:0.15rem; \}
        :root \{ --t2i-row-gap_FAST: 0.34rem; \}
      \}
      @media (min-width: 681px) and (max-width: 980px) \{
        .t2i-row[data-row-name="secondary"] \{ grid-template-columns:repeat(2,minmax(0,1fr)) !important; \}
        .t2i-row[data-row-name="controls"] \{ grid-template-columns:repeat(2,minmax(0,1fr)) !important; \}
        .t2i-row[data-row-name="assist_shared"] .t2i-col,
        .t2i-row[data-row-name^="assist_full_"] .t2i-col,
        .t2i-row[data-row-name="prompt"] .t2i-col \{ max-width:100% !important; \}
      \}
      @media (min-width: 481px) and (max-width: 680px) \{
        :root \{ --t2i-row-gap_FAST: 0.3rem; \}
        .t2i-row[data-row-name="secondary"],
        .t2i-row[data-row-name="prompt"],
        .t2i-row[data-row-name="assist_shared"],
        .t2i-row[data-row-name^="assist_full_"] \{ grid-template-columns:minmax(0,1fr) !important; \}
        .t2i-row[data-row-name="controls"] \{ grid-template-columns:repeat(2,minmax(0,1fr)) !important; \}
        .input-inner \{ margin:0.12rem; padding:0.22rem; \}
        .stepper-btn_FAST \{ width:1.64rem; height:1.62rem; padding:0; font-size:0.92rem; \}
        .stepper-value_FAST \{ height:1.62rem; margin:0 0.14rem; font-size:0.94rem; \}
        .input-toggle-button \{ min-width:2.75rem; height:1.5rem; font-size:0.76rem; \}
        .input-type-select select, .style-picker-btn \{ min-height:1.62rem; height:1.62rem; line-height:1.62rem; \}
      \}
      @media (max-width: 480px) \{
        :root \{ --t2i-row-gap_FAST: 0.26rem; \}
        .t2i-row[data-row-name="secondary"],
        .t2i-row[data-row-name="prompt"],
        .t2i-row[data-row-name="assist_shared"],
        .t2i-row[data-row-name^="assist_full_"] \{ grid-template-columns:minmax(0,1fr) !important; \}
        .t2i-row[data-row-name="controls"] \{ grid-template-columns:repeat(2,minmax(0,1fr)) !important; \}
        .input-inner \{ margin:0.1rem; padding:0.2rem; \}
        .input-label \{ font-size:77%; gap:0.24rem; \}
        .random-input-btn-ctn \{ margin-left:0.16rem; gap:0.12rem; \}
        .stepper_FAST \{ gap:0.1rem; \}
        .stepper-btn_FAST \{ width:1.48rem; height:1.52rem; padding:0; font-size:0.88rem; \}
        .stepper-value_FAST \{ height:1.52rem; margin:0 0.1rem; font-size:0.9rem; \}
        .input-toggle-button \{ min-width:2.55rem; height:1.44rem; font-size:0.72rem; padding:0 0.36rem; \}
        .input-type-select select, .style-picker-btn \{ min-height:1.52rem; height:1.52rem; line-height:1.52rem; \}
        .t2i-row[data-row-name="assist_compact"] .t2i-col-assist-compact_FAST \{ flex:1 1 100%; min-width:0; \}
      \}
      @media (max-width: 380px) \{
        .t2i-row[data-row-name="controls"] \{ grid-template-columns:minmax(0,1fr) !important; \}
      \}
    </style>
    <h1 id="pageTitleEl_FAST" style="font-size:1.2rem; margin-bottom:0.5rem;">
      ${settings.pageTitle || ""}
    </h1>
    <button id="hamburgerBtn_FAST" title="Menu" onclick="window.___toggleSidebar_FAST()">☰</button>
    <div id="leftSidebar_FAST" data-open="0">
      <div id="sidebarResizeHandle_FAST" class="sidebar-resize-handle_FAST" title="Drag to resize sidebar"></div>
      <button class="sidebar-item-btn_FAST" onclick="window.___toggleSidebar_FAST(); if(window.t2i_promptTemplate && window.t2i_promptTemplate.show){ window.t2i_promptTemplate.show(); }">📋 Templates</button>
      <button id="syncBtn_FAST" class="sidebar-item-btn_FAST" onclick="window.___syncOpenFromSidebar_FAST(this)">☁️ Cloud</button>
      <div class="sidebar-divider_FAST"></div>
      <button class="sidebar-item-btn_FAST" onclick="window.___openSettingsModal_FAST()">🛠️ Settings</button>
    </div>
    <div id="settingsOverlay_FAST" onclick="if(event.target===this) window.___closeSettingsPanel_FAST();"><div id="settingsPanel_FAST" style="width:min(520px,96vw);"></div></div>
    <div id="mainColumnEl_FAST" style="margin:0 auto; max-width:${___T2I_MAIN_MAX_WIDTH_FAST};">
      <div id="userInputsCtn_FAST" style="display:block; padding:0.25rem;">
        ${userInputsHtml}
      </div>
      ${dummyImageScriptTrigger}
      <div id="videoModePanel_FAST">
        <div id="videoUploadHint_FAST" style="display:none;margin-bottom:0.35rem;opacity:0.9;text-align:center;"></div>
        <div class="video-flow-progress_FAST"><div id="videoFlowBar_FAST"></div></div>
        <img id="videoUploadPreview_FAST" alt="Selected image for video mode" style="display:none;max-width:220px;margin:0 auto 0.55rem;border-radius:5px;">
        <div id="videoGeneratorEmbedHost_FAST" style="width:100%;min-height:700px;"></div>
      </div>
      <div style="margin:1rem 0 0;">
        <div style="display:flex;align-items:center;justify-content:center;">
          <span id="leftClickHelperEl_FAST" style="display:none;">click ➡&nbsp;</span>
          <button id="generateButtonEl_FAST" style="font-size:1.5rem;" onclick="window.___generateButtonClickEvent_FAST(event);">✨ generate</button>
          <span id="rightClickHelperEl_FAST" style="display:none;">&nbsp;⬅ click</span>
        </div>
        <div id="bottomClickHelperEl_FAST" style="display:none;"><div>⬆</div><div>click</div></div>
      </div>
      <div id="imageScaleRow_FAST" class="image-scale-row" style="margin-top:1rem;">
        <button onclick="window.___imageScaleStep_FAST(-10)">➖</button>
        <input id="imageScaleInput_FAST" type="text" value="100" onkeydown="window.___imageScaleInputKey_FAST(this,event)" onblur="window.___imageScaleBlur_FAST(this)" size="4">
        <button onclick="window.___imageScaleStep_FAST(10)">➕</button>
      </div>
      <div id="outputAreaEl_FAST">
        <span>${settings.introMessage || ""}</span>
      </div>
    </div>
    <div id="privateGalleryCtn_FAST"
      style="pointer-events:none;bottom:0.5rem;left:0;right:0;width:100%;text-align:center;position:fixed;z-index:100;font-size:0.85rem;display:flex;justify-content:center;gap:0.5rem;">
      <button class="floating-bottom-btn_FAST" ${settings.imageButtons?.privateSave ? "" : "hidden"} onclick="window.t2i_privateGallery.show()" title="Ctrl+Shift+G">
        🛡️ ${window.innerWidth > 600 ? "show " : ""}private gallery
      </button>
    </div>
    <div style="pointer-events:none;position:fixed;right:0.5rem;bottom:0.5rem;z-index:100;">
      <button id="guideBtn_FAST" class="floating-bottom-btn_FAST" onclick="window.open('https://perchance.org/generator-guide-vulkcat#edit','_blank')">Guide 📚</button>
    </div>
    <div style="pointer-events:none;position:fixed;left:0.5rem;bottom:0.5rem;z-index:100;">
      <button id="videoModeToggleBtn_FAST" class="floating-bottom-btn_FAST" onclick="window.___setVideoMode_FAST(!window.___isVideoMode_FAST)">🎬 Video Mode</button>
    </div>
    <br><br><br><br>
    `)
      .replaceAll("{","\\{").replaceAll("}","\\}")
      .replaceAll("[","\\[").replaceAll("]","\\]")
