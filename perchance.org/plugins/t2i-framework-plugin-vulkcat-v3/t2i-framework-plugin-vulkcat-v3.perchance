    const hint = document.getElementById("videoUploadHint_FAST");
    if(hint) { hint.style.display = src ? "" : "none"; hint.textContent = src ? "Preparando flujo de video..." : ""; }
    const prev = document.getElementById("videoUploadPreview_FAST");
    if(prev) {
      prev.style.display = src ? "" : "none";
      prev.src = src;
    }
  };
  window.___makeVideoFromImage_FAST = async function(btn) {
    const ctn = btn && btn.closest ? btn.closest(".t2i-image-ctn") : null;
    const src = window.___resolveGeneratedImageSrcFromCtn_FAST(ctn);
    if(!src || !ctn) return;
    const flow = window.___videoFlow_FAST;
    flow.token += 1;
    const token = flow.token;
    window.___cleanupVideoFlow_FAST();
    flow.retries = 0;
    window.___setVideoMode_FAST(true);
    window.___syncVideoPreviewFromImageSrc_FAST(src);
    window.___setVideoFlowState_FAST("preparing", "Preparando panel de video embebido...", 10);
    await window.___ensureVideoGeneratorEmbed_FAST();
    if(flow.token !== token) return;
    window.___setVideoFlowState_FAST("uploading", "Intentando enviar imagen al generador de video...", 30);
    await window.___attemptVideoAutoUpload_FAST(src);
    if(flow.token !== token) return;
    window.___setVideoFlowState_FAST("waiting_input_ack", "Esperando detección de imagen en el iframe...", 45);
    const onMessage = function(ev) {
      const data = ev && ev.data;
      if(!data || typeof data !== "object" || flow.token !== token) return;
      if(data.type === "T2I_FAST_VIDEO_INPUT_ACK") window.___setVideoFlowState_FAST("generating", "Imagen detectada, esperando video...", 65);
      if(data.type === "T2I_FAST_VIDEO_READY" && data.videoUrl) {
        window.___overlayVideoOnCard_FAST(ctn, data.videoUrl);
        window.___setVideoFlowState_FAST("ready", "Video listo y aplicado sobre la imagen.", 100);
        window.___cleanupVideoFlow_FAST(token);
