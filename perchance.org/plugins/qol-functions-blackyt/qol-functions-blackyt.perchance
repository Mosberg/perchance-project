// Display dialogs
showDialogModal(dialogID) =>
  let diag = document.getElementById(dialogID);
  diag.style.borderRadius = "5px";
  diag.showModal();
  return "";

//
closeDialogModal(dialogID) =>
  let diag = document.getElementById(dialogID);
  diag.close();
  return "";

// simple save
setLocalStorageItems(ItemName, ItemValue) =>
  const storedItem = localStorage.getItem(ItemName) || null;
  if (storedItem === ItemValue) {
    localStorage.removeItem(ItemName);
  } else {
    localStorage.setItem(ItemName, ItemValue);
  }

resetSomeOptions(Index, ctnID, ...selectors) =>
  const rstContainer = document.getElementById(ctnID);
  const selectOptions = rstContainer.querySelectorAll(selectors);

  if (Index === "random") {
    // get option count from first select
    const exclude = 1; // EXCLUDE index 1

    selectOptions.forEach(select => {
      let r;

      do {
        r = Math.floor(Math.random() * select.options.length);
      } while (r === exclude); // || r === exclude2);

      select.selectedIndex = r;
      select.dispatchEvent(new Event("change"));
    });

  } else {
    selectOptions.forEach(select => {
      select.selectedIndex = Index;
      select.dispatchEvent(new Event("change"));
    });
  }


insertTextPlus(targetEl, separator, text) =>
  // updated 01/12/25 mm/dd/yy
  let inputArea = document.querySelector(targetEl);
    if (!inputArea) {
      inputArea = document.querySelector(`[data-name="${targetEl}"]`);
    }

  if (inputArea) {
    const whitespace = separator || ", ";
    const textToInsert = whitespace + String(text);
    const start = inputArea.selectionStart;
    const end = inputArea.selectionEnd;
    const originalText = inputArea.value;

    inputArea.value = originalText.substring(0, start) + textToInsert + originalText.substring(end);

    const newCursor = start + textToInsert.length;
    inputArea.selectionStart = inputArea.selectionEnd = newCursor;

    inputArea.focus();
    // inputArea.blur();
    inputArea.dispatchEvent(new Event('input', { bubbles: true }));
  }
// ΏθΦ╜ Clear text // // // //
clearPrompt(element) =>
  let targetEl = document.querySelector(element);
  if (!targetEl) {
    targetEl = document.querySelector(`[data-name="${element}"]`);
  }

  if (targetEl) {
    targetEl.value = '';
    targetEl.focus(); // Focus on the target targetEl
    targetEl.blur(); // Immediately remove focus
    targetEl.dispatchEvent(new Event('input', { bubbles: true })); // Manually dispatch an input event to trigger an update
  }

  // ΏθΦ╜ Safe button/function to clear text without the risk of miss-click
toggleClear(btnID, element, label1, label2) =>
  if (window['await' + btnID]) {
    let targetEl = document.querySelector(element);
    if (!targetEl) {
      targetEl = document.querySelector(`[data-name="${element}"]`);
    }
    console.log(`ΏθΩΣΎ╕Π ${dateNow()} DELETED: ${targetEl.value}`);
  };

  let button = document.getElementById(btnID);
  if (!button) button = btnID;
  if (!window['await' + btnID]) {

    // First click - Was it itentional?
    button.classList.add('clearBtn');
    button.textContent = "έΝδ";
    showBalloonMessage(button, 'Click again to clear');
    window['await' + btnID] = true;

    // Yes it was, going back to sleep
    window['clearTimeout' + btnID] =
      setTimeout(() => {
        button.classList.remove('clearBtn');
        button.textContent = label1;
      window['await' + btnID] = false;
      }, 5000);
  } else {

    // Second click - Ok
    clearTimeout(window['clearTimeout' + btnID]); // Stop the reset timer
    button.classList.remove('clearBtn');
    button.textContent = label2;
    window['await' + btnID] = false;
    clearPrompt(element); // Finally the textbox can be clean!
  }
showBalloonMessage(button, message) =>
  // Create the balloon element
  const balloon = document.createElement('div');
  balloon.textContent = message;
  balloon.className = 'balloon-message';
  balloon.style = 'background:rgba(0, 0, 0, 0.4); border-radius:5px; padding:5px; color:red; text-shadow:1px -1px 1px #000000; pointer-events:none; user-select:none;'

  // Position above the button
  const rect = button.getBoundingClientRect();
  balloon.style.position = 'absolute';
  balloon.style.left = `${rect.left + window.scrollX - 100}px`;
  balloon.style.top = `${rect.top + window.scrollY - 30}px`; // 30px above

  // Add to the body
  document.body.appendChild(balloon);

  // Remove after 2 seconds
  setTimeout(() => {
    balloon.remove();
  }, 2000);
