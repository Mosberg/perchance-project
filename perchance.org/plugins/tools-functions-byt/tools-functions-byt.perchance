// user custom styles
getCustomStylesValue()=>
  for (let i = 1; i <= 21; i++) {
  const inputValue = document.getElementById(`CustomUserStyle${i}`).value;
  CLDATA[`CUData${i}`] = UrlToNameConverter(inputValue);
  // Repetitive logic explained 🔻
  // CLDATA.CUData1 = document.getElementById("CustomUserStyle1").value;
  // CLDATA.CUData1 = UrlToNameConverter(CLDATA.CUData1);
  localStorage.setItem(`CUData${i}`, CLDATA[`CUData${i}`]);
  localStorage.setItem(`inputCustomUserStyle${i}`, inputValue);
  }
loadInputCustomStyles()=>
  for (let i = 1; i <= 21; i++) {
    const input = document.getElementById(`CustomUserStyle${i}`);
    if (input) {
      input.value = localStorage.getItem(`inputCustomUserStyle${i}`) || "";
    }
  }
UrlToNameConverter(url)=>
  url = url.replace(/\/$/, "");
  const match = url.match(/\/([^\/#?]+)(?:[#?].*)?$/);
  return match ? match[1] : url || "nonelist";

RemoveCustomStyles()=>
  for (let i = 1; i <= 21; i++) {
  localStorage.removeItem(`CUData${i}`);
  localStorage.removeItem(`inputCustomUserStyle${i}`);
  }
