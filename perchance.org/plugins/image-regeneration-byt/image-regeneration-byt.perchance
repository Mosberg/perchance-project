// :: :: //
copyData(descriptionInput, negativeInput, seed, cfgInput, title, subtitle) =>
  let dataPrompt;
  let prompt = descriptionInput.value || "";
  let nP = ""; //negativeInput.value ? ` (negativePrompt:::${negativeInput.value})` : "";
  let s = seed.value || "-1";
  let gS = cfgInput.value || "7";
  let t = title.value || "";
  let st = subtitle.value || "";

  dataPrompt = `${prompt}${nP} (guidanceScale:::${gS}) (seed:::${s})`;
  if (window.copyrightTitle) dataPrompt = dataPrompt + ` (saveTitle:::${t}) (saveDescription:::${st})`
  copyText(dataPrompt.replace(/[\[]/g, "\\[").replace(/[\]]/g, "\\]").replace("(saveTitle:::)", "(saveTitle::: )").replace("(saveDescription:::)", "(saveDescription::: )"));
randomColor() =>
  return '#' + Math.floor(Math.random() * 16777215).toString(16).padStart(6, '0');
getAspect(url) =>
  return new Promise((resolve) => {
    const img = new Image();

    img.onload = () => {
      const { width, height } = img;
      if (width > height) resolve("768x512");
      else if (height > width) resolve("512x768");
      else resolve("768x768");
    };

    img.onerror = () => resolve("512x512");
    img.src = url;
  });

