SceneNgtv(...neg)=>
  let LocalNgtv = neg.join(", ");
  SceneNegative += ", " + LocalNgtv;
  return "";
SceneNegative = [""]
RNG = {import:simple-randomizer}
SNG = {import:simple-sequencer}
RandomSceneryOptions(itemList, itemFullList, sceneryArray, sceneryVar)=>
  if (typeof window[sceneryArray] === "undefined") {
    window[sceneryArray] = [];
  }

  if (typeof window[itemFullList] === "undefined") {

    let AllItems = itemList.selectAll.join("|").split("|").map(w => w);
    window[itemFullList] = AllItems.filter(fn => fn !== "random");

  };

  if (window[sceneryArray].length >= window[itemFullList].length) {
    window[sceneryArray] = [];
  };

  window[sceneryVar] = itemList.selectOne;

  if (window[sceneryArray].includes(window[sceneryVar])) {
    RandomSceneryOptions(itemList, itemFullList, sceneryArray, sceneryVar);
  } else {
    window[sceneryArray].push(window[sceneryVar]);
  };

  return "";





