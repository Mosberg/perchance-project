defineUG() =>
  if (window.upperGarment) return;
  if (!window.input) window.input = {outfitTorso: "outfit"};
  window.upperGarment = window.input.outfitTorso;
  return ""

//
defineInputColor() =>
  if (!window.initializeColor) {
    if (!window.input) {window.input = {};}
    if (!input.outfitColor01) {input.outfitColor01 = "";}
    if (!input.outfitColor02) {input.outfitColor02 = "";}
    if (!input.outfitColor03) {input.outfitColor03 = "";}
    if (!input.outfitColor04) {input.outfitColor04 = "";}
    if (!input.outfitColor05) {input.outfitColor05 = "";}
    if (!input.outfitColor06) {input.outfitColor06 = "";}
    window.initializeColor = "colors defined";
  }
  return "";

