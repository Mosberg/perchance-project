saveUserPrompt() =>
  const uPrompt = {
    prompt: window.promptInputEl.value,
    negativePrompt: "" //window.negativePromptInputEl.value
    //start: window.description0El.value,
    //main: window.descriptionEl.value,
    //end: window.description2El.value,
    //negative: window.negativeEl.value
  };
  if (!uPrompt.prompt && !uPrompt.negativePrompt) {alert("There is no data to be saved."); return}
  let slot = 0;
  for (let i = 0; i < localStorage.length; i++) {
    const savedSlot = localStorage.key(i);
    if (savedSlot.startsWith("savedUserPrompt")) {
      slot++;
    }
  }
  localStorage.setItem(`savedUserPrompt${slot}`, JSON.stringify(uPrompt));
  alert(`📖 Prompt saved in the slot ${slot}!`);
  //console.log(`User prompt saved in the slot ${slot} 📖`);
loadUserPrompt() =>
  const storage = {};

  // Collect only keys that start with "savedUserPrompt"
  for (let i = 0; i < localStorage.length; i++) {
    const key = localStorage.key(i);
    if (key.startsWith("savedUserPrompt")) {
      storage[key] = JSON.parse(localStorage.getItem(key));
    }
  }

  // Sort keys by the number at the end
  const sortedKeys = Object.keys(storage).sort((a, b) => {
    const numA = parseInt(a.replace("savedUserPrompt", ""), 10);
    const numB = parseInt(b.replace("savedUserPrompt", ""), 10);
    return numA - numB;
  });
  //console.log("Loaded:", storage, sortedKeys);
  return { storage, sortedKeys };
selectSlot() =>
  // I need to clear the error in the console when there is no saved prompt.
  const { storage, sortedKeys } = loadUserPrompt();
  const select = document.getElementById("selectSavedPrompt");
  select.innerHTML = ""; // clear

  sortedKeys.forEach(key => {
    const opt = document.createElement("option");
    const slotNumber = key.replace("savedUserPrompt", "");
    let data = storage[key];
    const preview = (
    //  storage[key]?.start ||
      storage[key]?.prompt ||
    //  storage[key]?.n ||
      storage[key]?.negativePrompt ||
      ""
    );
    let shortText = preview.slice(0, 64) + (preview.length > 64 ? "..." : "");

    opt.value = JSON.stringify(data);
    opt.textContent = `${slotNumber} - ${shortText}`; // the saved prompt
    opt.dataset.key = key;
    select.appendChild(opt);
  });
  window.savePromptSelectCreated = "Select created";
