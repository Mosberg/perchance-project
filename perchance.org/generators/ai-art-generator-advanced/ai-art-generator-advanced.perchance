deleteuserSavedPrompt() =>
  const select = document.getElementById("selectSavedPrompt");
  const selectedOption = select.options[select.selectedIndex];
  if (!selectedOption) {
    alert("No saved slot selected.");
    return;
  }

  const key = selectedOption.dataset.key;
  const keyName = key.replace("savedUserPrompt", "")


  if (!confirm(`Delete prompt saved in slot ${keyName}?`)) return;

  console.log("The item was removed:\n" + JSON.stringify(localStorage.getItem(`savedUserPrompt${keyName}`)));

  localStorage.removeItem(key);

  console.log("Status: " + localStorage.getItem(`savedUserPrompt${keyName}`))


  reindexSavedPrompts();
  selectSlot(); // refresh
  document.getElementById("previewSavedPrompt").value = "";
  document.getElementById("selectSavedPrompt").dispatchEvent(new Event('change', { bubbles: true }));
reindexSavedPrompts() =>
  const keys = [];

  // collect all keys in correct numeric order
  for (let i = 0; i < localStorage.length; i++) {
    const key = localStorage.key(i);
    if (key.startsWith("savedUserPrompt")) {
      keys.push(key);
    }
  }

  // sort them by numeric part
  keys.sort((a, b) => {
    return parseInt(a.replace("savedUserPrompt", "")) - parseInt(b.replace("savedUserPrompt", ""));
  });

  // rebuild them with new numbering
  keys.forEach((oldKey, index) => {
    const newKey = `savedUserPrompt${index}`;

    // get value from old key
    const value = localStorage.getItem(oldKey);

    // remove old and insert new
    localStorage.removeItem(oldKey);
    localStorage.setItem(newKey, value);
  });

