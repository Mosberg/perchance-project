 // This is already created at the window.onload but just in case...
getRawDescription() =>
  const descriptionValue = descriptionEl.value.replace(/[\[\]]/g, '');
  return descriptionValue.slice(0, 50) + "..."; // 45 the 'max' in mobile view

mainStyleChange(style) =>
  if (!window.activeMainStyle) {
    window.activeMainStyle = localStorage.getItem("activeMainStyleSave") || "anime";
  }
  window.activeMainStyle = style;
  localStorage.setItem("activeMainStyleSave", style);

mainStylesHandler() =>
  if (!window.styleCFG) window.styleCFG = "0";
  if (window.basicMode === "active") {
    return "";
  }
  if (input.artStyleOne.getName === "-" && input.artStyleTwo.getName === "-" && input.artStyleThree.getName === "-" && input.userCustomStyle.getName === "-") {
    return String(D1);
  }
  const style = window.activeMainStyle;
  if (style === "anime") {
    window.styleCFG = input.artStyleOne.CFG || "0";
    window.artStyleTitle = input.artStyleOne.getName;
    return String(input.artStyleOne.prompt);
  }
  if (style === "realistic") {
    window.styleCFG = input.artStyleTwo.CFG || "0";
    window.artStyleTitle = input.artStyleTwo.getName;
    return String(input.artStyleTwo.prompt);
  }
  if (style === "other") {
    window.styleCFG = input.artStyleThree.CFG || "0";
    window.artStyleTitle = input.artStyleThree.getName;
    return String(input.artStyleThree.prompt);
  }
  if (style === "custom") {
    window.styleCFG = "0";
    window.artStyleTitle = input.userCustomStyle.getName;
    let description = input.description ? `${whitespace}${input.description}` : "";
    let style = String(input.userCustomStyle.prompt || input.userCustomStyle)
    if (style) { return style + description; }
    else { return description.replace(whitespace, "")}
  }
  else { return ""; }
mainStylesNegativeHandler() =>
  if (window.basicMode === "active") {
    return "";
  }
  if (input.artStyleOne.getName === "-" && input.artStyleTwo.getName === "-" && input.artStyleThree.getName === "-" && input.userCustomStyle.getName === "-") {
    return String(NGOnly);
  }
  const style = window.activeMainStyle;
  if (style === "anime") {
    return String(input.artStyleOne.negative);
  }
  if (style === "realistic") {
    return String(input.artStyleTwo.negative);
  }
  if (style === "other") {
    return String(input.artStyleThree.negative);
  }
  if (style === "custom") {
    return input.negative || "" //String(input.userCustomStyle.negative);
  }
  else { return ""; }
/////////////////////////////
BACKUP(type, NewInput)=>
  // Copy created to evaluate the data from variables and functions that are not global, otherwise imported pages like in 'input.artStyleOne.prompt' will throws an error.
  // Necessary because this function exists only to "inject" changes into the description in input.description used by styles. Therefore, if there are no styles using it, nothing happens. 28/12/25 NEW: The way the generator works now, returning one style at time even if there are others options selected in the others styles, the condition below is almost useless.
  if (basicMode === "active" || input.artStyleOne.getName === "-" && input.artStyleTwo.getName === "-" && input.artStyleThree.getName === "-" && input.userCustomStyle.getName === "-") {
    return "";
  }

  if (type === "create") {
    input.description = String(NewInput);
    return "";
  }

  if (type === "restore") {
    input.description = settings.userInputs.description.value;
    return "";

  } else {
    return "";
  }

NBACKUP(type, NewInput)=>
  if (input.artStyleOne.getName === "-" && input.artStyleTwo.getName === "-" && input.artStyleThree.getName === "-" && input.userCustomStyle.getName === "-") {
    return "";
  }
  if (type === "create") {
    input.negative = String(NewInput);
    return "";
  }
  if (type === "restore") {
    input.negative = settings.userInputs.negative.value;
    return "";
  }
  else {
    return "";
  }

promptSwift()=>
  let promptResult;
  if (fullPromptLiveInput === "active") { // Prevents errors when typing "["
    BACKUP("create", D1).replace("[", "\[").replace("]", "\]");
  } else {
    BACKUP("create", D1);
  }

  // ⇲ Even with styles and other select options enabled, only the M.Description, Description 2 and Negative will be used (work with Tools).
  if (basicMode === "active") {
    promptResult = SIO.BASICprompt;
  }
  else {
    promptResult = (SIO.FULLprompt);
  }
  return promptResult;

negativeSwift()=>
  let promptResult;
  NBACKUP("create", NGOnly);

  if (basicMode === "active") {
    promptResult = SIO.BASICnegative;
  }
  else if (cleanPrompt.status === "active") {
    promptResult = SIO.BASICnegative;
  }
  else {
    promptResult = SIO.FULLnegative;
  }
  return promptResult;

// ❇️ Character, Outfit and Background Process //
character() =>
  let QUALY = "a beautiful character with balanced proportions and well-made; ";
  if (window.characterQualityPrompt === "inactive") { QUALY = "" }

  // ♦️ Characters template ♦️♦️
  const animeCharacter = input.animeCharacter.prompt || input.animeCharacter;
  const userCharacter = String(input.userCharacter);
  let Characters = [String(animeCharacter), userCharacter].filter(Boolean);
  let charactersResult;
  if (Characters.length > 1) { // If the user is selecting both options
    charactersResult = `two characters, the first is ${Characters[0]}.\n\nThe other character is ${Characters[1]}`;
  } else if (Characters.length) { charactersResult = Characters; }

  // Segs
  let XES = input.characterXES.getName !== "-" ? input.characterXES : {gender:"character", subject:"the character", possessive:"the"};
  const Camera = String(input.characterAngle);

  // ♦️ Appearance ♦️♦️
  const bodyType = String(input.characterBody);
  const chest = String(input.characterChest);
  const skinColor = String(input.characterSkinColor);
  let eyeColor = String(input.characterEyeColor);
  if (eyeColor) eyeColor = `${eyeColor} eyes`;
  const HairColor_Lenght = String(input.characterHairL); // Color assigned in the list.
  const hairType = String(input.characterHairT);
  const hairStyle = String(input.characterHairS);
  const bangs = String(input.characterHairB);
  const hairExtraFeatures = String(input.characterHairMisc);

  const appearance = [chest, skinColor, eyeColor, HairColor_Lenght, hairType, hairStyle, bangs, hairExtraFeatures].filter(Boolean);

  let Character_Camera = `the ${XES.gender}`; // Change the description with the angle and others characteristics inputs.
  if (Camera && appearance.length) {
    Character_Camera = `the image shows the ${XES.gender} ${Camera}, ${XES.subject}`;
  } else if (Camera) { Character_Camera = `the image shows the ${XES.gender} ${Camera}` };

  let appearanceResult;  // Shit to decide where to put 'has'
  if (bodyType && !bodyType.startsWith("has") && appearance.length) { // The character is slender, has red eyes...
    appearanceResult = `${Character_Camera} ${bodyType}, has ${appearance.join(", ")}`;
  } else if (bodyType && appearance.length) { // The character has a muscular body, red eyes...
    appearanceResult = `${Character_Camera} ${bodyType}, ${appearance.join(", ")}`;
  } else if (bodyType && !appearance.length) { // The character has small body
    appearanceResult = `${Character_Camera} ${bodyType}`;
  } else if (appearance.length) { // The character has red eyes...
    appearanceResult = `${Character_Camera} has ${appearance.join(", ")}`;
  } else if (Camera) { appearanceResult = `${Character_Camera}` }

  // 🚧 🚧 🚧
  if (appearanceResult) {
    appearanceResult = appearanceResult.toLowerCase() // Many fixes below
      .replace("heterochromia eyes", "eyes with heterochromia")
      .replace(/(has bald|bald)/i, "is bald")
      .replace(/(redhead hair)/i, "is bald")
      .replace(/(colors hair)/i, "colors")
      .replace(/(hair hair)/i, "hair")
      //.replace(/\s+/g, " ");
  }


  // ♦️ Emotions and actions ♦️♦️
  const Character_Appearance = (appearanceResult && appearance.length < 5) ? `${XES.subject} ` : `the ${XES.gender} `;
  const expression = String(input.characterEmo);
  const gaze = input.characterGaze.getName !== "-" ? "is " + String(input.characterGaze) : "";
  const action = input.characterAction.getName !== "-" ? "is " + String(input.characterAction) : "";
  const exp_act_array = [expression, gaze, action].filter(Boolean);
  let expressions_actions;
  if (exp_act_array.length) {
    expressions_actions = [ // 🚧 🚧 🚧 shit seems unnecessary now if I just put 'is'........ whatever
      exp_act_array[0] ? `${Character_Appearance} ${exp_act_array[0]}` : "",
      exp_act_array[1] ? `${XES.subject} ${exp_act_array[1]}` : "",
      exp_act_array[2] ? `while ${exp_act_array[2]}` : ""
    ].filter(Boolean).join(", ").toLowerCase().replace(", while", " while");
  }

  // ♦️ Outfit ♦️♦️
  const Character_Clothed = (appearanceResult || appearanceResult || expressions_actions) ? `${XES.subject} is wearing` : `the ${XES.gender} is wearing`; // In case only clothes options are being used.

  const clothes = [String(input.outfitSet), String(input.userOutfitSet), String(input.outfitCosplay.outfit), String(input.outfitOutwear), String(input.outfitSleeves), String(input.outfitWaist), String(input.outfitLegs), String(input.outfitFoot), String(input.outfitHands), String(input.outfitHead), String(input.outfitAccA), String(input.outfitAccB), String(input.outfitAccC), String(input.outfitColor), String(input.outfitFabric)];

  let [OutfitSet, UserOutfitSet, OutfitCosplay, outwear, torso, waist, legs, foot, hands, head, acc1, acc2, acc3, Color, Fabric] = clothes;
  outwear ? outwear = [String(input.outfitColor01), outwear].join(" ") : "";
  torso ? torso = torso : ""; //[String(input.outfitColor02), torso].join(" ") : ""; Assigned in the list
  waist ? waist = [String(input.outfitColor03), waist].join(" ") : "";
  legs? legs = [String(input.outfitColor04), legs].join(" ") : "";
  foot ? foot = [String(input.outfitColor05), `${foot} on the feet`].join(" ") : "";
  hands ? hands = [String(input.outfitColor06), hands].join(" ") : "";
  head ? head = [String(input.outfitColor07), head].join(" ") : "";
  acc1 ? acc1 = [String(input.outfitColor08), acc1].join(" ") : "";
  acc2 ? acc2 = [String(input.outfitColor09), acc2].join(" ") : "";
  acc3 ? acc3 = [String(input.outfitColor10), acc3].join(" ") : "";
  Color ? Color = "main color is " + Color : "";
  Fabric ? Fabric = "is " + Fabric : "";


  const basicLook = [OutfitSet, UserOutfitSet, OutfitCosplay, outwear, torso, waist, legs, foot, hands, head, acc1, acc2, acc3].filter(Boolean);
  const isWearingTemplateSet = (OutfitSet || UserOutfitSet || OutfitCosplay) ? "complemented with" : "paired with";
  let Complete_Outfit;
  if (basicLook.length) {
    Complete_Outfit = [
      `is wearing ${basicLook[0]}`,
      basicLook[1] ? `${isWearingTemplateSet} ${basicLook[1]}` : "", // 'Paired' is need (at least in early august version of perchance flux) to keep the two clothes 'together', otherwise, sometimes, the ai do not pay attention to the other. This also helps to create 'mix' of clothes like... long dress and skirt, making a unique dress mixed with the skirt characteristics.
      basicLook[2] ? `and ${basicLook[2]}` : "", // The flux version at the time I made it really works well with 'and, with', before that it was not really needed, and im no sure how it will be in the future.
      basicLook[3] ? `${basicLook[3]}` : "",
      basicLook[4] ? `${basicLook[4]}` : "",
      basicLook[5] ? `${basicLook[5]}` : "",
      basicLook[6] ? `and ${basicLook[6]}` : "",
      basicLook[7] ? `also ${basicLook[7]}` : "",
      basicLook[8] ? `${basicLook[8]}` : "",
      basicLook[9] ? `${basicLook[9]}` : "",
      basicLook[10] ? `${basicLook[10]}` : "",
      basicLook[11] ? `${basicLook[11]}` : "",
      basicLook[12] ? `completing the look with ${basicLook[12]}` : ""
    ].filter(Boolean).join(", ");
  };

  // Color and Fabric
  const colorFabricParts = [Color, Fabric].filter(Boolean);
  const Color_Fabric = [
    colorFabricParts[0] ? `${XES.possessive} outfit ${colorFabricParts[0]}` : "",
    colorFabricParts[1] ? `${colorFabricParts[1]}` : ""
  ].filter(Boolean).join(", ");

  // 🚧 🚧 🚧
  let finishedLook = [Complete_Outfit, Color_Fabric].filter(Boolean).join(", ").toLowerCase()
    .replace(/paired with no panties/i, 'and no panties')
    .replace(/; ([A-Z])/, (_, letter) => "; " + letter.toLowerCase()) // AI is crazy with unnecessary regex...
    .replace(/\b([avo])-/gi, (_, letter) => letter.toUpperCase() + "-"); // Fix a-line -> A-line, v-shape -> V-shape, etc.

  let result = [charactersResult, appearanceResult, expressions_actions, finishedLook].filter(Boolean).join("; ");
  if (result) {
    return QUALY + result;
  } else { return "" }

backgroundHandler(scheme, time, weather) =>
  const userBG = String(input.userBackground);
  let bgEx = String(input.bgExterior);
  let bgIn = String(input.bgInterior);

  //let backgrounds = [userBG, bgEx, bgIn].filter(Boolean).join(".\n");
  //if (backgrounds.length <= 0) { // shit 'hack' to remove ghost data
   // backgrounds = "";
  //}

  // If the user select the two backgrounds options, it changes in a way to describe the two as outside and inside view
  if (bgEx && bgIn) {
    bgIn = `Inside: ${bgIn.replace("background", "interior background").toLowerCase()}.`;
    bgEx = `The outside view: ${bgEx.replace("background", "exterior background").toLowerCase()}`;
  }
  const backgrounds = [userBG, bgIn, bgEx].filter(Boolean).join(".\n");

  const lastScene = [backgrounds, time, weather, scheme].filter(Boolean);
  return lastScene.join("; ")

bgScene(position) =>
  if (position === "start") {
    return String(input.bgAngle).toLowerCase();
  } else {
    return backgroundHandler(String(input.bgScheme), String(input.bgTime), String(input.bgWeather))
  }

// ❇️ User Options
// Assign the variables here using lists from LocalStorage
parseUserDefinitions(text)=>
  return text
    .split("\n")
    .map(l => l.trim())
    .filter(l => /^[A-Z0-9_]+\s*=\s*\S/.test(l))
    .map(l => {
      const [name, ...rest] = l.split("=");
      return {
        name: name.trim(),
        value: rest.join("=").trim()
      };
    });
buildPerchanceList(entries) =>
  let out = "";
  for (const { name, value } of entries) {
    out += `${name.replace(/_/g, " ").toLowerCase().replace(/\b\w/g, c => c.toUpperCase())}\n`;
    out += `\t${value}\n`;
  }
  return out;
createListFromTextarea(listName, textarea) => // use String(textarea)
  const entries = parseUserDefinitions(textarea);
  if (!entries.length) return null;
  const perchanceText = buildPerchanceList(entries);

  // The select will use the saved string because the function can not run in time to get the scratchpad items to create the list and be used in the select (maybe there is a way but i dont know how)
  localStorage.setItem(listName, perchanceText);
  // Create real Perchance tree
  //console.log("User Character list created!: " + perchanceText) //createPerchanceTree(String(perchanceText));

setNotepad() => // load at start
  // Set timeout here because there is some delay in the t2i-framework-plugin to get the scratchpad variables. Using the textarea.value would be more faster here tho, i think
  setTimeout(() => {
    createListFromTextarea('myStyles', input.scratchpadStyles);
    createListFromTextarea('myCharacters', input.scratchpadCharacters);
    createListFromTextarea('myOutfits', input.scratchpadOutfit);
    createListFromTextarea('myBg', input.scratchpadBackground);
    //console.log("Custom list created");
  }, 1500); //

aestheticTAG = [window.advAESTHETIC === "active" ? "aesthetic " : ""]
fullPrompt = ["inactive"]
