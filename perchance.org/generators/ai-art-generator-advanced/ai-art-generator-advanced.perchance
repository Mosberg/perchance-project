// ⋆ ⋆ ⋆ IMPORTS 🚚 ⋆ ⋆ ⋆
$preprocess = {import:kuronyx-magic}
dyn = {import:dynamic-import-plugin}
qolf = {import:qol-functions-blackyt} // 👄🍆
DBG = {import:dynamic-background-blackyt} // 👄🍆
date = {import:date-plugin}
generateHTML = {import:vanitas-vanitatum}
icon = {import:icon-plugin-v7-byt}
gns = {import:generator-stats-plugin}
AdvBox = {import:tools-functions-byt} // 👄🍆
TPROCESS = {import:t2i-f-process-blackyt} // 👄🍆
sSD = {import:smartseed} // 👄🍆
copyTxt = {import:copy-text-plugin}
Prison = {import:aaga-fbdn}
kuronyx = {import:kuronyx} // 👄🍆
aagaStyles = {import:aaga-styles-general} // ← Exclusive from AAGA (Ai Art Generator Advanced: https://perchance.org/ai-art-generator-advanced). // 👄🍆
aagaAnime = {import:aaga-styles-anime} // ← Exclusive from AAGA (https://perchance.org/ai-art-generator-advanced). // 👄🍆
aagaRealistic = {import:aaga-styles-realistic} // ← Exclusive from AAGA (https://perchance.org/ai-art-generator-advanced). // 👄🍆
perStyles = {import:perstyles-general} // ← styles edited from: t2i-styles, Vionet20, text2image-generator.
perAnime = {import:perstyles-anime} // ← styles edited from: t2i-styles, Vionet20, text2image-generator.
perRealistic = {import:perstyles-realistic} // ← styles edited from: t2i-styles, Vionet20, text2image-generator.
// From:
// 🔹 Original Vionet20 Styles: https://perchance.org/vionet20-t2i-styles-importable-v2
// 🔹 Original Text-2-Image Generator: https://perchance.org/text2image-generator
// 🔹 t2i-styles: https://perchance.org/t2i-styles
TgW = AAGA:-100 //[aagaStyles.TgWV] // tagWeights = [TgW]

Scene = {import:t2i-scenery} // 👄🍆
aagaCHAR = {import:everything-characters-flux} // ← AAGA exclusive, made by BlackYT based on research from Danbooru. // 👄🍆
aagaAW = {import:anime-waifu} // ← AAGA exclusive, made by BlackYT 👄🍆
Colors = {import:corlist} // ← AAGA exclusive, made by BlackYT, colors for anime.
Fashion = {import:female-outfit-list-flux} // ← AAGA exclusive, made by BlackYT, AI reserach, Danbooru copypast and research, actual testing. // 👄🍆

advRng = {import:item-randomizer-byt} // 👄🍆
betterSEQUENCE = {import:better-sequencer} // 👄🍆
textTools = {import:text-tools-blackyt} // 👄🍆
newImg = {import:image-regeneration-byt} // 👄🍆
imgMeta = {import:image-metadata-byt} // 👄🍆

userStylesList = [createPerchanceTree(localStorage.getItem("myStyles") || "-") || createPerchanceTree("-")]
userCharacterList = [createPerchanceTree(localStorage.getItem("myCharacters") || "-") || createPerchanceTree("-")]
userOutfitList = [createPerchanceTree(localStorage.getItem("myOutfits") || "-") || createPerchanceTree("-")]
userBgList = [createPerchanceTree(localStorage.getItem("myBg") || "-") || createPerchanceTree("-")]

LastVersion = 4.0.1

$meta
  title = AI Art Generator Advanced (Perchance) //AI Image Generator, AI Anime, Anime Waifu generator, Anime Ai Art, Create cute waifus or breathtaking landscapes with no cost, no registration, fast and free! High quality AI Image, customizable character, AI chat, create character backgrounds, dialogs and chat with them! Totally Free, Fast. Perchance advanced ai art generator, the one truly advanced!
  description = Random options, anime characters, auto gen, custom styles and characters, clothes, and others advanced options. //Someone just copied my description .-.: Generate anime images with random options, 150 styles, outfits, scenery, anime characters, advanced tools, simple, customizable, advanced.
  image = https://user.uploads.dev/file/eb44622446707d13c9daa1ed5487dee2.webp
  tags = ai art, t2i, anime, waifu, advRng, random options, art styles, gallery, customizable, character creation
  //header
    //mode = minimal

settings
  pageTitle = <span style="display:none"><a class="linkC" href="ai-art-generator-advanced">AI Art Generator Advanced</a></span>
  introMessage = <br><div class="bgText" style="margin: 1px 1px;">Select an option (Art, Anime or Photo), then click ✨<b>generate</b>. Click the "[icon("fa-solid fa-question")]" above for brief information about the options.</div>
  underImagesMessage = <button id="generateBtnTwo" class="ghost" style="font-size:1.5rem; margin:25px 0;" onclick="document.getElementById('generateButtonEl').click(); qolf.setDisableDelay('#generateBtnTwo', 3000); qolf.scrollToPage(generateButtonEl, 200)">&nbsp;generate ✨</button><br><div id="underImgCtn"></div>
  numImages = [Number(input.numImages)]
  socialFeatures = disabled

  imageButtons
    personality = true
    privateSave = true

  imageOptions
    //style = border-top:1px solid #0cccf7; border-right:1px solid #fa4dc3; border-bottom:1px solid #7933f2; border-left:1px solid #3350f2; border-radius:5px;
    saveTitle = [input.titleImage.slice(0, 150) || (basicMode === "active" || fullPrompt === "active" ? " " : "") || TPROCESS.TitleSeparatorFunction((window.S1TITLE || window.S2TITLE || window.S3TITLE || S4TITLE || artStyleTitle), (RSLMIX1 || String(input.artStyle4.getName)), (RSLMIX2 || String(input.artStyle5.getName)), (RSLMIX3 || String(input.artStyle6.getName))) || " "]
    saveDescription = [date().format("MMM Do, YYYY")] • [input.subtitleImage.slice(0, 150) || (fullPrompt === "active" ? " " : "") || getRawDescription() || ""]

    // ▼ ▼ ▼
    prompt = [sSD.smartSeedArray(skipNumber)][fullPrompt === "active" ? input.fullPrompt : promptSwift()][BACKUP("restore")]
    BASICprompt = [""][ToReset][mainStylesHandler()][TPROCESS.commaFunctionPlus(filter1, String(D0), String(D1), String(D2))]
    FULLprompt = [""][ToReset][TPROCESS.newLineBreakFunctionPlus(autoCorrect, whitespace, filter1, qBooster, String(D0), mainStylesHandler(), String(input.userArtStyleMix), String(input.artStyle4.prompt), String(input.artStyle5.prompt), String(input.artStyle6.prompt), TPROCESS.commaFunctionPlus(filter1, bgScene('start'), character()), bgScene('end'), String(D2))]

    // ▼ ▼ ▼ NEGATIVE PROMPT DISABLED!!!
    negativePrompt = [""] //[fullPrompt === "active" ? input.fullNegativePrompt : negativeSwift()][NBACKUP("restore")]
    FULLnegative = [""][TPROCESS.commaFunctionPlus(filter1, mainStylesNegativeHandler())]
    BASICnegative = [ToReset][TPROCESS.commaFunctionPlus(filter1, String(NGOnly))]

    // ▼ ▼ ▼
    resolution = [input.shape]
    seed = [""][sSD.inputSmartSeedV2(input.seed, randomSeed) || "-1"]
    guidanceScale = [input.gScale === "0" ? window.styleCFG : input.gScale]
    width = 1000
    hideGalleryButtons = [cnPst()]
    onFinish(data)=>
      if (!data?.iframe?.isConnected) return; localStorage.sfc_tEnable_cm_gl_pg++
      const iframe = data.iframe;
      let iframeCtn = iframe.closest('.t2i-image-ctn');
      let buttonSpace = iframeCtn.querySelector('.t2i-under-each-image-ctn div');
      buttonSpace.style.pointerEvents = "auto";
      buttonSpace.style.opacity = "1";
      imgMeta.downloadImgBtn(data, buttonSpace);
      const iI = () => newImg.imageInfo(data); // Prevents missclicks
      newImg.ghostFrames(data, iI);
      const seedInput = document.querySelector('[data-name=seed]');
      newImg.easyCopySeed(data, buttonSpace, seedInput);
      newImg.regenerateNewImg(data, buttonSpace);
      newImg.imgi(data, buttonSpace);
      let privateBtn = iframeCtn.querySelector('.private-save-button'); // Let the button activated
      privateBtn.classList.add('private-save-button-plus');
      privateBtn.classList.remove('active-btn-main');
      const click = privateBtn.onclick;
      privateBtn.onclick = function (e) {
        if (click) click.call(this, e);
        privateBtn.classList.add('active-btn-main');   //
      }
      const dwldBtn = iframeCtn.querySelector(".t2i-downloadBtn");
      autoSaving(iframeCtn, privateBtn, dwldBtn);
      window.removeBackground = "active";
      newImg.removeBtn(data, buttonSpace); // remove background

      if (localStorage.getItem('cfgInfo')) {
        const cfgInfo = document.createElement("button");
        const text = localStorage.getItem('cfgInfo') || "CFG: ";
        cfgInfo.textContent = `${text}${String(data.inputs.guidanceScale)}`;
        buttonSpace.appendChild(cfgInfo);
      }


  userInputs

    // #️⃣ html
    startAllInputs
      type = HTMLelement
      html = [mainOptionsHtmlRender(0)]

    // #️⃣ html / Buttons: 📚⭕📖
    startUserPromptArea
      type = HTMLelement
      html = [mainOptionsHtmlRender(1)]

    // #️⃣ html / Notepad Numeric Buttons
    Notepad1
      type = HTMLelement
      html = [notepadHtmlRender(1)]

    scratchpad
      label = [icon("fa-solid fa-book", "color:#00ffff")] <button style="margin: 1px 10px; font-weight:600;" onclick="userGiveName('note1SavedName', 'Notepad 1', this)"</button>[userGiveName('note1SavedName', 'Notepad 1')] <button onclick="downloadNotepad(input.scratchpad, userGiveName('note1SavedName', 'Notepad 1'))">⇩</button> //<button style="margin:1px 10px; font-weight:600;" onclick="setNotepad('character', input.scratchpad); alert('You need to refresh the page now and everytime you change something in this notepad.')">Use in "My Characters"</button>
