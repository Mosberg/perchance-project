getRandomItem(listName, key) => // Get random item from a list, dynamically
  if (!key) key = "";
  const listname = `${listName}${key}`
  if (!window[listname + "List"] && key) { // If the item has a sub item, like Item.subitem
    window[listname + "MainList"] = dyn(listName);
    window[listname + "List"] = window[listname + "MainList"][key];
  } else if (!window[listname + "List"]) { // Normal list
    window[listname + "List"] = dyn(listName);
  }
  const banList = ["$moduleSpace"]; // I still don't understand why some lists have it now...
  advRng(listname, banList, window[listname + "List"]);
  return window["random" + listname]

RANDOM(...tagsToRandomize) =>
  const userTagList = tagsToRandomize.map(String).join(",").split(/\s*,\s*/);
  advRng('UserRandomList1', userRandomBanList1 = [], userTagList);
  return randomUserRandomList1;
RANDOM2(...tagsToRandomize2)=> // Use in the input (descriptions or negatives).
  tagsToRandomize2 = tagsToRandomize2.map(String).join(",").split(/\s*,\s*/);
  if (typeof userTagList2 === "undefined") {
    userTagList2 = [...tagsToRandomize2];
  }
  if (String(userTagList2) !== String(tagsToRandomize2)) {
    userTagList2 = [...tagsToRandomize2];
    userRandomArray2 = [];
  }
  if (typeof userRandomArray2 === "undefined") {
    userRandomArray2 = []
  }
  if (userRandomArray2.length >= userTagList2.length) {
    userRandomArray2 = [];
  }
  userRandomTag2 = userTagList2.selectOne;
  if (userRandomArray2.includes(userRandomTag2)) {
    RANDOM2(...tagsToRandomize2);
  } else {
    userRandomArray2.push(userRandomTag2);
  }
  return userRandomTag2;
SEQUENCE(...tagsToSelect)=> // Use in the input (descriptions or negatives).
  tagsToSelect = tagsToSelect.map(String).join(",").split(/\s*,\s*/);
  if (typeof userSelectTagList === "undefined") {
    userSelectTagList = [...tagsToSelect];
  }
  if (String(userSelectTagList) !== String(tagsToSelect)) {
    userSelectTagList = [...tagsToSelect];
    userSelectionArray = [];
  }
  if (typeof userSelectionArray === "undefined") {
    userSelectionArray = []
  }
  if (userSelectionArray.length >= userSelectTagList.length) {
    userSelectionArray = [];
  }

  userSelectionTag = userSelectTagList[userSelectionArray.length];

  userSelectionArray.push(userSelectionTag);

  return userSelectionTag;
SEQUENCE2(...tagsToSelect2)=> // duplicate.
