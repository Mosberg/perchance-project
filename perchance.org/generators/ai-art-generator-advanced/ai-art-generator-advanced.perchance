//🔻Get data from all inputs to display in Full Prompt
editablePrompt() =>
  //if (fullPrompt === "active") return
  const selectedInputs = document.querySelectorAll("#allSelectOptions .input-inner");
  const buttons = document.querySelectorAll(".fp-event");
  // 🚩 Creating and removing seems unnecessary :thinking: I need to think about it later.
  if (fullPromptLiveInput === "active") {
    fullPrompt = "active"; // to use in settings.title
    BACKUP("create", D1); // Copy created to evaluate the data from variables and functions that are not global, otherwise imported pages like in 'input.artStyleOne.prompt' will throws an error.
    window.promptInputEl.value = promptSwift();
    input.fullPrompt = window.promptInputEl.value;
    window.descriptionEl.addEventListener('input', window.updateFinalPrompt);
    window.description0El.addEventListener('input', window.updateFinalPrompt);
    window.description2El.addEventListener('input', window.updateFinalPrompt);

    //NBACKUP("create", NGOnly);
    //window.negativePromptInputEl.value = negativeSwift();
    //input.fullNegativePrompt = window.negativePromptInputEl.value;
    //window.negativeEl.addEventListener('input', window.updateFinalPrompt);

    selectedInputs.forEach(input => {
      input.addEventListener('change', window.updateFinalPrompt);
    });

    buttons.forEach(btn => {
      btn.addEventListener('click', window.updateFinalPrompt);
    });
  }

  else if (fullPromptLiveInput === "inactive") {
    //fullPrompt = "inactive";
    window.descriptionEl.removeEventListener('input', window.updateFinalPrompt);
    window.description0El.removeEventListener('input', window.updateFinalPrompt);
    window.description2El.removeEventListener('input', window.updateFinalPrompt);
    //window.negativeEl.removeEventListener('input', window.updateFinalPrompt);
    selectedInputs.forEach(input => {
      input.removeEventListener('change', window.updateFinalPrompt);
    });
    buttons.forEach(btn => {
      btn.removeEventListener('click', window.updateFinalPrompt);
    });
    //window.promptInputEl.value = "";
    //input.fullPrompt = "";
    //window.negativePromptInputEl.value =
    //input.fullNegativePrompt = "";
  }

editablePromptBtn() =>
  const btn = document.getElementById("liveInputBtn");
  if (!window.fullPromptLiveInput) window.fullPromptLiveInput = "inactive";
  fullPromptLiveInput = fullPromptLiveInput === "active" ? "inactive" : "active";

  if (fullPromptLiveInput === "active") {
    btn.classList.add("active-btn-main");
    btn.textContent = "Live Input Active!";
    // Save the input before activation (Actually is better to not do it, because the purpose of Full Prompt is to edit the generator options, so activating Live Input to get the prompt, and deactivating it to edit (while being free to change to description and changing the options) is intended).
