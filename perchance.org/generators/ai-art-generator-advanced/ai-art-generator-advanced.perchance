    description
      label = <span style="font-weight:600; margin: 0 5px;">📒 Main Prompt</span> <button class="label-btn" style="width:30px; height:1.4rem; margin:0 5px;" onclick="copyText(descriptionEl.value); qolf.fastEffect(this, 300, 'rainbow-effect')">[icon('fa-solid fa-copy')]</button><button class="label-btn" style="width:30px; height:1.4rem; margin:0 5px;" onclick="document.querySelector('button.ai-suggest-btn').click()">🧠</button>
      tip = [t2i.defaultText.promptTip].\n\nNotice: If you forget to close brackets, the site will display an error message.
      type = paragraph
      remember = [SharedLinkVerif]
      width = min(750px, 100%)
      height = min(150px)
      takesUpFullRow = true
      foldToggleState = shown
      useVariables = true
      modifiers = [input.artStyleOne?.modifiers || input.artStyleTwo?.modifiers || input.artStyleThree?.modifiers || null]
