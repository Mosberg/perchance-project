    fullPrompt
      label = <span style="font-weight:600; margin: 0 5px;">📖 Full Prompt</span> <button id="liveInputBtn" class="deactivated-btn label-btn" style="height:1.4rem; width:150px; margin-left:10px; margin-right:5px; white-space:nowrap; overflow:hidden;" onclick="editablePromptBtn()">Live Input Deactivated</button> <button class="label-btn" style="width:30px; height:1.4rem; margin-left:5px;" onclick="copyText(promptInputEl.value); qolf.fastEffect(this, 300, 'rainbow-effect')">[icon('fa-solid fa-copy')]</button>
      //tip = You can edit the prompt. While this window is active, the generations will only use the prompt from here. It do not works well with Tools, and the Repeat function have no effect here. If you use square brackets, the description will dissapear until you close them.\n\nThe content here will be lost when closing this window, it do NOT remember your data.
      type = paragraph
      width = min(750px, 100%)
      height = min(250px)
      takesUpFullRow = true
      foldToggleState = shown
      remember = [SharedLinkVerif]
      excludeFromShareLink = true
