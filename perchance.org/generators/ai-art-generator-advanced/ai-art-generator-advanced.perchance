// ❇️ Auto Gen //
sleep(ms) =>
  return new Promise(resolve => setTimeout(resolve, ms));
async autoGenerate() =>
  console.log(`Auto Generate Started: ${qolf.dateNow()}`);
  const startTime = performance.now();
  const autoBtn = document.getElementById('autoGenBtn');
  let numberCounter = 0;

  while (window.autoGenerateStatus !== "stop") {
    // Wait until your counter reaches the limit
    if (window.imageCounter >= input.numImages) {
      numberCounter = numberCounter + window.imageCounter;
      window.imageCounter = 0;
      await sleep(1000); // small delay
      document.getElementById('generateButtonEl').click();
      const genBtn2 = document.getElementById("generateBtnTwo").parentElement;
      genBtn2.style.order = "9"; // Change the order so the button stays after the others dynamic elements.
      genBtn2.hidden = true;
    }
    // Prevent CPU 100% usage, allow other functions to run
    await sleep(3000);
  }

  const endTime = performance.now();
  const totalTime = qolf.peformanceReaderNow( endTime - startTime);

  numberCounter = numberCounter + window.imageCounter;
  alert(`Images generated: ${numberCounter}.\nAuto Generation was running for ${totalTime}.`)
  console.log(`Auto Generate Ended: ${qolf.dateNow()}`);
  window.imageCounter = 0;
autoSaving(el, btn1, btn2) =>
  if (window.autoGenerateStatus === "stop") return;
  if (window.autoGenerateGallerySave === "active") btn1.click();
  if (window.autoGenerateDownload === "active") btn2.click();
  window.imageCounter ++;
  el.querySelector("iframe").style.border = "3px solid #5af542";
  setTimeout(() => {
    el.style.order = 5;
  }, 1000);

