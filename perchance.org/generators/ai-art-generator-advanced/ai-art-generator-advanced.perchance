// ❇️ Tags Tools //
tagSeparatorChange() =>
  (!window.tagSeparator) ? window.tagSeparator = "," : "";
  const separator = [",", "\n", "/"];
  const currentSeparator = separator.indexOf(window.tagSeparator);
  return window.tagSeparator = separator[(currentSeparator + 1) % separator.length];
changeTagSeparator(btnID) =>
  const text = tagSeparatorChange();
  btnID.textContent = `tag separator: ${text}`;
  if (text === "\n") { btnID.textContent = "New line" };
  if (text === ",") { btnID.textContent = "Comma (, )" };
  if (text === "/") { btnID.textContent = "Slash (/)" };
  const ftCtn = document.getElementById('toolsTextareaCtn');
  const ctnTxtArea = ftCtn.querySelector('TEXTAREA');
  ctnTxtArea.value += '';
  ctnTxtArea.focus();
  ctnTxtArea.blur();
  ctnTxtArea.dispatchEvent(new Event('input', { bubbles: true }));
logShuffleTags()=> // function needed only to read the permutations.
  if (RNGKey.status === "active" && NRNGKey.status === "active") {
    return "The Shuffle #Words# and Shuffle #negative# are both active. Please activate only one to see the log."
  }
  if (RNGKey.status === "active") {
    AdvBox.maybeSimpleRandomizer(input.description);
  } else if (NRNGKey.status === "active") {
    AdvBox.maybeSimpleRandomizer(input.negative);
  } else {
    return "something is wrong, reload the page."
  }

  numberTags = totalPermutations;

  AdvBox.maybeSimpleRandomizer("ZcCcS-45rEsEt"); // Random and uncommon string to reset the function maybeSimpleRandomizer since it uses global var and the value is saved, the function auto-resets when the input changes. Otherwise, this 'read' will use (spend) one permutation every call.
  return numberTags;
numberTags = "?"
readImageNumber()=>
  let numberImages = document.querySelector('[data-name="numImages"]');
  let setNumberImages;
  let extraPic = 0; // Add or Remove Tag because they display the first generation without adding or removing anything.
  if (ADDTGKey.status === "active" || RMVTGKey.status === "active" || WALKey.status === "active") {extraPic = 1};

  let effectiveTags = numberTags + extraPic;

  if (effectiveTags === 0 || effectiveTags === "?") {
    setNumberImages = 1;
  } else if (effectiveTags <= 40) {
    setNumberImages = effectiveTags;
  } else if (effectiveTags <= 100) {
    setNumberImages = Math.ceil(effectiveTags / 5) * 5;
  } else if (effectiveTags < 200 && (RNGKey.status === "active" || NRNGKey.status === "active")) {
    setNumberImages = Math.ceil(effectiveTags / 2);
  } else {
    setNumberImages = 100;
  }
  return setNumberImages;
setImageNumber(value)=>
  const ni = numberTags; // Im not sure if i need to change the value of numberTags back to normal, so note to remember.
  if (!value === false) {
    numberTags = Number(value.trim().match(/\d+/)?.[0]); // ?.[0] -> to avoid errors.
  }
  let numberImages = document.querySelector('[data-name="numImages"]');
  if (numberTags === 0 || numberTags === "?") {
    numberImages.selectedIndex = 0;
  }
  if (numberTags > 0 && numberTags <= 40) {
    numberImages.selectedIndex = numberTags - 1;
  } else if (numberTags <= 100 && numberTags > 40) {
    numberImages.selectedIndex = Math.floor((numberTags - 40) / 5) + 39;
  } else if (numberTags > 100) {
    numberImages.selectedIndex = 51;
  }
  numberImages.dispatchEvent(new Event("change"));
logWalkTags()=>
  (!window.tagSeparator) ? window.tagSeparator = "," : "";
  let TempList = "";

  const allInputs = { description: input.description, description2: input.description2, negative: input.negative };
  const foundIn = Object.entries(allInputs)
    .filter(([key, value]) => /#tag#/i.test(value))
    .map(([key]) => key);

  if (foundIn.length >= 2) {
    numberTags = 0;
    return `<span style="color:red; background:black; border-radius:5px; padding:2px;">#tag#</span> found in: <span style="color:red; background:black; border-radius:5px; padding:2px;">${foundIn.join(', ')}</span>. Please use #tag# in only one input to see the log.`;
  }

  if (/#tag#/i.test(input.description)) {
    TempList = (input.description).replace(/#tag#/gi, "").split(window.tagSeparator).map(word => word.trim()).filter(word => word !== "");
  }
  if (/#tag#/i.test(input.description2)) {
    TempList = (input.description2).replace(/#tag#/gi, "").split(window.tagSeparator).map(word => word.trim()).filter(word => word !== "");
  }
  if (/#tag#/i.test(input.negative)) {
    TempList = (input.negative).replace(/#tag#/gi, "").split(window.tagSeparator).map(word => word.trim()).filter(word => word !== "");
  }
  if (TempList !== "") {
    numberTags = TempList.length;
    return numberTags;
  } else {
    numberTags = 0;
  }
logAddRemoveTags()=>
  (!window.tagSeparator) ? window.tagSeparator = "," : "";
  let TempList = (input.FilterText).split(window.tagSeparator).map(word => word.trim()).filter(word => word !== "");
  numberTags = TempList.length;
  return numberTags;
// 🔻 This need to be in the right panel [startToolsEventListen()] to start the events listeners.
startToolsEventListen()=>
  const filterTextEl = document.querySelector('[data-name="FilterText"]');
  const logBtn = document.getElementById('logTagBtn');
  const setBtn = document.getElementById('setLogTagBtn');
  const recommendBtn = document.getElementById('logRecommendsBtn');

  descriptionEl.addEventListener('input', () => {
    if (RNGKey.status === "active") {
      recommendBtn.hidden = true;
      logBtn.textContent = `Possible Variations: ${logShuffleTags()}`;
      setBtn.textContent = `Set number of images to ${readImageNumber()}`;
    };

    if (WALKey.status === "active") {
      logBtn.innerHTML = `Tags: ${logWalkTags()}`;
      recommendBtn.hidden = false;
      setBtn.textContent = `Set number of images to ${RE = readImageNumber()}`;
      recommendBtn.textContent = `Variations: ${RE}`;
    }
  });

  description2El.addEventListener('input', () => {
    if (WALKey2.status === "active") {
      logBtn.innerHTML = `Tags: ${logWalkTags()}`;
      recommendBtn.hidden = false;
      setBtn.textContent = `Set number of images to ${RE = readImageNumber()}`;
      recommendBtn.textContent = `Variations: ${RE}`;
    }
  });

  //negativeEl.addEventListener('input', () => {
    //if (NRNGKey.status === "active") {
      //recommendBtn.hidden = true;
      //logBtn.textContent = `Possible Variations: ${logShuffleTags()}`;
      //setBtn.textContent = `Set number of images to ${readImageNumber()}`;
    //};

    //if (NWALKey.status === "active") {
      //logBtn.innerHTML = `Tags: ${logWalkTags()}`;
      //recommendBtn.hidden = false;
      //setBtn.textContent = `Set number of images to ${RE = readImageNumber()}`;
      //recommendBtn.textContent = `Variations: ${RE}`;
    //}
  //});

  filterTextEl.addEventListener('input', () => {
    if (REPTGKey.status === "active" || ADDTGKey.status === "active" || RMVTGKey.status === "active") {
      logBtn.textContent = `Tags: ${logAddRemoveTags()}`;
      recommendBtn.hidden = false;
      //(REPTGKey.status === "inactive" || RNGKey.status === "active" || NRNGKey.status === "active") ? recommendBtn.hidden = false : recommendBtn.hidden = true;
      setBtn.textContent = `Set number of images to ${RE = readImageNumber()}`;
      recommendBtn.textContent = `Variations: ${RE}`;
    }
  });
  console.log("startToolsEventListen set");
  return "";
tagsBtnTriggerEvent() =>
  // This function is to trigger the Event Listeners from the functions in Tools when activating them, for example, to display the info about number of tags.
  const filterTextEl = document.querySelector('[data-name="FilterText"]');
  descriptionEl.dispatchEvent(new Event('input', { bubbles: true }));
  description2El.dispatchEvent(new Event('input', { bubbles: true }));
  //negativeEl.dispatchEvent(new Event('input', { bubbles: true }));
  filterTextEl.dispatchEvent(new Event('input', { bubbles: true }));
switchKey(btn, ...keys) =>
  // Activate/Deactivate the functions in tools

  const BtnID = document.getElementById(btn);

  keys.forEach(keyName => {
    window[keyName].status =
      window[keyName].status === "active" ? "inactive" : "active";
  });

  const anyActive = keys.some(keyName => window[keyName]?.status === "active");
  if (anyActive) {
    BtnID.classList.add("active-btn-main");
  }
  else {
    BtnID.classList.remove("active-btn-main");
  }
toolsObjectSwitch(...keyNames) =>
  // This function is to disable all objects from tools
  let objectsArray = ['RNGKey', 'NRNGKey', 'REPTGKey', 'D0REPTGKey', 'D2REPTGKey', 'NREPTGKey', 'ADDTGKey', 'D0ADDTGKey', 'D2ADDTGKey', 'NADDTGKey', 'RMVTGKey', 'D0RMVTGKey', 'D2RMVTGKey', 'NRMVTGKey', 'WALKey', 'WALKey0', 'WALKey2', 'NWALKey'];
  const activeObjects = new Set(keyNames);
  for (const name of objectsArray) {
    if (!activeObjects.has(name)) {
      window[name].status = "inactive";
      //console.log(`${name}: ${window[name].status}`);
    }
  }
toolsObjButtonSwitch(btn, ...keynames) =>
  // This one just to deactive the buttons from the functions on tools
  let buttonsArray = ['randomBtn', 'randomNegBtn', 'ReplaceTagPID', 'AddTagPID', 'RemoveTagPID', 'WalkingTagPID'];

  for (let btnID of buttonsArray) {
    const btnEl = document.getElementById(btnID);
    // if the btn name exists in the array above, it activate it (with switchKey()), and deactivate the others buttons names/ID from the array.
    if (btnID === btn) {
      switchKey(btn, ...keynames);
    } else {
      btnEl.classList.remove("active-btn-main");
    }
  }

// PProcess and NProcess to evaluate the #tags# in descriptions and negative.
PProcess(userPrompt, ...keys)=>
  // Not the best function; there are better ways to do it, but I didn't know how when I did it...
  // The (keys.input) is needed otherwise the end and start description will be caught in the first condition.
  if (userPrompt.length === 0) return "";
  let NewUserPrompt;

  // SHUFFLE Condition
  if (keys.some(key => key.type === "RNG" && key.status === "active")) {
    return AdvBox.maybeSimpleRandomizer(NewUserPrompt || userPrompt);
  }

  // REPLACE Conditions
  if (keys.some(key => key.type === "REPLACETAG" && key.input === "mainDescription" && key.status === "active")) { // Main Description
    NewUserPrompt = userPrompt.replace(/(#tag#|#add.?Tag#)/gi, AdvBox.ReplaceTag('DynamicTags', input.FilterText, input.numImages));
  }
  if (keys.some(key => key.type === "REPLACETAG" && key.input === "startDescription" && key.status === "active")) { // Start Description
    NewUserPrompt = userPrompt.replace(/(#tag#|#add.?Tag#)/gi, AdvBox.ReplaceTag('Dynamic0Tags', input.FilterText, input.numImages));
  }
  if (keys.some(key => key.type === "REPLACETAG" && key.input === "endDescription" && key.status === "active")) { // End Description
    NewUserPrompt = userPrompt.replace(/(#tag#|#add.?Tag#)/gi, AdvBox.ReplaceTag('Dynamic2Tags', input.FilterText, input.numImages));
  }

  // ADD Conditions
  if (keys.some(key => key.type === "ADDTAG" && key.input === "mainDescription" && key.status === "active")) { // Main Description
    NewUserPrompt = userPrompt.replace(/(#tag#|#add.?Tag#)/gi, AdvBox.AddTag('DynamicTags', input.FilterText, input.numImages));
  }
  if (keys.some(key => key.type === "ADDTAG" && key.input === "startDescription" && key.status === "active")) { // Start Description
    NewUserPrompt = userPrompt.replace(/(#tag#|#add.?Tag#)/gi, AdvBox.AddTag('Dynamic0Tags', input.FilterText, input.numImages));
  }
  if (keys.some(key => key.type === "ADDTAG" && key.input === "endDescription" && key.status === "active")) { // End Description
    NewUserPrompt = userPrompt.replace(/(#tag#|#add.?Tag#)/gi, AdvBox.AddTag('Dynamic2Tags', input.FilterText, input.numImages));
  }

  // REMOVE Conditions
  if (keys.some(key => key.type === "RMVTAG" && key.input === "mainDescription" && key.status === "active")) { // Main Description
    NewUserPrompt = userPrompt.replace(/(#tag#|#add.?Tag#)/gi, AdvBox.RmvTag('DynamicTags', input.FilterText, input.numImages));
  }
  if (keys.some(key => key.type === "RMVTAG" && key.input === "startDescription" && key.status === "active")) { // Start Description
    NewUserPrompt = userPrompt.replace(/(#tag#|#add.?Tag#)/gi, AdvBox.RmvTag('Dynamic0Tags', input.FilterText, input.numImages));
  }
  if (keys.some(key => key.type === "RMVTAG" && key.input === "endDescription" && key.status === "active")) { // End Description
    NewUserPrompt = userPrompt.replace(/(#tag#|#add.?Tag#)/gi, AdvBox.RmvTag('Dynamic2Tags', input.FilterText, input.numImages));
  }

  // WALK Conditions
  if (keys.some(key => key.type === "WALKER" && key.input === "mainDescription" && key.status === "active")) { // Main Description
    NewUserPrompt = AdvBox.TheWalkingTag(input.FilterText, userPrompt, 'MainD', input.numImages);
  }
  if (keys.some(key => key.type === "WALKER" && key.input === "startDescription" && key.status === "active")) { // Start Description
    NewUserPrompt = AdvBox.TheWalkingTag(input.FilterText, userPrompt, 'Desc0', input.numImages);
  }
  if (keys.some(key => key.type === "WALKER" && key.input === "endDescription" && key.status === "active")) { // End Description
    NewUserPrompt = AdvBox.TheWalkingTag(input.FilterText, userPrompt, 'Desc2', input.numImages);
  }

  // Result
  return (typeof NewUserPrompt === "undefined" || NewUserPrompt === "") ? userPrompt : NewUserPrompt;
NProcess(userPrompt, ...keys)=>
  if (userPrompt.length === 0) return "";
  let NewUserPrompt;

  // REPLACE Conditions
  if (keys.some(key => key.type === "REPLACETAG" && key.status === "active")) {
    NewUserPrompt = userPrompt.replace(/(#tag#|#add.?Tag#)/gi, AdvBox.ReplaceTag('DynamicNTags', input.FilterText, input.numImages));
  }

  // ADD Conditions
  if (keys.some(key => key.type === "ADDTAG" && key.status === "active")) {
    NewUserPrompt = userPrompt.replace(/(#tag#|#add.?Tag#)/gi, AdvBox.AddTag('DynamicNTags', input.FilterText, input.numImages));
  }

  // REMOVE Conditions
  if (keys.some(key => key.type === "RMVTAG" && key.status === "active")) {
    NewUserPrompt = userPrompt.replace(/(#tag#|#add.?Tag#)/gi, AdvBox.RmvTag('DynamicNTags', input.FilterText, input.numImages));
  }
  // WALK Conditions
  if (keys.some(key => key.type === "WALKER" && key.status === "active")) {
    NewUserPrompt = AdvBox.TheWalkingTag(input.FilterText, userPrompt, 'NEG', input.numImages);
  }

  // SHUFFLE Condition
  if (keys.some(key => key.type === "RNG" && key.status === "active")) {
  return AdvBox.maybeSimpleRandomizer(NewUserPrompt || userPrompt);
  }

  return (typeof NewUserPrompt === "undefined" || NewUserPrompt === "") ? userPrompt : NewUserPrompt;
