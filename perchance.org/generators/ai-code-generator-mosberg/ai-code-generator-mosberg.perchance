ai = {import:ai-text-plugin}
comments = {import:comments-plugin}
literal = {import:literal-plugin}

storagePrefix = ["acgMosberg."]

storageKey(name) =>
  return storagePrefix + name

storageGet(name, fallback) =>
  let key = storageKey(name)
  if(localStorage[key] !== undefined) return localStorage[key]
  return fallback

storageSet(name, value) =>
  localStorage[storageKey(name)] = value

currentMode = [storageGet("currentMode", "architect")]
activePendingObj = null

modes
  architect
    category = Core
    label = Architect
    description = System design, file plans, and implementation sequencing for complex builds.
    instructionPlaceholder = Describe the feature, product, or system you want to architect...
    fileExtension = md
    languageLabel = Markdown
    codeHints = md,markdown
    defaultFence = markdown
    previewType = markdown
    instruction
      You are a principal software architect.
      Design a complete implementation strategy for this request:
      <<<instruction>>>
      Additional context:
      <<<context>>>
      Produce:
      - architecture overview
      - component and data flow
      - file/folder structure
      - step-by-step execution plan
      - edge cases, risks, and validation checkpoints
      Keep recommendations practical and immediately actionable.
      $output = [this.joinItems("\n")]
