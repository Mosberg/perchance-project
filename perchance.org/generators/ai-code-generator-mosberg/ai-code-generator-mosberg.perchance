escapeHtml(text) =>
  return String(text || "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")

syncModeFromUi() =>
  if(window.currentModeEl && currentModeEl.value) {
    currentMode = currentModeEl.value
    storageSet("currentMode", currentMode)
    localStorage.currentMode = currentMode
  }
  if(!modes[currentMode]) currentMode = "general"

getCurrentMode() =>
  syncModeFromUi()
  return modes[currentMode] || modes.general

getModeEntries() =>
  return modes.selectAll
    .filter(m => m.label !== undefined)
    .map(m => {
      return {
        name: m.getName,
        label: String(m.label || m.getName),
        category: String(m.category || "Other"),
        description: String(m.description || ""),
        fileExtension: String(m.fileExtension || "txt")
      }
    })

uiValue(id, fallback) =>
  if(window[id] && window[id].value !== undefined) return window[id].value
  return fallback

uiChecked(id, fallback) =>
  if(window[id] && window[id].checked !== undefined) return !!window[id].checked
  return !!fallback

resolveModeStartWith(mode) =>
  let useFence = uiChecked("useFenceEl", true)
  if(useFence && mode.defaultFence) {
    let fenceName = String(mode.defaultFence || "").trim()
    if(fenceName) return "```" + fenceName + "\n"
  }
  if(mode.startWithText) return String(mode.startWithText)
  return ""

resolveModeHideStartWith(mode, startWithText) =>
  if(String(startWithText || "").startsWith("```")) return true
  return mode.hideStartWith === true

shouldStartFresh() =>
  return uiChecked("startFreshEl", false)

buildInstruction() =>
  syncModeFromUi()

  let mode = getCurrentMode()
  let userInstruction = (uiValue("instructionEl", "") || "").trim()
  let projectContext = (uiValue("contextEl", "") || "").trim()
  let extraRules = (uiValue("customInstructionEl", "") || "").trim()

  let responseDepth = uiValue("responseDepthEl", "balanced")
  let outputShape = uiValue("outputShapeEl", "single-file")
  let targetPlatform = uiValue("targetPlatformEl", "generic")
  let framework = uiValue("frameworkEl", "auto")

  let includeTests = uiChecked("includeTestsEl", false)
  let includeComments = uiChecked("includeCommentsEl", false)
  let includeExplanation = uiChecked("includeExplanationEl", true)
  let strictLint = uiChecked("strictLintEl", true)
  let includeChecklist = uiChecked("includeChecklistEl", true)
  let safeOutput = uiChecked("safeOutputEl", true)
  let useFence = uiChecked("useFenceEl", true)
  let deterministic = uiChecked("deterministicEl", false)

  if(!userInstruction) userInstruction = "Generate a useful starter implementation for the selected mode."
  if(!projectContext) projectContext = "No additional project context provided."

  let template = mode.instruction.toString()
  template = template.split("<<<instruction>>>").join(userInstruction)
  template = template.split("<<<context>>>").join(projectContext)

  let parts = [template, "", "Global generation configuration:"]

  let depthNote = "balanced detail"
  if(responseDepth === "concise") depthNote = "concise output with minimal extra prose"
  if(responseDepth === "deep") depthNote = "deep output with strong implementation detail"
  parts.push("- Response depth: " + depthNote + ".")

  parts.push("- Target platform/runtime: " + targetPlatform + ".")
  if(framework !== "auto") parts.push("- Preferred framework: " + framework + ".")

  if(outputShape === "single-file") {
    parts.push("- Output shape: single file unless multiple files are strictly needed.")
  } else if(outputShape === "multi-file") {
    if(useFence) {
      parts.push("- Output shape: multi-file. Use this exact file block format for each file:")
      parts.push("  ```file:path/to/file.ext")
      parts.push("  file content")
      parts.push("  ```")
    } else {
      parts.push("- Output shape: multi-file. Use this exact delimiter format for each file:")
      parts.push("  --- FILE: path/to/file.ext ---")
      parts.push("  file content")
    }
  } else if(outputShape === "patch") {
    parts.push("- Output shape: unified diff patch for changed files.")
    parts.push("- Include enough context in each hunk for safe application.")
  }

  if(useFence) {
    parts.push("- Wrap code in markdown fenced blocks.")
  } else {
    parts.push("- Do not use markdown fenced code blocks unless explicitly required.")
  }

  if(includeTests) {
    parts.push("- Include tests relevant to the produced code.")
  } else {
    parts.push("- Do not add tests unless the request explicitly asks for tests.")
  }

  if(includeComments) {
    parts.push("- Include concise comments for non-obvious logic.")
  } else {
    parts.push("- Keep comments minimal and only where strictly necessary.")
  }

  if(includeExplanation) {
    parts.push("- Add concise implementation notes after the code when helpful.")
  } else {
    parts.push("- Output code/artifacts only with no extra explanatory prose.")
  }

  if(strictLint) {
    parts.push("- Ensure syntax correctness and lint-friendly style.")
  }

  if(safeOutput) {
    parts.push("- Avoid destructive operations and unsafe commands unless explicitly requested.")
  }

  if(deterministic) {
    parts.push("- Favor deterministic naming, stable ordering, and predictable behavior.")
  }

  if(includeChecklist) {
    parts.push("- End with a short implementation checklist or validation checklist.")
  }

  if(extraRules) {
    parts.push("")
    parts.push("Additional rules:")
    parts.push(extraRules)
  }

  return parts.join("\n")

settings
  instruction() =>
    this.lastModeUsed = currentMode
    return buildInstruction()
  startWith() =>
    let mode = getCurrentMode()
    if(shouldStartFresh()) {
      let freshStart = resolveModeStartWith(mode)
      this.lastHideStartWith = resolveModeHideStartWith(mode, freshStart)
      return freshStart
    }
    if(responseEl.value.trim() === "") {
      let initialStart = resolveModeStartWith(mode)
      this.lastHideStartWith = resolveModeHideStartWith(mode, initialStart)
      return initialStart
    }
    this.lastHideStartWith = false
    return responseEl.value
  hideStartWith = [
    resolveModeHideStartWith(
      getCurrentMode(),
      (shouldStartFresh() || responseEl.value.trim() === "") ? resolveModeStartWith(getCurrentMode()) : ""
    )
  ]
  outputTo = [responseEl]
  onChunk(data) =>
    if(responseEl.scrollTop + responseEl.offsetHeight > responseEl.scrollHeight - 70) {
      responseEl.scrollTop = responseEl.scrollHeight
    }
    if(window.updateOutputStats) window.updateOutputStats()
    if(window.updatePreviewDiff) window.updatePreviewDiff()
    if(modes[this.lastModeUsed] && modes[this.lastModeUsed].onChunk) modes[this.lastModeUsed].onChunk(data)
  onStart(data) =>
    setGeneratingUi(true)
    if(modes[this.lastModeUsed] && modes[this.lastModeUsed].onStart) modes[this.lastModeUsed].onStart(data)
  onFinish(data) =>
    setGeneratingUi(false)
    storageSet("response", responseEl.value)
    localStorage.response = responseEl.value
    if(window.updateOutputStats) window.updateOutputStats()
    if(window.updatePreviewDiff) window.updatePreviewDiff()
    if(uiChecked("autoPreviewEl", true)) runPreviewForCurrentMode()
    if(uiChecked("autoCopyEl", false) && responseEl.value.trim()) {
      navigator.clipboard.writeText(responseEl.value).catch(e => console.error(e))
    }
    if(window.recordHistorySnapshot && uiChecked("autoHistoryEl", true)) {
      window.recordHistorySnapshot({auto:true, mode: currentMode})
    }
    if(modes[this.lastModeUsed] && modes[this.lastModeUsed].onFinish) modes[this.lastModeUsed].onFinish(data)
  render = [ getCurrentMode().render || null ]

setGeneratingUi(isGenerating) =>
  if(window.generateBtn) {
    generateBtn.disabled = isGenerating
    if(isGenerating) {
      generateBtn.textContent = "Generating..."
    } else {
      generateBtn.textContent = responseEl && responseEl.value.trim() ? "Regenerate" : "Generate"
    }
  }
  if(window.continueBtn) continueBtn.disabled = isGenerating || (responseEl && responseEl.value.trim() === "")
  if(window.bottomContinueBtn) bottomContinueBtn.disabled = isGenerating || (responseEl && responseEl.value.trim() === "")
  if(window.retryBtn) retryBtn.disabled = isGenerating
  if(window.responseCopyBtn && responseEl && responseEl.value.trim()) responseCopyBtn.style.display = ""

async generate() =>
  window.responseContentBeforeLastGenerate = responseEl.value

  let pendingObj = ai(settings)
  activePendingObj = pendingObj

  if(window.stopBtn) stopBtn.style.display = ""
  if(window.bottomStopBtn) bottomStopBtn.style.display = ""
  if(window.loaderEl) loaderEl.innerHTML = pendingObj.loadingIndicatorHtml || "Generating..."

  function stopClickHandler() {
    if(activePendingObj && activePendingObj.stop) activePendingObj.stop()
    if(window.stopBtn) stopBtn.style.display = "none"
    if(window.bottomStopBtn) bottomStopBtn.style.display = "none"
    if(window.loaderEl) loaderEl.innerHTML = "Stopped."
  }

  if(window.stopBtn) stopBtn.onclick = stopClickHandler
  if(window.bottomStopBtn) bottomStopBtn.onclick = stopClickHandler

  try {
    let data = await pendingObj.onFinishPromise
    return data
  } catch(e) {
    console.error(e)
    if(window.loaderEl) loaderEl.innerHTML = "Generation failed. Please retry."
    setGeneratingUi(false)
  } finally {
    activePendingObj = null
    if(window.stopBtn) stopBtn.style.display = "none"
    if(window.bottomStopBtn) bottomStopBtn.style.display = "none"
    if(window.loaderEl && loaderEl.innerHTML === "Stopped.") {
      // leave stopped text briefly
    } else if(window.loaderEl) {
      loaderEl.innerHTML = ""
    }
  }

extractCodeBlocks(text) =>
  let source = String(text || "")
  let blocks = []
  let regex = /```([a-zA-Z0-9_+-]*)\s*\n?([\s\S]*?)```/g
  let match
  while((match = regex.exec(source))) {
    blocks.push({
      lang: String(match[1] || "").toLowerCase(),
      code: String(match[2] || "").trim()
    })
  }
  return blocks

pickCodeBlockByHint(text, hintsCsv) =>
  let blocks = extractCodeBlocks(text)
  if(blocks.length === 0) return String(text || "").trim()

  let hints = String(hintsCsv || "")
    .split(",")
    .map(h => h.trim().toLowerCase())
    .filter(h => h)

  if(hints.length > 0) {
    for(let hint of hints) {
      let found = blocks.find(b => b.lang === hint || b.lang.includes(hint) || hint.includes(b.lang))
      if(found) return found.code
    }
  }

  return blocks[0].code

extractHtmlPage(text) =>
  let source = String(text || "")
  let blocks = extractCodeBlocks(source)
  let htmlBlock = blocks.find(b => b.lang === "html" || b.code.includes("<html") || b.code.includes("<body"))
  if(htmlBlock) return htmlBlock.code

  let docMatch = source.match(/<!DOCTYPE html>[\s\S]*<\/html>/i)
  if(docMatch) return docMatch[0]

  let bodyMatch = source.match(/<body[^>]*>[\s\S]*<\/body>/i)
  if(bodyMatch) return bodyMatch[0]

  return source

renderPreviewMessage(title, messageHtml) =>
  renderedOutputEl.innerHTML = `<div style="border:1px solid var(--mosberg-border,#d5dbe4); border-radius:10px; padding:10px; background:var(--mosberg-card,#ffffff);"><div style="font-weight:700; margin-bottom:8px;">${escapeHtml(title)}</div><div style="font-size:0.95rem; line-height:1.45;">${messageHtml}</div></div>`

renderCodePreview(codeText, title, languageLabel) =>
  let safeCode = escapeHtml(codeText || "")
  renderedOutputEl.innerHTML = `<div style="border:1px solid var(--mosberg-border,#d5dbe4); border-radius:10px; overflow:hidden; background:var(--mosberg-card,#ffffff);"><div style="padding:8px 10px; border-bottom:1px solid var(--mosberg-border,#d5dbe4); font-weight:700; display:flex; justify-content:space-between; gap:8px;"><span>${escapeHtml(title || "Code Preview")}</span><span style="opacity:0.7; font-weight:500;">${escapeHtml(languageLabel || "code")}</span></div><pre style="margin:0; padding:12px; max-height:70vh; overflow:auto; background:#11161e; color:#e6edf7; font-size:0.85rem;">${safeCode}</pre></div>`

renderHtmlPreview(text) =>
  let htmlPage = extractHtmlPage(text)
  renderedOutputEl.innerHTML = `<div style="font-weight:700; margin-bottom:8px;">Live HTML Preview</div><iframe srcdoc="" style="width:100%; height:760px; max-height:80vh; border:1px solid var(--mosberg-border,#d5dbe4); border-radius:10px; background:#fff;"></iframe>`
  renderedOutputEl.querySelector("iframe").srcdoc = htmlPage

renderJavaScriptPreview(text) =>
  let jsCode = pickCodeBlockByHint(text, "javascript,js,ts,typescript")
  if(!jsCode.trim()) {
    renderPreviewMessage("JavaScript Preview", "No JavaScript code was detected.")
    return
  }

  let payload = encodeURIComponent(JSON.stringify({code: jsCode}))
  let htmlPage = `
  <!DOCTYPE html>
  <html>
    <head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <style>
        body { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; margin: 0; padding: 10px; background: #0e1117; color: #d2deee; }
        #log { white-space: pre-wrap; line-height: 1.45; }
        .log { color: #d2deee; }
        .warn { color: #f5cc80; }
        .error { color: #ff8a8a; }
      </style>
    </head>
    <body>
      <div id="log">Running JavaScript...\n</div>
      <script id="payloadEl" type="application/json">${payload}</script>
      <script>
        const logEl = document.getElementById("log");
        const append = (cls, args) => {
          const line = document.createElement("div");
          line.className = cls;
          line.textContent = args.map(a => {
            if (typeof a === "object") {
              try { return JSON.stringify(a, null, 2); } catch (e) { return String(a); }
            }
            return String(a);
          }).join(" ");
          logEl.appendChild(line);
        };

        const origLog = console.log;
        const origWarn = console.warn;
        const origError = console.error;

        console.log = (...args) => { append("log", args); origLog.apply(console, args); };
        console.warn = (...args) => { append("warn", args); origWarn.apply(console, args); };
        console.error = (...args) => { append("error", args); origError.apply(console, args); };

        window.onerror = (msg, src, line, col) => {
          append("error", ["Error:", msg, "at", line + ":" + col]);
        };

        try {
          const data = JSON.parse(decodeURIComponent(document.getElementById("payloadEl").textContent));
          const runner = new Function(data.code);
          const result = runner();
          if (result && typeof result.then === "function") {
            result.then(v => console.log("Promise resolved:", v)).catch(e => console.error("Promise rejected:", e && e.message ? e.message : e));
          }
        } catch (e) {
          console.error("Runtime error:", e && e.message ? e.message : e);
        }
      </script>
    </body>
  </html>
  `

  renderedOutputEl.innerHTML = `<div style="font-weight:700; margin-bottom:8px;">JavaScript Sandbox Console</div><iframe srcdoc="" style="width:100%; height:520px; max-height:70vh; border:1px solid var(--mosberg-border,#d5dbe4); border-radius:10px; background:#fff;"></iframe>`
  renderedOutputEl.querySelector("iframe").srcdoc = htmlPage

renderPythonPreview(text) =>
  let pythonImports = [...String(text || "").matchAll(/pip install ([^\n`]+)/gs)]
    .map(m => m[1].split(" "))
    .flat()
    .map(p => p.trim())
    .filter(p => p)

  let pythonCodeBlocks = [...String(text || "").matchAll(/```(py|python)([\s\S]*?)```/gs)].map(m => m[2])

  if(pythonCodeBlocks.length === 0) {
    pythonCodeBlocks = [...String(text || "").matchAll(/```([\s\S]*?)```/gs)].map(m => m[1])
  }

  if(pythonCodeBlocks.length === 0 && /(^|\n)import\s+/.test(String(text || ""))) {
    pythonCodeBlocks = [String(text || "")]
  }

  if(pythonCodeBlocks.length === 0) {
    renderPreviewMessage("Python Preview", "No executable Python code was detected.")
    return
  }

  let oneOrMoreHasNoTopImports = false
  for(let block of pythonCodeBlocks) {
    if(!/(^|\n)import\s+/.test(block.split("\n").slice(0, 6).join("\n"))) {
      oneOrMoreHasNoTopImports = true
      break
    }
  }
  if(oneOrMoreHasNoTopImports) {
    pythonCodeBlocks = [pythonCodeBlocks.join("\n\n")]
  }

  let matplotlibImportCode = [
    "import matplotlib",
    "matplotlib.use(\"module://matplotlib_pyodide.html5_canvas_backend\")",
    "import matplotlib_pyodide.html5_canvas_backend",
    "matplotlib_pyodide.html5_canvas_backend._base_fonts_url=\"https://cdn.jsdelivr.net/pyodide/v0.25.1/full/fonts/\""
  ].join("\n")

  for(let i = 0; i < pythonCodeBlocks.length; i++) {
    if(pythonCodeBlocks[i].includes("import matplotlib.") && !pythonCodeBlocks[i].includes("import matplotlib\n")) {
      pythonImports.push("matplotlib")
      pythonCodeBlocks[i] = matplotlibImportCode + "\n" + pythonCodeBlocks[i]
    } else if(pythonCodeBlocks[i].includes("import matplotlib\n")) {
      pythonImports.push("matplotlib")
      pythonCodeBlocks[i] = pythonCodeBlocks[i].replace(/import matplotlib\n/g, matplotlibImportCode + "\n")
    }

    if(pythonCodeBlocks[i].includes("np.") && !pythonCodeBlocks[i].includes("import numpy as np")) {
      pythonImports.push("numpy")
      pythonCodeBlocks[i] = "import numpy as np\n" + pythonCodeBlocks[i]
    }
    if(pythonCodeBlocks[i].includes("pd.") && !pythonCodeBlocks[i].includes("import pandas as pd")) {
      pythonImports.push("pandas")
      pythonCodeBlocks[i] = "import pandas as pd\n" + pythonCodeBlocks[i]
    }
  }

  for(let i = 0; i < pythonCodeBlocks.length; i++) {
    let lines = pythonCodeBlocks[i].split("\n")
    lines = lines.filter(l => !l.startsWith("pip install ") && !l.startsWith("!pip install "))
    pythonCodeBlocks[i] = lines.join("\n")
  }

  pythonImports = [...new Set(pythonImports)]

  let payload = encodeURIComponent(JSON.stringify({pythonCodeBlocks, pythonImports}))
  let htmlPage = `
  <!DOCTYPE html>
  <html>
    <head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <script src="https://cdn.jsdelivr.net/pyodide/v0.25.1/full/pyodide.js"></script>
      <style>
        body { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; margin: 0; padding: 10px; background: #0f1218; color: #d8e2f0; }
        .stderr { color: #ff8b8b; white-space: pre-wrap; }
        .stdout { white-space: pre-wrap; }
      </style>
    </head>
    <body>
      <div id="outputEl">Loading Python runtime...</div>
      <script id="dataEl" type="application/json">${payload}</script>
      <script type="module">
        const outputEl = document.getElementById("outputEl");
        const data = JSON.parse(decodeURIComponent(document.getElementById("dataEl").textContent));
        let outputs = [];

        const append = (cls, text) => {
          outputs.push("<div class='" + cls + "'>" + String(text)
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;") + "</div>");
          outputEl.innerHTML = outputs.join("");
        };

        try {
          const pyodide = await loadPyodide({
            stdout: (line) => append("stdout", line),
            stderr: (line) => append("stderr", line)
          });

          if (data.pythonImports.length) {
            append("stdout", "Loading packages: " + data.pythonImports.join(", "));
            await pyodide.loadPackage(data.pythonImports).catch(e => append("stderr", e && e.message ? e.message : e));
          }

          for (const block of data.pythonCodeBlocks) {
            try {
              const result = await pyodide.runPythonAsync(block);
              if (result !== undefined && result !== null && String(result).length > 0) {
                append("stdout", String(result));
              }
            } catch (e) {
              append("stderr", e && e.message ? e.message : e);
            }
          }

          if (!outputs.length) {
            append("stdout", "Python execution finished with no textual output.");
          }
        } catch (e) {
          append("stderr", "Runtime setup failed: " + (e && e.message ? e.message : e));
        }
      </script>
    </body>
  </html>
  `

  renderedOutputEl.innerHTML = `<div style="font-weight:700; margin-bottom:8px;">Executed Python Output</div><iframe srcdoc="" style="width:100%; height:760px; max-height:82vh; border:1px solid var(--mosberg-border,#d5dbe4); border-radius:10px; background:#fff;"></iframe>`
  renderedOutputEl.querySelector("iframe").srcdoc = htmlPage

renderMarkdownPreview(text) =>
  let markdownText = pickCodeBlockByHint(text, "markdown,md")
  if(!markdownText.trim()) markdownText = String(text || "")

  let payload = encodeURIComponent(markdownText)
  let htmlPage = `
  <!DOCTYPE html>
  <html>
    <head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
      <style>
        body { font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; margin: 0; padding: 16px; line-height: 1.6; color: #172130; background: #ffffff; }
        pre { background: #0f1520; color: #e5ecf8; padding: 10px; border-radius: 8px; overflow: auto; }
        code { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; }
      </style>
    </head>
    <body>
      <div id="mdOut"></div>
      <script>
        const raw = decodeURIComponent("${payload}");
        document.getElementById("mdOut").innerHTML = marked.parse(raw);
      </script>
    </body>
  </html>
  `

  renderedOutputEl.innerHTML = `<div style="font-weight:700; margin-bottom:8px;">Markdown Preview</div><iframe srcdoc="" style="width:100%; height:680px; max-height:78vh; border:1px solid var(--mosberg-border,#d5dbe4); border-radius:10px; background:#fff;"></iframe>`
  renderedOutputEl.querySelector("iframe").srcdoc = htmlPage

renderJsonPreview(text) =>
  let raw = pickCodeBlockByHint(text, "json")
  if(!raw.trim()) raw = String(text || "")

  try {
    let parsed = JSON.parse(raw)
    renderCodePreview(JSON.stringify(parsed, null, 2), "JSON Validation", "JSON")
  } catch(e) {
    renderPreviewMessage("JSON Validation Error", `<div style="color:#b3261e; font-weight:700; margin-bottom:6px;">Invalid JSON</div><pre style="white-space:pre-wrap; background:#f8f9fb; padding:8px; border-radius:8px; border:1px solid #e4e8ef;">${escapeHtml(String(e && e.message ? e.message : e))}</pre>`)
  }

runPreviewForCurrentMode() =>
  let mode = getCurrentMode()
  let outputText = String(responseEl && responseEl.value ? responseEl.value : "")
  let previewType = String(mode.previewType || "text")

  if(!outputText.trim()) {
    renderPreviewMessage("Preview", "No generated output yet.")
    return
  }

  if(previewType === "html") {
    renderHtmlPreview(outputText)
    return
  }

  if(previewType === "python") {
    renderPythonPreview(outputText)
    return
  }

  if(previewType === "javascript") {
    if(uiChecked("runJsEl", false)) {
      renderJavaScriptPreview(outputText)
    } else {
      renderCodePreview(pickCodeBlockByHint(outputText, mode.codeHints), "Code Preview", mode.languageLabel || mode.label)
    }
    return
  }

  if(previewType === "markdown") {
    renderMarkdownPreview(outputText)
    return
  }

  if(previewType === "json") {
    renderJsonPreview(outputText)
    return
  }

  renderCodePreview(pickCodeBlockByHint(outputText, mode.codeHints), "Code Preview", mode.languageLabel || mode.label)

clearRenderedOutput() =>
  renderPreviewMessage("Preview", "Preview cleared.")

generateModesHtml() =>
  let selectedMode = storageGet("currentMode", currentMode || "architect")
  return getModeEntries()
    .map(entry => {
      let isSelected = entry.name === selectedMode ? "selected" : ""
      return `<option ${isSelected} value="${escapeHtml(entry.name)}" data-category="${escapeHtml(entry.category)}">${escapeHtml(entry.category + " | " + entry.label)}</option>`
    })
    .join("")

generateModeCategoryOptionsHtml() =>
  let categoryMap = {}
  for(let entry of getModeEntries()) {
    categoryMap[entry.category] = true
  }
  let categories = Object.keys(categoryMap).sort()
  let html = `<option value="all">All Categories</option>`
  for(let category of categories) {
    html += `<option value="${escapeHtml(category)}">${escapeHtml(category)}</option>`
  }
  return html

urlModeToActualMode
  html = html
  javascript = javascript
