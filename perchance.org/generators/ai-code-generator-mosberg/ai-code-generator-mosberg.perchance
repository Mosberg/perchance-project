$meta
  async dynamic(inputs) =>
    let baseTitle = "AI Code Generator Mosberg (free, no sign-up, advanced studio)"
    let baseDescription = "Advanced AI coding workspace with many language modes, architecture planning, refactor/review/test flows, output tools, profiles, history, and live previews for HTML/JS/Python/Markdown/JSON."

    let modeMap = {
      html: "HTML/CSS/JS",
      javascript: "JavaScript",
      js: "JavaScript",
      typescript: "TypeScript",
      ts: "TypeScript",
      react: "React",
      node: "Node.js",
      python: "Python",
      py: "Python",
      sql: "SQL",
      bash: "Bash",
      powershell: "PowerShell",
      java: "Java",
      csharp: "C#",
      cpp: "C++",
      go: "Go",
      rust: "Rust",
      json: "JSON",
      yaml: "YAML",
      regex: "Regex",
      docs: "Documentation",
      markdown: "Markdown",
      review: "Code Review",
      test: "Testing",
      debug: "Debugging",
      refactor: "Refactoring",
      perchance: "Perchance Lists",
      perchancehtml: "Perchance HTML"
    }

    let modeParam = inputs.urlParams && inputs.urlParams.mode ? String(inputs.urlParams.mode).toLowerCase() : ""
    if(modeParam && modeMap[modeParam]) {
      let modeLabel = modeMap[modeParam]
      return {
        title: "AI " + modeLabel + " Generator Mosberg (free, no sign-up)",
        description: "Generate and optimize " + modeLabel + " code with advanced controls, profiles, previews, and multi-mode coding workflows."
      }
    }

    return {
      title: baseTitle,
      description: baseDescription
    }
