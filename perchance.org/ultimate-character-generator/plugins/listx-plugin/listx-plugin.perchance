// Sexuality and Orientation
    sexuality
      heterosexual
        description = Primarily attracted to a different gender.
      homosexual
        description = Primarily attracted to the same gender.
      bisexual
        description = Attracted to more than one gender.
      pansexual
        description = Attraction not limited by gender; person-focused.
      asexual
        description = Experiences little or no sexual attraction.
      demisexual
        description = Sexual attraction develops only after strong emotional connection.
      graysexual
        description = Experiences sexual attraction infrequently or under specific conditions.
      queer
        description = Broad, fluid identity outside traditional labels.
      questioning
        description = Exploring or unsure about their sexual identity.
      custom
        description = A unique or personal identity not listed.

    orientation
      romantic
        description = Experiences romantic attraction toward others.
      aromantic
        description = Experiences little or no romantic attraction.
      biromantic
        description = Romantic attraction toward more than one gender.
      panromantic
        description = Romantic attraction not limited by gender.
      demiromantic
        description = Romantic attraction develops only after emotional closeness.
      custom
        description = A unique or personal romantic identity.

