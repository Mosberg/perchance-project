ai = {import:ai-text-plugin}
commentsPlugin = {import:comments-plugin}
tabbedCommentsPlugin = {import:tabbed-comments-plugin-v1}
fullscreenButton = {import:fullscreen-button-plugin}
literal = {import:literal-plugin} // <-- we use this to make it so curly brackets and square brackets in the story are interpreted as literal/plain brackets, and not Perchance special curly/square block characters
upload = {import:upload-plugin} // <-- for the share link feature
kv = {import:kv-plugin} // <-- for the share link feature
combineEmojis = {import:combine-emojis-plugin} // simple helper for layering multiple emojis on top of one another
prompt2 = {import:prompt2-plugin} // for "modal" popup, used for the shortcuts feature
bugReport = {import:bug-report-plugin} // for comments-plugin-based feedback button - it's a helper for getting browser debug info like browser version, localStorage size limits, etc. - stuff that's relevant to bug reports
createTextEditor = {import:text-editor-plugin-v1} // a higher-performance version of <textarea> that also supports text styling (e.g. text within asterisks can be italicized)
roll = {import:dice-plugin}

$meta // this is the stuff that appears in search engines, social media preview cards, browser tab title, etc.
  title = 🗡️ AI RPG - Custom Text Adventure
  description = Altered version of the original, allows for dynamic alteration of the pacing and genre of the story you tell.
  image = https://user-uploads.perchance.org/file/7779244672aaaf6c2c3c6b72d61c600a.jpeg

pageTitle = 🗺️ AI RPG Custom 🧙‍♂️

//loreBook = new Map()

searchLore() =>
	let results = [];
  t = storySoFarEl.value.slice(-1000);
  let searchResult = 0;
	for ( x of loreBook.keys()){
		if (t.includes(x))
			{
        y = loreBook.get(x);
        y= y.toString();
        y= y + x;
				results.push(y||'');
			}
	}
  t = currentTrackedInfoEl.value;
  for ( x of loreBook.keys()){
		if (t.includes(x))
			{
        y = loreBook.get(x);
        y= y.toString();
        y= y + x;
				results.push(y||'');
			}
	}
  t = storyOverviewEl.value;
  for ( x of loreBook.keys()){
		if (t.includes(x))
			{
        y = loreBook.get(x);
        y= y.toString();
        y= y + x;
				results.push(y||'');
			}
	}
  return results;

allMessage() =>
  let lines=[];
  lines.push(getVoice());
  lines.concat(searchLore());
  let result = lines.join(" ");
  return result;

fetchLore(key) =>
  x ='';
  if(loreBook.has(key)){
    x =(loreBook.get(key));
    return x;
  }
  return x;

addLore(key, lore)=>
  if(key != null){
	loreBook.set(key, lore);
  }
  loreBookToArray();
  updateLore()

removeLore(key)=>
	loreBook.delete(key);
  loreBookToArray();
  updateLore()

loreBookToArray()=>
  x = new Array;
  for(key of loreBook.keys()){
    lore = loreBook.get(key);
    x.push(key);
    x.push(lore);}
  localStorage.loreBook=JSON.stringify(x);

arrayToLorebook()=>
  if(localStorage.loreBook){
  x = JSON.parse(localStorage.loreBook);
  arraylength = x.length;
  i = 0;
  for(i; i < arraylength; i++){
    key = x[i];
    i++;
    lore = x[i];
    loreBook.set(key, lore);
  }
  }

destroyLorebook()=>
  let confirmed = confirm("This will remove ALL of the lore from your lorebook. Continue?");
  if(!confirmed) return;
  loreBook.clear();
  localStorage.loreBook=[];
  updateLore()

updateLore()=>
  x = "";
  for(key of loreBook.keys()){
    if(key){
      lore = loreBook.get(key);
      x = x + key + " : " + lore + "\n";
    }
  }
  loreDisplay.value=x;

// Note: see `responseStyleEl` in the HTML panel for the editor's notes / writing style
shortWritingInstruction = [responseStyleEl.value.replace("@@@custom", responseStyleCustomInputEl.value).trim()]
startWithPrefix = [`# Direct Consequences of NEXT_ACTION (${shortWritingInstruction || "1 paragraph"}):`]

// This is the task instruction that's appended to the story text when the player takes an action. You can edit it and then click the reload button to test your changes. And you can of course click save to create your own custom copy of this generator.
consequencesOfActionTaskInstruction
  [getExtraInstructionsForConsequencesOfAction()]
  [allMessage()]
  Above is the player's next action/speech/command in this story. You are the Game Master for this RPG, and your task is to write the direct consequences of that NEXT_ACTION (including NPC dialogue if relevant). You must refer to the player's character using 'you' and 'your'. Your response should follow this template:
  [""] // blank line
  [startWithPrefix]  // see the `startWithPrefix = ...` above line, which includes the 'writing style' input.
  (write consequences/results here)
  //# Player State/Feelings: // Note: we use "# Player" as a stop sequence, so the "# Player State:" line and the stuff below never gets written. This is a galaxy brain trick to prevent the AI from including anything other than consequences in the response. Otherwise it sometimes includes other stuff even in spite of instructions to the contrary.
  //(remind the player of things, like how they feel, what they're thinking)
  //# Commentary:
  //(reminders, suggest possible actions, symbolism of items/things, comment on the interesting aspects of the consequences, and get the player excited about potential actions they might want to do next)
  //# Ambient Outro (outside environment, distant sounds, scents, tangential callbacks, etc.): // Note: we use "# Ambient Outro" as a stop sequence, so this "# Ambient Outro" line and the stuff below never gets written. This is a galaxy brain trick to prevent the AI from including anything other than consequences in the response. Otherwise it sometimes includes other stuff even in spite of instructions to the contrary.
  //(a short ambient environmental/outside outro to round off the above paragraph)
  //# Ambient Characters (Character actions not directly related to the scene):
  //(a short description of nearby characters, their actions, etc to finalize the paragraph.)
  $output = [this.joinItems("\n").trim()]

// This is the task instruction that's appended to the story text when the player clicks continue without adding an action.
continueWithoutActionTaskInstruction // we tell it to write the next 4 paragraphs, but stop it at after 1 - to prevent any sort of undesirable "wrapping up" of the story, which the AI sometimes does in the final paragraph.
  [getExtraInstructionsForContinueWithoutTask()]
  Your task is to write the next 4 paragraphs in this story. Include character dialogue when relevant. Let the scene play out naturally over the next 4 paragraphs.
  $output = [this.joinItems("\n").trim()]

getPerspective()=>
  switch(perspectiveEl.value){
    case "first": return "Tell the story in the first person perspective, from the player's point of view.";
      break;
    case "third": return "Tell the story in the third person perspective.";
      break;
    default :return "Tell the story in the second person perspective.";}

getVoice()=>
  switch(StyleEl.value){
    case "brief": return "Be laconic.";
      break;
    case "verbose" : return "Be verbose";
      break;
    case "tolkein" : return "Write in the style of JRR Tolkein";
      break;
    case "sMeyer" : return "Write in the style of Stephanie Meyer.";
      break;
    case "rowling" : return "Write in the style of JK Rowling.";
      break;
    case "lovecraft" : return "Write in the style of HP Lovecraft";
      break;
    case "hemingway" : return "Write in the style of Ernest Hemingway.";
      break;
    case "dickens" : return "Write in the style of Charles Dickens.";
      break;
    case "doyle" : return "Write in the style of Arthur Conan Doyle.";
      break;
    case "twain" : return "Write in the style of Mark Twain.";
      break;
    case "shakespeare" : return "Write in the style of William Shakespeare.";
      break;
    case "austen" : return "Write in the style Jane Auten.";
      break;
    case "gMarten": return "Write in the style of George R R Martin."
      break;
    case "sKing": return "Write in the style of Stephen King.";
      break;
    case "dAdams": return "Write in the style of Douglas Adams.";
      break;
    case "tPratchett": return "Write in the style of Terry Pratchett.";
      break;
    case "nGaiman": return "Write in the style of Neil Gaiman.";
      break;
    case "mShelley": return "Write in the style of Mary Shelley.";
      break;
    case "hWells": return "Write in the style of H.G. Wells.";
      break;
    case "jVerne": return "Write in the style of Jules Verne.";
      break;
    case "koontz": return "Write in the style of Dean Koontz."
      break;
    case "ward": return "Write in the style of J.R. Ward."
  }
    return '';

diceRoll() =>
  localStorage.dieRoll = roll("1d20");

getDifficultyModifiers()=>
  let t = "";
  let critSuccess = 0;
  let critFail = 0;
  let success = 0;
  let fail = 0;
  switch(difficultyModeEl.value){
    case "hard":
      critSuccess = 20;
      success = 15;
      fail = 10;
      critFail = 1;
      break;
    case "free":
      critSuccess = 15;
      success = 10;
      fail =1;
      break;
    case "impossible":
      critSuccess = 21;
      success = 20;
      fail = 10;
      critFail = 5;
    default:
      critSuccess = 20;
      success = 15;
      fail =5;
      critFail = 1;
      break;
  }
  switch(gameModeEl.value){
    case "game":{
      if(localStorage.dieRoll){
        if(localStorage.dieRoll >= critSuccess){
          t= "The player has succeeded in their action in the best possible way.";
        }
        else if(localStorage.dieRoll >= success){
          t= "The player has succeeded in their action.";
        }
        else if(localStorage.dieRoll <= fail){
          t= "The player has failed in their action.";
        }
        else if(localStorage.dieRoll <= critFail){
          t= "The player has failed in their action in the worst possible way.";
        }
        else
          t= "The player's attempt has resulted in a neutral outcome.";}
      else
        t= "The player's attempt has resulted in a neutral outcome.";
    }
    break;
    default:
      switch (difficultyModeEl.value){
        case "hard": t = "`DIFFICULTY_LEVEL: **VERY HARD** (permadeath; highly realistic consequences; strict aherence to reality; player CANNOT take impossible actions)`";
          break;
        case "free": t = "`DIFFICULTY_LEVEL: **VERY EASY ** (NPCs will accept the players actions; no consequences; the player can do anything`";
          break;
        case "impossible": t = "'DIFFICULTY_LEVEL: **IMPOSSIBLE** (Everything the player tries will fail; horrible things will happen; the player cannot succeed'";
          break;
      }
      break;
  }
    return t;


getExtraInstructionsForConsequencesOfAction() =>
  let lines = [];
  lines.push(getDynamicNotes() || null);
  lines = lines.concat(searchLore());
	lines.push(gameModeEl.value === "game" ? "You should sometimes note any interactable objects/items/exits/etc in the environment, in typical text game style.": null);
  lines.push(getDifficultyModifiers());
  lines.push(getPerspective());
  lines.push("Tell the story in the present tense.");
	switch(pacingModeEl.value){
		case "quick" : lines.push(`Pacing: fast (No unnecessary detail, keep the story moving forward, avoid detailed descriptions)`);
      break;
		case "detailed" : lines.push(`Pacing: Detailed (linger in the present moment, give detailed descriptions of events occurring as they happen). Describe everything happening using all relevant senses.` );
      break;
		case "gloss" : lines.push(`Skip forward to the next logical point in the story. Skip all unnecessary information and detail.)`);
      break;
	}
	switch(genreModeEl.value){
		case "adventure": lines.push(`This is an action/adventure story. When narratively appropriate, proactively introduce both external and internal conflicts to drive the story forward when necessary. Escalate tensions gradually, creating a sense of anticipation.`);
      break;
		case "comedy": lines.push(`This is a comedy story.`);
      break;
		case "lifeSim": lines.push(`This is a slice-of-life story. No violence is permitted.`);
      break;
		case "coa" : lines.push(`This is a coming of age story. No violence is permitted.`);
      break;
		case "horror": lines.push(`This is a horror story.`);
      break;
		case "romance" : lines.push(`This is a romance story. No violence is permitted.`);
      break;
		case "mystery" : lines.push(`This is a mystery story.`);
      break;
		case "drama" : lines.push(`This is a drama story. Use tropes from the soap opera genre to tell the story.`);
      break;
		case "survival" : lines.push(`This is a story about survival.`);
      break;
		case "school" : lines.push('The story is a school drama, with an emphasis on interpersonal relationships and conflict.');
      break;
		case "isekai" : lines.push('The story is an Isekai, with the player having been taken from the real world to this one.');
      break;
	}
	switch(subGenreModeEl.value){
		case "adventure": lines.push(`This is an action/adventure story. When narratively appropriate, proactively introduce both external and internal conflicts to drive the story forward when necessary. Escalate tensions gradually, creating a sense of anticipation.`);
      break;
		case "comedy": lines.push(`This is a comedy story.`);
      break;
		case "lifeSim": lines.push(`This is a slice-of-life story. No violence is permitted.`);
      break;
		case "coa" : lines.push(`This is a coming of age story. No violence is permitted.`);
      break;
		case "horror": lines.push(`This is a horror story.`);
      break;
		case "romance" : lines.push(`This is a romance story. No violence is permitted.`);
      break;
		case "mystery" : lines.push(`This is a mystery story.`);
      break;
		case "drama" : lines.push(`This is a drama story. Use tropes from the soap opera genre to tell the story.`);
      break;
		case "survival" : lines.push(`This is a story about survival.`);
      break;
		case "school" : lines.push('The story is a school drama, with an emphasis on interpersonal relationships and conflict.');
      break;
		case "isekai" : lines.push('The story is an Isekai, with the player having been taken from the real world to this one.');
      break;
	}
  lines.push(getVoice());
	switch(namingModeEl.value){
		case  "greek" : lines.push(`Use Greek naming conventions.` );
      break;
		case  "norse" : lines.push(`Use Norse naming conventions.` );
      break;
		case  "spanish" : lines.push(`Use Spanish naming conventions.` );
      break;
		case  "french" : lines.push(`Use French naming conventions.` );
      break;
		case  "italian" : lines.push(`Use Italian naming conventions.`) ;
      break;
		case  "roman" : lines.push(`Use Roman naming conventions.` );
      break;
		case  "egyptian" : lines.push(`Use Egyptian naming conventions.` );
      break;
		case  "aztec" : lines.push(`Use Aztec naming conventions.` );
      break;
		case  "chinese" : lines.push(`Use Chinese naming conventions.` );
      break;
		case  "japanese" : lines.push(`Use Japanese naming conventions.` );
      break;
		case  "korean" : lines.push(`Use Korean naming conventions.` );
      break;
		case  "indian" : lines.push(`Use Indian naming conventions.` );
      break;
		case  "mayan" : lines.push(`Use Mayan naming conventions.` );
      break;
		case  "portuguese" : lines.push(`Use Portuguese naming conventions.` );
      break;
		case  "irish" : lines.push(`Use Irish naming conventions.` );
      break;
		case  "celtic" : lines.push(`Use Celtic naming conventions.` );
      break;
		case  "scottish" : lines.push(`Use Scottish naming conventions.` );
      break;
		case  "german" : lines.push(`Use German naming conventions.`);
      break;
		case  "english" : lines.push(`Use English naming conventions.`);
      break;
		case  "polish" : lines.push(`Use Polish naming conventions.`);
      break;
		case  "dutch" : lines.push(`Use Dutch naming conventions.`);
      break;
		case  "swedish" : lines.push(`Use Swedish naming conventions.`);
      break;
	}
	lines = lines.filter(l => l); // filter out `null` lines
	text = lines.join("\n").trim();
	return text;

getDynamicNotes() =>
  let notes = [];
  if(localStorage.infoTrackingEnabled) {
    if(/\nmana: 0(\n|\/)/i.test(currentTrackedInfoEl.value)) notes.push("If a character has zero mana, they cannot cast spells.");
  }
  return notes.length > 0 ? "\n# Notes:\n- "+notes.join("\n- ") : "";

getExtraInstructionsForContinueWithoutTask() =>
  let lines = [];
  if(responseStyleEl.value === "@@@custom" && storyWritingStyleCustomInputEl.value.trim()) {
    lines.push("WRITING_STYLE: "+storyWritingStyleCustomInputEl.value);
  }
  lines = lines.filter(l => l); // filter out `null` lines
  let text = lines.join("\n").trim();
  return text;

// Edit the text below to adjust the AI's writing style, then click save. You can start by just adding/removing/editing lines from the Tips section.
// Make sure not to change the indentation of any lines. I.e. there should be 2 spaces before each line in the instruction.
// This `sharedInstructionPrefix` is placed before the specific task instructions like `consequencesOfActionTaskInstruction` and `continueWithoutActionTaskInstruction`.
sharedInstructionPrefix // stuff that we put before all tasks - i.e. general context/rules, overview, plus the adventure/story text so far.
  In this open-world story, your task is to simulate the world around the player, and write the consequences of the player's actions. Follow all instructions given.
  [""]
  //- The story is a dialogue between you and the player.
  //- You must not reference previous events.
  - You must not act or speak on the player's behalf.
  - Use only English.
  //- You must not narrate, repeat, or rephrase the player's actions or commands.
  //- You must not repeat phrases.
  //- Avoid repetition.
  - Avoid using similes.
  - When a character leaves the scene, forget about them.
  - You must not mention characters unless directly relevant to the scene.
  - Follow typical narrative structure. Scenes with a high amount action and stress should be followed by downtime.
  - Focus on the people around the player.
  - Introduce characters naturally. You must not introduce new characters mid-scene.
  - Write the story using prose.
  //- Do not remind the player about anything. The player is intelligent and can remember stuff.
  - This story never ends. When narratively appropriate, proactively drive the story forward, introducing new arcs, and new events/situations for the player to react to. //When narratively appropriate, proactively introduce both external and internal conflicts to drive the story forward when necessary. Escalate tensions gradually, creating a sense of anticipation.
  - Everything is allowed.
  - Aggression, graphic violence, death, character toxicity, and vulgarity are allowed in scenarios with mature themes. You should portray conflict and suffering realistically - i.e. without shallow resolutions or excessive positivity bias.
  - Let the player carve their own path. Don't railroad them into a specific story. This is an open-world story, so the player can attempt *any* action they want, and the story will fluidly and realistically adapt around the consequences of their actions.
  //- You should sometimes note any interactable objects/items/exits/etc in the environment, in typical text game style.
  - For coherent and grounded gameplay, ensure the story world rules are enforced. For example, a character cannot cast a spell if they have zero mana.
  - Avoid using the names "Castellanos", "Grom", "Henderson", or "Elara".
  // NOTE: This line and the lines below are 'comments' - i.e. they're ignored by the Perchance engine due to the "//" at the start. The lines below are historical 'tips' that I'm not using anymore, but I'm keeping them here in case I need to enable them at some point.
  // - Use the 'OVERVIEW' to deeply intuit the story arc of the game that the player wants to play. You should aim to direct your simulation of the world toward an experience that you think the player is likely to enjoy, based on their past actions.
  // - IMPORTANT: Use a direct, concise, clean, relaxed writing style.
  // - Avoid clichés, excessive metaphors, and exposition dumps.
  // - Let the player discover the world/characters/plot by interacting with it (e.g. via dialogue with NPCs, interaction with the world, etc.)
  // - DO NOT foreshadow, and never hint at potential player choices.
  // - Do NOT "wrap up" your responses with vaguely broad statements or questions to the player.
  // - You should end your responses abruptly at points where a player decision is needed.
  // - Keep your writing crisp and direct. No waffling or grandiose phrasing. It is **forbidden** to use excessive literary embellishments, or purple prose. NEVER use excessive metaphor or long-winded sentences.
  // - Your job as a DM is to simulate the world *around* the player - i.e. the actions of the NPCs, the state of the world, etc. - you must never make decisions on behalf of the player. Only the *player* can decide what they will do/say/thing.
  // - Avoid repetition of previous information.
  // - Don't bore the player with excessive descriptions. This is a game, not a novel.
  [""]
  [storySoFarEl.value.trim().length < 700 ? `\n# Forbidden Words:\n- cacophony\n- symphony\n- verdant\n- tapestry/tapestries\n- testament\n- sentinel\n- cerulean\n- whisper/whispers/whispering/whispered\n- sun kissed the horizon\n- stark\n- reminder\n` : ""]
  # Overall, here's what the story should be about[storySoFarEl.value.trim().length < 1000 ? " (lead into this slowly)" : ""]: // while the story is less than 1000 characters long, we tell the AI to lead into it slowly, so it doesn't try to immediately jump to important plot points that are specified in the overview
  OVERVIEW: [literal(storyOverviewEl.value.trim()) || "(Unsure, you decide.)"]
  [""]
  # STORY SO FAR[storyOverviewEl.value.trim() ? ` (previous player actions are prefixed with ">")` : ""]:
  [literal(window.processedStorySoFarText || "(Nothing yet.)")]
  [getExtraSharedInstructionPrefixStuff()]
  $output = [this.joinItems("\n").trim()]

getExtraSharedInstructionPrefixStuff() =>
  let lines = [];
  lines.push(!storyArcInstructionEl.hidden & storyArcInstructionEl.value.trim() !== "" ? `NEXT_KEY_EVENT (Make sure this happens): ${literal(storyArcInstructionEl.value.replace(/\n/g, " "))}` : null);
  lines = lines.filter(l => l); // filter out `null` lines
  let text = lines.join("\n").trim();
  text = "\n\n<instructions>\n"+text;
  return text;

generationEventHandlers
  onStart(data) =>
    window.gotFirstChunk = false; // first 'used'/appended chunk of the output
    window.withheldTrailingNewlines = ""; // if a chunk ends in a newline, we don't immediately add it - instead we put it in this buffer, in case it's the end of the generated text, in which case we don't want to add it, since that cause "scroll jank" when we later remove it
    generateBtn.disabled = true;
    rollGenerateBtn.disabled = true;
    regenLastBtn.disabled = true;
    deleteLastBtn.disabled = true;
    generateBtn.textContent = "⌛ loading...";
    stopBtn.style.display = "block";
    if(storySoFarEl.value.trim() && window.continueMode !== "inline") storySoFarEl.value += "\n";
    storySoFarEl.scrollTop = 99999999;
  onChunk(data) =>
    if(data.isFromStartWith) {
      if(window.includeStartWithInOutput) {
        storySoFarEl.appendText(data.textChunk); // ctrl+f for includeStartWithInOutput to see where we use this
        window.gotFirstChunk = true;
        setInterfaceMode("normal");
      }
    } else {
      let textChunk = data.textChunk;

      //storySoFarEl.value = storySoFarEl.value.replace(/—/, "- ");
      // First chunk stuff:
      if(!window.gotFirstChunk) {
        if(storySoFarEl.value.trim() && window.continueMode !== "inline") {
          textChunk = "\n"+textChunk.replace(/^\s*\n+/g, "");
        }
      }

      // we 'move' the trailing new lines from the end of the last token to the start of this token:
      textChunk = window.withheldTrailingNewlines + textChunk;
      window.withheldTrailingNewlines = "";

      // remove trailing newlines - to prevent "scroll jank" in onFinish when we trim() the story
      let trailingNewlines = textChunk.match(/\n+$/)?.[0]
      if(trailingNewlines) {
        window.withheldTrailingNewlines += trailingNewlines;
        textChunk = textChunk.replace(/\n+$/, "");
      }

      if(textChunk.length > 0) { // <-- since empty chunks are possible, and they would ruin our withheldTrailingNewlines stuff
        storySoFarEl.appendText(textChunk);
      }
      textChunk = textChunk.replace(/<.+>/g , "");
      if(storySoFarEl.value.endsWith("\n# Player")) {
        storySoFarEl.value = storySoFarEl.value.replace(/\n# Player$/g, "")
      }

      // Hacky purple prose fixes for opening paragraph:
      if(storySoFarEl.value.length < 800) {
        let t = storySoFarEl.value;
        if(t.includes("the cacophony")) t = t.replace(/the cacophony/, "the sound");
        if(t.includes("was thick with")) t = t.replace(/was thick with/, "had");
        if(t.includes("symphony of")) t = t.replace(/symphony of/, "pattern of");
        if(t.includes("tapestry of")) t = t.replace(/tapestry of/, "pattern of");
        if(/\b(shade of emerald)\b/.test(t)) t = t.replace(/\b(shade of emerald)\b/, "shade of green");
        if(/\b(stark reminder)\b/.test(t)) t = t.replace(/\b(stark reminder)\b/, "reminder");
        if(/\b(is a stark contrast to)\b/.test(t)) t = t.replace(/\b(is a stark contrast to)\b/, "contrasts with");
        if(storySoFarEl.value !== t) storySoFarEl.value = t;
      }
      window.gotFirstChunk = true;
      setInterfaceMode("normal");
    }
    if(storySoFarEl.scrollTop > (storySoFarEl.scrollHeight - storySoFarEl.offsetHeight)-50) { // <-- if the text box is already scrolled near the end of the text
      storySoFarEl.scrollTop = 99999999; // scroll down to bottom of text box as story streams in
    }
  onFinish(data) =>
    if(storySoFarEl.value.length < 10000 & /^\*?\*?paragraph 1\*?\*?:\s+?/i.test(storySoFarEl.value)) {
      // for some reason the ai sometimes adds this
      storySoFarEl.value = storySoFarEl.value.replace(/^\*?\*?paragraph 1\*?\*?:\s+?/i, "");
    }
    generateBtn.disabled = false;
    rollGenerateBtn.disabled = false;
    localStorage.dieRoll = null;
    updateRollView();
    regenLastBtn.disabled = false;
    deleteLastBtn.disabled = false;
    generateBtn.textContent = "▶️ continue";
    stopBtn.style.display = "none";
    antiAntiLayoutJank(() => storySoFarEl.value = storySoFarEl.value.trim()); // remove newlines and spaces from the end of the story
    localStorage.storySoFar = storySoFarEl.value;
    updateButtonsDisplay();
    if(storySoFarEl.value.length > 1000) whatHappensNextEl.placeholder = "(Optional) What will you do next?";
    if(localStorage.autoUpdate === "true") updateTrackedInfo();

getParagraphEndRegex() => return /[.。．！!？?ー":*»’”—–。]$/;

async regenLast() =>
  if(!storySoFarEl.value.trim().includes("\n")) { // i.e. only the intro paragraph
    antiAntiLayoutJank(() => storySoFarEl.value="");
  } else if(window.storyTextBeforeLastGeneration !== undefined && window.storyTextBeforeLastGeneration !== null) {
    antiAntiLayoutJank(() => { storySoFarEl.value=window.storyTextBeforeLastGeneration; storySoFarEl.scrollTop=storySoFarEl.scrollHeight; }); // e.g. for when they continued generation mid-paragraph, the regen button should try from that mid-paragraph point, not delete the whole paragraph
  } else {
    // let lastActionStartIndex = storySoFarEl.value.lastIndexOf("\n>");
    // if(lastActionStartIndex !== -1) {
    //   let lastStoryTextStartIndex = storySoFarEl.value.indexOf("\n", lastActionStartIndex+3);
    //   if(lastStoryTextStartIndex !== -1) {
    //     antiAntiLayoutJank(() => storySoFarEl.value = storySoFarEl.value.slice(0, lastStoryTextStartIndex));
    //   }
    // }
    let chunks = storySoFarEl.value.trim().split(/\n\n/);
    antiAntiLayoutJank(() => { storySoFarEl.value=chunks.slice(0, -1).join("\n\n"); storySoFarEl.scrollTop=storySoFarEl.scrollHeight; });
  }
  localStorage.storySoFar = storySoFarEl.value;
  continueStory({continueInline:!!window.lastGenWasContinueInline});

getPreprocessedStoryText() =>
  let storySoFarText = storySoFarEl.value;
  let resultText = storySoFarText;
  try {
    // get a version of the message feed with hierarchical summaries swapped in:
    let messagesWithSummaryReplacements = getMessagesWithSummaryReplacements(storySoFarText);

    if(messagesWithSummaryReplacements.slice(-8).filter(m => /^SUMMARY\^[0-9]+:/.test(m)).length > 0) {
      console.error("Summarization is going too close to the end of the story. Must stay back so LLM doesn't get confused, and so messages-in-startWith trick works.");
    }

    // The getMessagesWithSummaryReplacements function will remove the <tracked_info_placeholder>
    // So we add it back by getting all messages after the tracked info, then finding the first one of those in the `messagesWithSummaryReplacements`, and putting the tracked info placeholder before that.
    if(/(^|\n)<tracked_info_placeholder>(\n|$)/.test(storySoFarText) && !messagesWithSummaryReplacements.includes("<tracked_info_placeholder>")) {
      let messages = storySoFarText.split(/\n{2,}/).map(m => m.trim());
      let trackedInfoPlaceholderIndex = messages.findIndex(m => m === "<tracked_info_placeholder>");
      if(trackedInfoPlaceholderIndex !== -1) {
        let messagesAfterTrackedInfo = messages.slice(trackedInfoPlaceholderIndex+1);
        // find first message that matches a message after the tracked info, and put the <tracked_info_placeholder> before that:
        for(let i = 0; i < messagesWithSummaryReplacements.length; i++) {
          let m = messagesWithSummaryReplacements[i].trim();
          if(messagesAfterTrackedInfo.includes(m)) {
            messagesWithSummaryReplacements.splice(i, 0, "<tracked_info_placeholder>");
            break;
          }
        }
      }
    }
    console.log(messagesWithSummaryReplacements);
    messagesWithSummaryReplacements = messagesWithSummaryReplacements.map(m => m.replace(/SUMMARY\^[0-9]+:/, "Summary (previous events):").trim());

    resultText = messagesWithSummaryReplacements.join("\n\n").trim();
  } catch(e) {
    console.error("Falling back to using *all* messages because there was an error while trying to compute messagesWithSummaryReplacements:", e);
  }
  resultText = resultText.replace(/(^|\n+)<tracked_info_placeholder>\n*/, infoTrackingBtn.dataset.enabled && currentTrackedInfoEl.value ? `\n\n<tracked_info>\n${currentTrackedInfoEl.value}\n</tracked_info>\n\n` : "\n\n");
  resultText = resultText + getPerspective() + "Tell the story in the present tense.";
  resultText = resultText.trim();
  return resultText;

async continueStory(opts) =>
  if(!opts) opts = {};
  if(window.currentlyGenerating) return; // we already disable buttons below, but this is just for extra safety
  window.currentlyGenerating = true;

  window.lastGenWasContinueInline = !!opts.continueInline;

  try { injectSummariesAndComputeNextSummariesInBackgroundIfNeeded(); } catch(e) { console.error(e); }
  await new Promise(r => setTimeout(r, 5)); // just in case i accidentally make the above function async at some point - want to ensure it grabs a snapshot of the chat logs text before `temporarilyRemovedPrefixChatLogsForStreamingRenderPerformance` stuff

  window.userClickedStop = false;
  resetRatingButtons();

  continueTextBtn.style.visibility = "hidden"; // using this too because i think the continue button textarea tracking stuff is making it visible during generation via style.display
  continueTextBtn.hidden = true;
  continueTextBtn.disabled = true;
  storySoFarEl.spellcheck = false;
  shortcutButtonsCtn.querySelectorAll("button").forEach(el => el.disabled=true);

  updateTrackedInfoUndoBtn.hidden = true;

  // important for summary stuff, since we need "normalized" paragraphs so that summary replacements/injections work properly:
  antiAntiLayoutJank(() => { storySoFarEl.value = storySoFarEl.value.trim().split(/\n{2,}/).map(p => p.trim()).join("\n\n"); storySoFarEl.scrollTop=storySoFarEl.scrollHeight; })

  // if(!opts.continueInline && storySoFarEl.value !== "" && getParagraphEndRegex().test(storySoFarEl.value.trim())) { // if the story textbox isn't empty and it ends with a fullstop, question mark, quote, etc.
  //   antiAntiLayoutJank(() => storySoFarEl.value = storySoFarEl.value.trim() + "\n\n"); // then we add a couple of new lines to the end, ready for the next paragraph that's about to be generated
  // }

  if(infoTrackingBtn.dataset.enabled && currentTrackedInfoEl.value.trim() && !storySoFarEl.value.includes("<tracked_info_placeholder>")) {
    storySoFarEl.value = storySoFarEl.value.trim().replace(/\n+<tracked_info_placeholder>\n*/g, "\n\n").trim() + "\n\n<tracked_info_placeholder>";
  }


  if(opts.continueInline) {
    antiAntiLayoutJank(() => storySoFarEl.value = storySoFarEl.value.trim());
    window.continueMode = "inline";
  } else {
    window.continueMode = "normal";
    if(storySoFarEl.value.trim() && whatHappensNextEl.value.trim()) {
      storySoFarEl.value = storySoFarEl.value.trim() + "\n\n" + "> "+whatHappensNextEl.value.trim();
      whatHappensNextEl.value = "";
      localStorage.whatHappensNext = "";
    }
  }
  storySoFarEl.scrollTop = storySoFarEl.scrollHeight;

  // function replaceLast(str, pattern, replacement) {
  //   const index = str.lastIndexOf(pattern);
  //   if (index === -1) return str;
  //   return str.slice(0, index) + replacement + str.slice(index + pattern.length);
  // }

  let instructionStoryText = getPreprocessedStoryText();
  let continueWithAction = false; // we only use the "action" task template if there was a "> " which precedes the text we're about to generate
  let instructionStoryChunks = instructionStoryText.trim().split("\n\n");

  // We don't want e.g. part of the tracked_info to be put in the startWith,
  // so we make sure its all in a single chunk
  if(instructionStoryText.includes("<tracked_info>")) {
    let instructionStoryChunksFixed = [];
    let areWithinMultiParagraphSection = false;
    let currentMultiParagraphSectionChunks = [];
    for(let p of instructionStoryChunks) {
      if(p.trim().startsWith("<tracked_info>")) areWithinMultiParagraphSection = true;

      if(areWithinMultiParagraphSection) {
        currentMultiParagraphSectionChunks.push(p);
        if(p.trim().endsWith("</tracked_info>")) {
          instructionStoryChunksFixed.push(currentMultiParagraphSectionChunks.join("\n\n"));
          currentMultiParagraphSectionChunks = [];
          areWithinMultiParagraphSection = false;
        }
      } else {
        instructionStoryChunksFixed.push(p);
      }

    }
    instructionStoryChunks = instructionStoryChunksFixed;

    // we don't really want the tracked info being put into the startWith
    // so as a little hack, we move it back one spot from the end if it's at the end
    if(instructionStoryChunks.length >= 2 && instructionStoryChunks.at(-1).trim().startsWith("<tracked_info>")) {
      let lastIndex = instructionStoryChunks.length-1;
      let trackedInfo = instructionStoryChunks[lastIndex];
      instructionStoryChunks[lastIndex] = instructionStoryChunks[lastIndex-1];
      instructionStoryChunks[lastIndex-1] = trackedInfo;
    }
  }

  let inlineCompletionText = "";
  if(window.continueMode === "inline") {
    // we kind of treat the inline-completed paragraph like that text is "generated" by the function call, rather than being part of the story.
    // so we don't have to mess around with extra if conditions in the NEXT_ACTION stuff below, for example.
    inlineCompletionText = instructionStoryChunks.pop();
  }

  // if last paragraph starts with "> " then we should use the "action" template.
  if(instructionStoryChunks.at(-1)?.trim().startsWith("> ")) continueWithAction = true;

  if(continueWithAction) { // replace last "> " with "NEXT_ACTION: "
    // NOTE: the underscore is important! as of writing, the LLM that the ai text plugin uses pays more attention to it
    let lastParagraph = instructionStoryChunks.at(-1);
    if(lastParagraph.trim().startsWith("> ")) instructionStoryChunks[instructionStoryChunks.length-1] = lastParagraph.trim().replace(/^> /, "NEXT_ACTION: ");
  }

  let startWithStoryText = "";
  if(continueWithAction) {
    startWithStoryText = startWithPrefix+"\n"+inlineCompletionText;
  } else {
    // the paragraph before the one being generated should be in the startWith, to help the AI see the continuation of the story properly (i.e. not get distracted by the instructions)
    startWithStoryText = instructionStoryChunks.pop() || "";
    if(inlineCompletionText) {
      startWithStoryText += (startWithStoryText ? "\n\n" : "") + inlineCompletionText;
    } else {
      startWithStoryText += "\n\n";
    }
  }

  instructionStoryText = instructionStoryChunks.join("\n\n");

  window.processedStorySoFarText = instructionStoryText.trim(); // global, because it's used by sharedInstructionPrefix

  if(continueWithAction) {
    window.taskPrompt = consequencesOfActionTaskInstruction.evaluateItem;
  } else {
    window.taskPrompt = continueWithoutActionTaskInstruction.evaluateItem;
  }
  window.taskPrompt += "\n</instructions>"; // since sharedInstructionPrefix adds <instruction> at the start of the shared instructions to help separate all the instructions from the story text

  window.storyTextBeforeLastGeneration = storySoFarEl.value;
  if(storySoFarEl.value.trim()) {
    window.lastGenerationStreamObj = ai({
      instruction: () => {
        let lines = [];
        lines.push(sharedInstructionPrefix.evaluateItem);
        lines.push(window.taskPrompt);
        return lines.join("\n").trim().replace(/<instructions>\n+/, "<instructions>\n");
      },
      startWith: () => {
        if(storySoFarEl.value.trim() === "") return "";
        return startWithStoryText;
      },
      // CAUTION: note to self: if you change the stop sequence, ensure that the onChunk new-line removal stuff still makes sense
      stopSequences: ["\n\n", "\n# Player"],
      onStart: generationEventHandlers.onStart,
      onChunk: generationEventHandlers.onChunk,
      onFinish: generationEventHandlers.onFinish,
    }); // we put it into a 'global' variable so that we can use it in the 'onclick' of the stop button to stop the text generation
  } else {
    storySoFarEl.value = storySoFarEl.value.trim();
    window.includeStartWithInOutput = true;
    window.lastGenerationStreamObj = ai({
      instruction: `Write the opening paragraph of an interactive story based on this instruction/idea by the player: "${storyOverviewEl.value.trim() || "Something unusual and fun"}"\nWrite one paragraph only. This is just the opening paragraph - the *start* of the story, so don't progress too quickly. Avoid cringe/overly grandiose phrasing. Start in a specific/concrete situation, perhaps with some character dialogue. Don't reveal key story details yet.  ${Math.random() < 0.5 ? " Include some character dialogue." : "" } ${getVoice()}/n ${getPerspective()}  Tell the story in the present tense. `,
      //startWith: "You",
      stopSequences: ["\n"],
      onStart: generationEventHandlers.onStart,
      onChunk: generationEventHandlers.onChunk,
      onFinish: generationEventHandlers.onFinish,
    });
    window.lastGenerationStreamObj.then(() => {
      window.includeStartWithInOutput = false;
    });
  }

  loaderEl.innerHTML = window.lastGenerationStreamObj.loadingIndicatorHtml;

  let data = await window.lastGenerationStreamObj;

  loaderEl.innerHTML = "";

  window.currentlyGenerating = false;

  if(localStorage.generateCount === undefined || isNaN(Number(localStorage.generateCount))) localStorage.generateCount = "0";
  localStorage.generateCount = Number(localStorage.generateCount) + 1;
  updateLastParagraphButtonsDisplayIfNeeded();

  if(data.stopReason !== "error" && !window.userClickedStop) {
    enableRatingButtons();
  }

  if(/, a stark reminder of [^.]{0, 20}\.$/.test(storySoFarEl.value.slice(-2000).trim())) {
    storySoFarEl.value = storySoFarEl.value.trim().replace(/, a stark reminder of [^.]{1,40}\.$/, ".");
  }

  continueTextBtn.disabled = false;
  continueTextBtn.style.visibility = "visible";
  storySoFarEl.spellcheck = true;
  shortcutButtonsCtn.querySelectorAll("button").forEach(el => el.disabled=false);

  let generateCount = Number(localStorage.generateCount);
  if(generateCount > 20 && !localStorage.haveUsedTabToContinueMessage) {
    let isTouchScreen = false;
    try { isTouchScreen = window.matchMedia("(pointer: coarse)").matches; } catch(e) { console.error(e); }
    if(window.innerWidth > window.innerHeight && !isTouchScreen) {
      continueTextBtnTabLabel.style.display = "";
    }
  }
  if(generateCount > 5) subtitleEl.style.display = "none";

updateLastParagraphButtonsDisplayIfNeeded() =>
  let generateCount = Number(localStorage.generateCount);
  if(generateCount > 4) {
    rateLastMessageCtn.style.display = "inline-block";
    deleteLastBtn.textContent = "🗑️";
    deleteLastBtn.style.minWidth = "3rem";
    regenLastBtn.textContent = "🔁";
    regenLastBtn.style.minWidth = "3rem";
  }

updateButtonsDisplay() =>
  if(storySoFarEl.value.trim() === "") {
    bottomButtonsCtn.style.display = "none";
  } else {
    bottomButtonsCtn.style.display = "flex";
    generateBtn.textContent = "▶️ continue";
  }



deleteLastParagraph() =>
  window.storyTextBeforeLastParagraphDelete = storySoFarEl.value;
  if(window.storyTextBeforeLastGeneration) window.storyTextBeforeLastGeneration_beforeParagraphDelete = window.storyTextBeforeLastGeneration;
  window.storyTextBeforeLastGeneration = null;
  antiAntiLayoutJank(() => { storySoFarEl.value = storySoFarEl.value.trim().split('\n\n').slice(0, -1).join('\n\n'); storySoFarEl.scrollTop = storySoFarEl.scrollHeight; });
  localStorage.storySoFar = storySoFarEl.value;
  // show undo button for a few seconds:
  undoDeleteLastParagraphCtn.style.display = "";
  clearTimeout(window.undoDeleteButtonHideTimeout);
  window.undoDeleteButtonHideTimeout = setTimeout(() => {
    undoDeleteLastParagraphCtn.style.display = "none";
  }, 1000*4);
undoDeleteLastParagraph() =>
  if(window.storyTextBeforeLastParagraphDelete) {
    antiAntiLayoutJank(() => storySoFarEl.value = window.storyTextBeforeLastParagraphDelete);
    if(window.storyTextBeforeLastGeneration_beforeParagraphDelete) window.storyTextBeforeLastGeneration = window.storyTextBeforeLastGeneration_beforeParagraphDelete;
    window.storyTextBeforeLastGeneration_beforeParagraphDelete = null;
    localStorage.storySoFar = storySoFarEl.value;
    undoDeleteLastParagraphCtn.style.display = "none";
  } else {
    console.error("??? should not have been able to click delete button.");
  }

antiAntiLayoutJank(fn) => // due to browser's built-in anti-scroll-jank algorithm which sometimes has bad heuristics - i.e. forcibly scrolls whole page to keep textarea text in same position, despite that not being what we want
  let prevPageScrollTop = document.scrollingElement.scrollTop; // record page scroll position
  fn();
  document.scrollingElement.scrollTop = prevPageScrollTop; // restore page scroll position




generateWhatHappensNextIdeas() =>
  whatHappensNextSuggestionsCtn.style.display = "";
  generateWhatHappensNextIdeasBtn.disabled = true;

  let textSoFar = "";
  let pendingObj = ai({
    instruction: whatHappensNextInstruction.evaluateItem,
    startWith: `Here are 3 different ideas for what you could do next in this story:\n1. I`,
    onChunk: (data) => {
      textSoFar += data.textChunk;
      if(!data.isFromStartWith) {
        whatHappensNextSuggestionsCtn.innerHTML = textSoFar.replace(/\n+/g, "\n\n");
      }
    },
    onFinish: () => {
      let existingInstruction = (window.whatHappensNextSuggestionsRegenInstructions || "").trim().replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

      let html = textSoFar.trim().split("\n").filter(l => /^[0-9]+\./.test(l.trim())).map(l => l.replace(/^[0-9]+\./g, "").trim()).map(ideaText => {
        let ideaTextEscaped = ideaText.replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        return `<div style="border:1px solid gray; margin:0.25rem; display:flex; padding:0.25rem; border-radius:3px;">
          <div style="">${ideaTextEscaped}</div>
          <button data-idea="${ideaTextEscaped}" onclick="whatHappensNextEl.value=this.dataset.idea; whatHappensNextSuggestionsCtn.style.display='none';">use</button>
        </div>`;
      }).join("");

      html = `<div style="max-height: min(90vh, 600px); overflow: auto ">${html}</div>`;
      html += `<div style="display:flex; margin:0.25rem;"><input value="${existingInstruction}" oninput="window.whatHappensNextSuggestionsRegenInstructions=this.value" placeholder="(Optional) Idea regen instructions." style="flex-grow: 1;"><button style="margin-left: 0.25rem;" onclick="generateWhatHappensNextIdeas()">🔁 regen</button></div>`;

      whatHappensNextSuggestionsCtn.innerHTML = html;
      generateWhatHappensNextIdeasBtn.disabled = false;
    },
  });
  whatHappensNextSuggestionsCtn.innerHTML = pendingObj.loadingIndicatorHtml;

whatHappensNextInstruction
  Please write 3 *short* one-sentence, creative ideas for what the player could do next in this story. You should guess at actions that the player is likely to want to choose, based on their previous actions (prefixed by ">").
  [""]
  [literal(getMessagesWithSummaryReplacements(storySoFarEl.value).map(m => m.replace(/SUMMARY\^[0-9]+:/, "Summary (previous events):")).join("\n\n").trim())]
  [""]
  Again, please write 3 one-sentence ideas. They should be unique, creative, high-level ideas for what the player could do next, which the player is likely to find appealing (based on your observation of their previous actions). Just give a few words for each idea.
  Your ideas should be comparable to that of a world–renowned, award-winning author. Original, subtle, realistic, engaging, authentic, grounded, nuanced.
  Each idea must be a SINGLE, *short* sentence.
  Phrase your ideas in first person like "I decide to..."
  [window.whatHappensNextSuggestionsRegenInstructions?.trim() ? `IMPORTANT: Your ideas **MUST** be based on this instruction: ${window.whatHappensNextSuggestionsRegenInstructions}` : ""]
  Follow this template:
  [""]
  1. <a short, **ONE-SENTENCE** spark for an idea about what the player could do next>
  2. <a *DIFFERENT* idea for what the player could do next>
  3. <another SHORT alternative idea for what the player could do next>
  $output = [this.joinItems("\n")]



resetRatingButtons() =>
  rateLastMessageBadBtn.disabled = true;
  rateLastMessageGoodBtn.disabled = true;
  rateLastMessageBadBtn.style.opacity = 1;
  rateLastMessageGoodBtn.style.opacity = 1;

enableRatingButtons() =>
  rateLastMessageBadBtn.disabled = false;
  rateLastMessageGoodBtn.disabled = false;

async rateLastMessage(rating) =>
  if(!window.lastGenerationStreamObj) return;

  if(!localStorage.knowsHowRatingsWork) {
    if(!confirm("Your ratings help improve Perchance's AI plugin, which powers this generator. Please do not submit ratings if your story includes sensitive personal info.\n\nContinue?")) return;
    localStorage.knowsHowRatingsWork = "1";
  }

  let score = rating==="good" ? 1 : 0;
  rateLastMessageBadBtn.disabled = true;
  rateLastMessageGoodBtn.disabled = true;
  if(rating === "good") {
    rateLastMessageBadBtn.style.opacity = 0.2;
  } else {
    rateLastMessageGoodBtn.style.opacity = 0.2;
  }

  if(!window.recentRatingReasonCounts) window.recentRatingReasonCounts = {};
  let reasonCountEntries = Object.entries(window.recentRatingReasonCounts).sort((a,b) => b[1]-a[1]);
  if(reasonCountEntries.length > 10) reasonCountEntries = reasonCountEntries.slice(0, 10);
  window.recentRatingReasonCounts = Object.fromEntries(reasonCountEntries);
  recentRatingReasonsDataList.innerHTML =  reasonCountEntries.map(e => `<option value="${e[0].replace(/</g, "&lt;").replace(/"/g, "&quot;")}"></option>`).join("");

  let reasonResolver;
  let reasonFinishPromise = new Promise(r => reasonResolver=r);
  ratingReasonEl.value = "";
  ratingReasonCtn.style.display = "";
  ratingReasonEl.focus();
  await new Promise(r => setTimeout(r, 100));

  // if they click anywhere other than the reason input, then we resolve with the current contents of the reason box
  function windowClickHandler(event) {
    if(!ratingReasonCtn.contains(event.target)) {
      reasonResolver(ratingReasonEl.value);
    }
  }
  window.addEventListener("click", windowClickHandler);

  // if they press enter, then we resolve too
  function enterKeydownHandler(event) {
    if(event.key === 'Enter') {
      reasonResolver(ratingReasonEl.value);
    }
  }
  ratingReasonEl.addEventListener("keydown", enterKeydownHandler);

  let reason = await reasonFinishPromise;
  if(reason.length < 100) window.recentRatingReasonCounts[reason] = (window.recentRatingReasonCounts[reason] || 0) + 1;

  ratingReasonCtn.style.display = 'none';
  window.removeEventListener("click", windowClickHandler);
  ratingReasonEl.removeEventListener("keydown", enterKeydownHandler);
  window.lastGenerationStreamObj.submitUserRating({score, reason});


async currentTrackedInfoManualEditHandler() =>
  localStorage.currentTrackedInfo = currentTrackedInfoEl.value;
  window.manualCurrentTrackedInfoEditsSinceLastCheckpoint++;
  if(window.manualCurrentTrackedInfoEditsSinceLastCheckpoint > 10) {
    updateTrackedInfoUndoBtn.hidden = true;
  }
  update(updateTrackedInfoBtn);

async generateInitialTrackedInfo() =>
  let instruction = prompt("(Optional) Provide an instruction for the template you'd like to generate, 𝗼𝗿 𝗷𝘂𝘀𝘁 𝗰𝗹𝗶𝗰𝗸 𝗢𝗞.")
  if(instruction === null) return; // they clicked cancel
  let originalPlaceholder = currentTrackedInfoEl.placeholder;
  currentTrackedInfoEl.placeholder = "⏳ Loading... Just a sec.";
  updateTrackedInfoBtn.disabled = true;
  updateTrackedInfoStopBtn.hidden = false;
  currentTrackedInfoEl.value = "";
  let prePrefix = `<tracked_info>\n`;
  window.processedStorySoFarText = getPreprocessedStoryText();
  let promise = ai({
    instruction: `
    ${sharedInstructionPrefix.evaluateItem}
    Your task is to generate a simple plaintext RPG info tracking sheet with some starting values${storySoFarEl.value.trim() ? " Based on what has happened so far" : ""} for tracking an RPG game's world/character state. Base your response on this instruction: ${instruction || "Simple tracker for player's level, hitpoints, mana, xp, inventory, location, etc."}
    </instructions>

    BASIC EXAMPLE (you can change/add/remove things from this as necessary - this is just an example):
    <tracked_info>
    # Player:
    Level: 1
    Hitpoints: 100/100
    Mana: 10/10
    XP: 0/300
    Gold: 2
    Location: Adventurer's Guild, Arandale (Eastern Province of Daeanchen)
    Quest: None
    Inventory:
    - handkerchief
    - rusty dagger
    </tracked_info>
    `.trim(),
    startWith: `${prePrefix}# Player:`,
    stopSequences: ["</track"],
    onChunk: (data) => {
      currentTrackedInfoEl.value += data.textChunk;
      currentTrackedInfoEl.value = currentTrackedInfoEl.value.replace(prePrefix, "");
    },
  });
  updateTrackedInfoStopBtn.onclick = function() {
    promise.stop();
  };
  await promise;
  currentTrackedInfoEl.value = currentTrackedInfoEl.value.replace(/<\/track$/, "").trim();
  localStorage.currentTrackedInfo = currentTrackedInfoEl.value;
  currentTrackedInfoEl.placeholder = originalPlaceholder;
  updateTrackedInfoBtn.disabled = false;
  updateTrackedInfoStopBtn.hidden = true;
  storySoFarEl.value = storySoFarEl.value.trim().replace(/\n+<tracked_info_placeholder>\n*/g, "\n\n").trim() + "\n\n<tracked_info_placeholder>";
  localStorage.storySoFar = storySoFarEl.value;
  update(updateTrackedInfoBtn);


async updateTrackedInfo() =>
  if(!infoTrackingBtn.dataset.enabled) throw new Error("It shouldn't be possible to update tracked info if it's disabled.");

  if(localStorage.knowsTrackedInfoAutoUpdateIsInaccurate !== "1") {
    if(!confirm(`Note: The AI often makes mistakes when trying to auto-update the tracked info. I'll improve this eventually, but for now you may want to manually update this info to ensure accuracy.`)) return;
    localStorage.knowsTrackedInfoAutoUpdateIsInaccurate = "1";
  }

  let numMarkers = storySoFarEl.value.split(/\n+<tracked_info_placeholder>\n+/).length - 1;
  if(numMarkers > 1) { // should only be one, so we keep the last one:
    let i = -1;
    storySoFarEl.value = storySoFarEl.value.replace(/\n+<tracked_info_placeholder>\n+/, function(m) {
      i++;
      return i === numMarkers-1 ? m : "\n\n";
    });
  }
  if(numMarkers === 0) {
    storySoFarEl.value = storySoFarEl.value.trim().replace(/\n+<tracked_info_placeholder>\n*/g, "\n\n").trim() + "\n\n<tracked_info_placeholder>";
  }

  let originalPlaceholder = currentTrackedInfoEl.placeholder;
  currentTrackedInfoEl.placeholder = "⏳ Loading... Just a sec.";
  updateTrackedInfoBtn.disabled = true;
  updateTrackedInfoStopBtn.hidden = false;

  let error;

  let originalTrackedInfoText = currentTrackedInfoEl.value;
  try {
    let prePrefix = `<tracked_info:updated>\n`;
    let originalTextPrefix = originalTrackedInfoText.split(/[:=]/)[0];
    if(originalTextPrefix.includes("\n") || originalTextPrefix.length > 50) originalTextPrefix = "";

    window.processedStorySoFarText = getPreprocessedStoryText();
    let subsequentEventsText = window.processedStorySoFarText.split("</tracked_info>")[1].trim();
    subsequentEventsText = subsequentEventsText.replace(/ \(previous events\)/g, ""); // so it doesn't get confused by the hierarchical summary stuff, and think "previous" events should be excluded

    currentTrackedInfoEl.value = ""; // must come AFTER the call to getPreprocessedStoryText() above, since it is used in `getPreprocessedStoryText`

    // This commented-out old approach tried to rely on the prefix cache of the full story text, but it was confusing the model.
    // BUT: I'm not sure if the new approach will suffer from not having enough context on the stuff mentioned in the preceding events (e.g. character nicknames, and stuff like that)
    // EDIT: And also, the model still stuggles with the new approach anyway...
    // let promise = ai({
    //   instruction: `
    //   ${sharedInstructionPrefix.evaluateItem}
    //   TASK: Your task is to write an updated version of the tracked info, based on anything that has happened in the story AFTER the <tracked_info> block in the story you see above. Look at things that happened AFTER </tracked_info> and write the new, updated tracked info based on the things that have happened since then. Update the *existing* sections/properties (no new sections, no extra stuff).
    //   </instructions>
    //   `.trim(),
    //   startWith: `${prePrefix}${originalTextPrefix}`,
    //   stopSequences: ["</track"],
    //   onChunk: (data) => {
    //     currentTrackedInfoEl.value += data.textChunk;
    //     currentTrackedInfoEl.value = currentTrackedInfoEl.value.replace(prePrefix, "");
    //   },
    // });

    let generatedText = "";
    let trackedInfoText = "";
    let trackedInfoHasStarted = false;
    let promise = ai({
      instruction: `
      Below are some events that have happened since the tracked_info was last updated. Your task is to:
      1. Write a concise paragraph-by-paragraph dot-point summary of the events_since_last_tracked_info_update with a focus on events that could affect the tracked_info properties.
        - IMPORTANT: Within dot-point your summary, whenever you notice a tracked_info change, explicitly write the change in parentheses e.g. "(X changes from Y to Z)"
      2. Use the dot-point summary that you wrote to update the tracked_info data. Write your summary, and then after that, write the updated tracked info enclosed in tags like this: <tracked_info:updated>...</tracked_info:updated>

      ---

      <events_since_last_tracked_info_update>
      ${subsequentEventsText}
      </events_since_last_tracked_info_update>

      ---

      <tracked_info:original>
      ${originalTrackedInfoText}
      </tracked_info:original>

      ---

      Reminders:
      - If none of the tracked_info properties have changed, then just respond with the exact same tracked info text.
      - Your task is to write an updated version of the tracked info, based on your concise paragraph-by-paragraph dot-point summary of the events_since_last_tracked_info_update.
      - Update the *existing* sections/properties (no new sections, just update existing properties/lists, and only if needed).
      - Start your response with the dot-point event summary, and then after that, write the updated tracked info enclosed in tags like this: <tracked_info:updated>...</tracked_info:updated>
      - IMPORTANT: Within dot-point your summary, whenever you notice a tracked_info change, explicitly write the change in parentheses e.g. "(X changes from Y to Z)" or "(No change)". You must repeat this particular instruction as part of the first line of your response, so you don't forget it.
      - The parentheses stuff is for the summary dot-point items (NOT for text within the tracked_info tags).
      `.trim(),
      startWith: `Summary of events, with required tracked info updates appended in parentheses, in the form "(X changes from Y to Z)" or "(No change)":\n-`, // `${prePrefix}${originalTextPrefix}`,
      stopSequences: ["</track"],
      onChunk: (data) => {
        if(trackedInfoHasStarted) {
          currentTrackedInfoEl.value += data.textChunk;
        }
        generatedText += data.textChunk;
        if(!trackedInfoHasStarted && generatedText.includes(prePrefix)) {
          currentTrackedInfoEl.value = generatedText.split(prePrefix)[1];
          trackedInfoHasStarted = true;
        }
      },
    });
    updateTrackedInfoStopBtn.onclick = function() {
      promise.stop();
    };
    let result = await promise;
    if(result.stopReason === "error" || result.stopReason === "user") { // "user" means .stop() was called - i.e. stop button clicked
      currentTrackedInfoEl.value = originalTrackedInfoText;
    } else {
      let newTrackedInfoText = currentTrackedInfoEl.value;
      newTrackedInfoText = newTrackedInfoText.replace(/\n?<\/track$/, "").trim();
      newTrackedInfoText = newTrackedInfoText.split("\nUpdated Tracked Info:")[0];
      newTrackedInfoText = newTrackedInfoText.replace(/ \(.+? changes from.+?\)(\n|$)/g, "\n");
      newTrackedInfoText = newTrackedInfoText.replace(/ \(.*?(found|spent).+?\)(\n|$)/g, "\n");
      newTrackedInfoText = newTrackedInfoText.replace(/ \((chang(ed|s|)|updat(ed|s|)|increment(ed|s|)|decrement(ed|s|)) (from|by|to).*?\)(\n|$)/gi, "\n");
      newTrackedInfoText = newTrackedInfoText.replace(/ \(new item\)(\n|$)/gi, "\n");
      newTrackedInfoText = newTrackedInfoText.replace(/ \(no changes?\)(\n|$)/gi, "\n");
      newTrackedInfoText = newTrackedInfoText.replace(/ \(1.*? used\)(\n|$)/gi, "\n");
      currentTrackedInfoEl.value = newTrackedInfoText.trim();
      localStorage.currentTrackedInfo = newTrackedInfoText;
      let storySoFarBeforeMovingTrackedInfoPlaceholder = storySoFarEl.value;
      storySoFarEl.value = storySoFarEl.value.trim().replace(/\n+<tracked_info_placeholder>\n*/g, "\n\n").trim() + "\n\n<tracked_info_placeholder>";
      localStorage.storySoFar = storySoFarEl.value;
      updateTrackedInfoUndoBtn.hidden = false;
      updateTrackedInfoUndoBtn.onclick = function() {
        if(updateTrackedInfoUndoBtn.hidden) return; // just for safety in case of something weird like programmatic click or whatever
        updateTrackedInfoUndoBtn.hidden = true;
        currentTrackedInfoEl.value = originalTrackedInfoText;
        localStorage.currentTrackedInfo = currentTrackedInfoEl.value;
        storySoFarEl.value = storySoFarBeforeMovingTrackedInfoPlaceholder; // NOTE: this is safe because we hide the undo button when the story text is edited at all (e.g. by manually typing, or generating, etc.)
        localStorage.storySoFar = storySoFarEl.value;
      };
      window.manualCurrentTrackedInfoEditsSinceLastCheckpoint = 0;
    }
  } catch(e) {
    console.error(e);
    error = e;
    currentTrackedInfoEl.value = originalTrackedInfoText;
  } finally {
    currentTrackedInfoEl.placeholder = originalPlaceholder;
    updateTrackedInfoBtn.disabled = false;
    updateTrackedInfoStopBtn.hidden = true;
    update(updateTrackedInfoBtn);
  }
  if(error) throw error; // so it shows up in the UI for people to report


setInterfaceMode(mode) =>
  if(mode === "normal") {
    storyBeginBtn.hidden = true;
    storyBeginOptionsCtn.hidden = true;
    storyGenerationAreaEl.hidden = false;
    subtitleEl.hidden = true;
  } else if(mode === "intro") {
    storyBeginBtn.hidden = false;
    storyBeginOptionsCtn.hidden = false;
    storyGenerationAreaEl.hidden = true;
    subtitleEl.hidden = false;
  }

loadChatDataIntoInputAreas(data) =>
  // this function accepts a data object, or if it's not specified then it loads from localStorage
  if(!data) data = localStorage;
  storyOverviewEl.value = data.storyOverview || "";
  storySoFarEl.value = data.storySoFar || "";
  whatHappensNextEl.value = data.whatHappensNext || "";
  storyArcInstructionEl.value = data.storyArcInstruction || "";

  // RESPONSE STYLE:
  let responseStyle = [...responseStyleEl.querySelectorAll("option")][0].value;
  if(data.responseStyle) {
    let isValid = [...responseStyleEl.querySelectorAll("option")].filter(el => el.value===data.responseStyle).length > 0;
    if(isValid) responseStyle = data.responseStyle;
  }
  responseStyleEl.value = responseStyle;
  customResponseStyleCtn.hidden = responseStyle !== "@@@custom";
  responseStyleCustomInputEl.value = data.responseStyleCustomInput || "";
  storyWritingStyleCustomInputEl.value = data.storyWritingStyleCustomInput || "";

  // BACKGROUND AUDIO:
  let backgroundAudio = [...backgroundAudioSelectEl.querySelectorAll("option")][0].value;
  if(data.backgroundAudio) {
    let isValid = [...backgroundAudioSelectEl.querySelectorAll("option")].filter(el => el.value===data.backgroundAudio).length > 0;
    if(isValid) backgroundAudio = data.backgroundAudio;
  }
  backgroundAudioSelectEl.value = backgroundAudio;
  backgroundAudioCustomInputEl.hidden = backgroundAudio !== "@@@custom";
  backgroundAudioCustomInputEl.value = data.backgroundAudioCustomInput || "";

  // BACKGROUND IMAGE:
  backgroundImageEl.value = data.backgroundImage || "";
  if(data.backgroundImage) {
    let option = [...backgroundImageSelectEl.querySelectorAll("option")].find(o => o.value === data.backgroundImage);
    backgroundImageSelectEl.value = option?.value || "@@@custom";
  } else {
    backgroundImageSelectEl.value = "";
  }
  updateBackgroundImage();

  difficultyModeEl.value = data.difficultyMode || "";
  pacingModeEl.value = data.pacingMode || "";
  genreModeEl.value = data.genreMode|| "";
  autoUpdateEl.value = data.autoUpdate || "";
  subGenreModeEl.value = data.subGenreMode|| "";
  gameModeEl.value = data.gameMode ||"";
  namingModeEl.value = data.namingMode || "";
  StyleEl.value = data.voice || "";
  perspectiveEl.value = data.perspective || "";
  //loreBook.data.lorebook;

  if(storySoFarEl.value.trim() || Number(localStorage.generateCount||0) > 1) {
    setInterfaceMode("normal");
  }

  currentTrackedInfoEl.value = data.currentTrackedInfo || "";
  infoTrackingBtn.dataset.enabled = data.infoTrackingEnabled || "";
  updateInfoTrackingDisplay();

  renderShortcutButtons();

  {
    // For long stories, this can take a while, so we time it:
    let t = performance.now();
    storySoFarEl.scrollTop = storySoFarEl.scrollHeight; // scroll to the bottom of the current story
    window.storySoFarElInitialRenderTime = performance.now()-t;
    console.log("storySoFarElInitialRenderTime:", window.storySoFarElInitialRenderTime);
  }

  updateButtonsDisplay();
  if(storySoFarEl.value.length > 1000) whatHappensNextEl.placeholder = "(Optional) What will you do next?";

loadDataIntoLocalStorage(data) =>
  localStorage.storyOverview = data.storyOverview || "";
  localStorage.storySoFar = data.storySoFar || "";
  localStorage.whatHappensNext = data.whatHappensNext || "";
  localStorage.responseStyle = data.responseStyle || "";
  localStorage.responseStyleCustomInput = data.responseStyleCustomInput || "";
  localStorage.storyWritingStyleCustomInput = data.storyWritingStyleCustomInput || "";
  localStorage.backgroundAudio = data.backgroundAudio || "";
  localStorage.backgroundAudioCustomInput = data.backgroundAudioCustomInput || "";
  localStorage.backgroundImage = data.backgroundImage || "";
  localStorage.currentTrackedInfo = data.currentTrackedInfo || "";
  localStorage.infoTrackingEnabled = data.infoTrackingEnabled || "";
  localStorage.difficultyMode = data.difficultyMode || "";
  localStorage.pacingMode= data.pacingMode || "";
  localStorage.genreMode = data.genreMode || "";
  localStorage.perspective= data.perspective || "";
  localStorage.autoUpdate = data.autoUpdate || "";
  localStorage.subGenreMode = data.subGenreMode || "";
  localStorage.gameMode = data.gameMode || "";
  localStorage.namingMode = data.namingMode || "";
  localStorage.storyArcInstruction = data.storyArcInstruction || "";
  localStorage.shortcutButtons = JSON.stringify(data.shortcutButtons || []);
  localStorage.loreBook =JSON.stringify(data.loreBook||[]);

async generateShareLinkForStory() =>
  if(!confirm("This will save the current game data as a sharable link/URL. It's a private URL that's only accessible to others if you give them the link. Continue?")) return;

  if(!window.CompressionStream) {
    alert("Share links use a feature that's only available in modern browsers. Please upgrade your browser to the latest version to use this feature.");
    return;
  }
  if((storyOverviewEl.value+storySoFarEl.value).trim() === "") {
    alert("You need to add some content before sharing.");
    return;
  }
  shareLinkCtn.style.display = "none";

  shareStoryBtn.disabled = true;
  shareStoryBtn.textContent = "⏳ uploading data...";

  let jsonString = JSON.stringify(getCurrentStoryData());

  // convert json text to blob:
  jsonString = jsonString.replace(/#/g, "%23"); // since hash is a special character in dataurls (like normal URLs)
  let blob = await fetch("data:text/plain;charset=utf-8,"+jsonString).then(res => res.blob());

  // compress blob:
  let compressedBlob = await compressBlobWithGzip(blob);

  let { url, size, error } = await upload(compressedBlob);
  if(error) {
    shareStoryLinkInputEl.value = `error: ${error}`;
  } else {
    shareStoryLinkInputEl.value = `https://perchance.org/${window.generatorName}#data=`+url.replace("https://user-uploads.perchance.org/file/", "uup1:");
  }
  shareLinkCtn.style.display = "";
  shareStoryBtn.textContent = "🔗 share";
  shareStoryBtn.disabled = false;
  shareStoryBtn.style.display = "none";

async compressBlobWithGzip(blob) =>
  const cs = new CompressionStream('gzip');
  const compressedStream = blob.stream().pipeThrough(cs);
  let outputBlob = await new Response(compressedStream).blob();
  return new Blob([outputBlob], { type: "application/gzip" }); // <-- to add the correct mime type

async loadDataFromUrlHash() =>
  let success = false;
  if(!window.DecompressionStream) {
    alert("Story share links use a browser feature that's only available in modern browsers. Please upgrade your browser to the latest version to allow for loading data from story share links.");
    return {success, error:"browser_compat"};
  }

  let loadingModal = document.createElement('div');
  loadingModal.innerHTML = `<div style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.5); z-index: 9999; display: flex; justify-content: center; align-items: center;">
    <div style="padding: 20px; background-color: var(--box-color); border-radius: 8px;">
      ⏳ loading adventure data...
    </div>
  </div>`;
  loadingModal = loadingModal.firstElementChild;
  document.body.append(loadingModal);

  try {
    let hashText = window.location.hash.slice(1);
    if(!hashText.startsWith("data=")) {
      throw new Error("Invalid share URL.");
    }
    let fileUrl = hashText.replace(/^data=/, "");
    if(fileUrl.startsWith("uup1:")) {
      fileUrl = fileUrl.replace("uup1:", "https://user-uploads.perchance.org/file/");
    }
    let fetchOptions = {};
    if(window.AbortSignal && AbortSignal.timeout) fetchOptions.signal = AbortSignal.timeout(10000);
    let blob = await fetch(fileUrl, fetchOptions).then(res => res.blob());
    let text;
    if(fileUrl.endsWith(".gz")) {
      let decompressedBlob = await decompressBlobWithGzip(blob);
      text = await decompressedBlob.text();
    } else {
      text = await blob.text();
    }
    let data = JSON.parse(text);
    if(data.format === "perchance-ai-rpg-v1") {
      if((storyOverviewEl.value+storySoFarEl.value+whatHappensNextEl.value).trim() !== "") {
        let confirmed = confirm("𝗛𝗲𝗮𝗱𝘀 𝘂𝗽: You're loading an adventure share link. This will overwrite your existing adventure. 𝗖𝗼𝗻𝘁𝗶𝗻𝘂𝗲?\n\n(Note: You can click cancel and then load the share link in your browser's incognito/private mode to avoid overwriting your current adventure, or just save your existing adventure first.)");
        if(!confirmed) {
          loadingModal.remove();
          return {success, error:"loading_cancelled_by_user"};
        }
      }
      try { loadDataIntoLocalStorage(data); } catch(e) { alert("Failed to load data into your browser storage. Please report this issue using the feedback button, including the adventure length (word count) and your device/browser."); console.error(e); }
      loadChatDataIntoInputAreas(data);
      success = true;
    } else {
      alert("Unknown adventure data format.");
    }
  } catch(e) {
    alert(`Failed to load adventure data: ${e.message}`);
    console.error(e);
  }

  loadingModal.remove();
  return {success};

async decompressBlobWithGzip(blob) =>
  const ds = new DecompressionStream("gzip");
  const decompressedStream = blob.stream().pipeThrough(ds);
  return await new Response(decompressedStream).blob();

getCurrentStoryData() =>
  return {
    format: "perchance-ai-rpg-v1",
    storyOverview: storyOverviewEl.value.trim(),
    storySoFar: storySoFarEl.value.trim(),
    whatHappensNext: whatHappensNextEl.value.trim(),
    responseStyle: responseStyleEl.value,
    responseStyleCustomInput: responseStyleCustomInputEl.value,
    storyWritingStyleCustomInput: storyWritingStyleCustomInputEl.value,
    backgroundAudio: backgroundAudioSelectEl.value,
    backgroundAudioCustomInput: backgroundAudioCustomInputEl.value,
    backgroundImage: backgroundImageEl.value,
    currentTrackedInfo: currentTrackedInfoEl.value,
    infoTrackingEnabled: infoTrackingBtn.dataset.enabled,
    difficultyMode: difficultyModeEl.value,
    pacingMode: pacingModeEl.value,
    genreMode: genreModeEl.value,
    autoUpdate: autoUpdateEl.value,
    subGenreMode: subGenreModeEl.value,
    gameMode: gameModeEl.value,
    namingMode: namingModeEl.value,
    voice: StyleEl.value,
    storyArcInstruction: storyArcInstructionEl.value,
    loreBook: JSON.parse(localStorage.loreBook|| "[]"),
    shortcutButtons: JSON.parse(localStorage.shortcutButtons || "[]"),
  };

saveStoryDataToUsersDevice() =>
  let data = getCurrentStoryData();
  let filename = prompt("Choose a filename:", window.lastSaveFilenameUsed || "my-adventure");
  if(filename === null) return;
  window.lastSaveFilenameUsed = filename;
  filename += ".ai-rpg.json";
  let blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  let url = URL.createObjectURL(blob);
  let a = document.createElement('a');
  a.href = url;
  a.download = filename;
  a.click();
  URL.revokeObjectURL(url);

async loadStoryDataFromUsersDevice() =>
  return new Promise((resolve, reject) => {
    let input = document.createElement('input');
    input.type = 'file';
    input.accept = 'application/json, text/json, text/plain, application/JSON, .json';
    input.onchange = async (event) => {
      let file = event.target.files[0];
      if (file) {
        try {
          let content = await file.text();
          let data = JSON.parse(content);
          if(data.format === "perchance-ai-rpg-v1") {
            if((storyOverviewEl.value+storySoFarEl.value+whatHappensNextEl.value).trim() !== "") {
              let confirmed = confirm("Loading this data will 𝗼𝘃𝗲𝗿𝘄𝗿𝗶𝘁𝗲 your current adventure. Continue?");
              if(!confirmed) return;
            }
            try { loadDataIntoLocalStorage(data); } catch(e) { alert("Failed to load data into your browser storage. Please report this issue using the feedback button, including the story length (word count) and your device/browser."); console.error(e); }
            loadChatDataIntoInputAreas(data);
            resolve(true);
          } else {
            alert("Unknown save file format.");
          }
        } catch (error) {
          alert("There was an error while loading that adventure file.");
          reject(error);
        }
      }
    };
    input.click();
    arrayToLorebook();
    updateLore();
  });





async copyStoryTextToClipboardWithoutSummaries() =>
  let text = storySoFarEl.value.split(/\n{2,}/).map(p => p.trim()).filter(p => !p.startsWith("SUMMARY^")).join("\n\n");

  await navigator.clipboard.writeText(text);
  copyStoryTextWithoutSummariesBtn.textContent = "✅ copied";
  setTimeout(() => {
    copyStoryTextWithoutSummariesBtn.textContent = "📋 copy adventure without summaries";
  }, 3000);


getMessagesWithSummaryReplacements(text, opts) =>
  if(!opts) opts = {};
  const minimumMessageLevel = opts.minimumMessageLevel || 0; // used by the summarization process.

  let messages = text.split("\n\n").map(m => m.trim()).filter(m => m);
  let messagesWithSummaryReplacements = [];
  let highestLevelSeen = 0;

  // it's we go backwards through the messages, and only 'collect' a message if its level is not below the highest level we've seen so far. it makes sense if you think about it for a bit.
  // said another way, we go from the end of the messages to the start while 'monotonically climbing' up a level whenever we hit a 'higher' message.
  while(messages.length > 0) {
    let m = messages.pop();
    let level = Number((m.match(/SUMMARY\^([0-9]+):/)||[])[1] || 0);
    if(level < minimumMessageLevel) continue;
    if(level >= highestLevelSeen) {
      messagesWithSummaryReplacements.unshift(m);
      highestLevelSeen = level;
    }
  }
  return messagesWithSummaryReplacements;


summaryPromptInstruction
  Your task is to generate some text for a story/narration and then a 'SUMMARY' of that text, and then repeat a few times. Below is the story overview, and a summary of earlier events. You must write the text, and then a summary of that text that you wrote, and then some more text, and a summary of that new text, and repeat. Each summary should be a single paragraph of text which concisely compresses the recent text to roughly half its original size.
  IMPORTANT: Every summary must be UNIQUE, and it must be concise, and information dense. Avoid flowery prose in summaries. Write concise summaries, but don't miss any important facts/events.
  IMPORTANT: Summaries must contain ALL important details from the text they're summarizing. Try to include *every* important detail in your summaries, resulting in a summary that is about half the length of the original text.
  Use this format/template for your response:
  ```
  \[A\]: <story/narration text>
  SUMMARY of \[A\]: <a dense, one-paragraph summary of the \[A\] text>
  ---
  \[B\]: <story/narration text>
  SUMMARY of \[B\]: <a dense, one-paragraph summary of the \[B\] text>
  ---
  \[C\]: <story/narration text>
  SUMMARY of \[C\]: <a dense, one-paragraph summary of the \[C\] text>
  ```
  [""]
  # Story Overview:
  [literal(storyOverviewEl.value.trim().replace(/\n+/g, "\n") || "(Not specified.)")]
  [""]
  # Summary of Previous Events:
  [literal(window.summaryMessagesForInstruction.join("\n"))]
  [""]
  ---
  [""]
  Again, your task is to write some text labelled with a letter, and then a summary of that text, and then some new text, and then a summary of that new text, and so on. Each summary should be a single paragraph of text which compresses the new text to roughly half its original length. Don't add flowery prose to summarise. Summary messages should be *dense* with important facts and information. Include *all* the plausibly-relevant story details from the text within the summary.
  IMPORTANT: Each 'SUMMARY' message must be UNIQUE and distinct from previous summaries. And 'SUMMARY of \[C\]' should include ALL important details from the \[C\] text and *never* invent any details that weren't in the text. Avoid accidentally repeating the events/details from earlier messages/summaries.
  IMPORTANT: The summaries must use short, information-dense sentences to compress the text into the key facts. Summaries should concisely capture *all* the *important* points from the text, compressing the text to about half its original length while retaining all important events/details.
  $output = [this.joinItems("\n")] // joins all of the above lines together

// CAUTION: note to self: don't make this async - must synchronously grab chatlog text due to `temporarilyRemovedPrefixChatLogsForStreamingRenderPerformance` stuff changing chat log text during streaming
injectSummariesAndComputeNextSummariesInBackgroundIfNeeded() =>
  if(!window.summariesReadyToInject) window.summariesReadyToInject = [];
  // inject summaries if we have any:
  if(window.summariesReadyToInject.length > 0) {
    // ensure logs are normalized so our message comparison checks work:
    let allMessagesOriginal = storySoFarEl.value.split(/\n{2,}/g).map(m => m.trim()).filter(m => m);
    let allMessagesNew = allMessagesOriginal.slice(0);
    for(let {summarizedMessages, lastMessageSummarizedIndex, summary, level} of window.summariesReadyToInject) {
      let lastSummarizedMessage = summarizedMessages[summarizedMessages.length-1];
      if(allMessagesOriginal[lastMessageSummarizedIndex] === lastSummarizedMessage) {
        allMessagesNew.splice(lastMessageSummarizedIndex + 1, 0, `SUMMARY^${level}: ${summary}`);
      } else {
        console.warn("Content of last-summmarized-message doesn't match content of message at lastMessageSummarizedIndex. Safe to ignore this warning if logs have been edited since last 'send' button click. This summary will simply be discarded and we'll compute a new one with the up-to-date chat logs.");
      }
    }
    storySoFarEl.value = allMessagesNew.join("\n\n");
    window.summariesReadyToInject = [];
  }

  const { countTokens, idealMaxContextTokens } = ai({getMetaObject:true});

  const contextLengthToIdeallyStayUnder = idealMaxContextTokens*0.88;
  const numCharsToSummarizeAtATime = 1500; // don't make this bigger without testing - IIRC, the summary calls to the AI could have context too large (causing implicit middle-out ablation) at when the summary hierarchy gets "deep"

  // must get text synchronously, since storySoFarEl can be temporarily ablated during streaming for rendering performance.
  const storySoFarElText = storySoFarEl.value;
  const messagesWithSummaryReplacements = getMessagesWithSummaryReplacements(storySoFarElText);

  let currentlyUsedContextLength = countTokens(messagesWithSummaryReplacements.join("\n\n") + storyOverviewEl.value);
  if(currentlyUsedContextLength < contextLengthToIdeallyStayUnder) {
    console.log(`Summarization not needed. currentlyUsedContextLength=${currentlyUsedContextLength} which is less than ${contextLengthToIdeallyStayUnder}`);
    return;
  }

  // compute next summary in background if needed:
  (async function() {
    if(window.alreadyDoingSummary) return;
    try {
      window.alreadyDoingSummary = true;

      const allMessageObjs = storySoFarElText.split(/\n{2,}/).map(m => m.trim()).filter(m => m).map((text, i) => {
        return {
          text, // note that this `text` is trimmed in the `map` above - very important that we do this kind of normalization for summary replacement stuff, since we do actual string-match replacement.
          index: i,
          level: Number((text.match(/SUMMARY\^([0-9]+):/)||[])[1] || 0)
        };
      });

      // conceptually we treat each "level" just like the first.
      // the first level is just a bunch of messages with interspersed "SUMMARY^1: ..." messages, where the summary messages are a summary of the messages before them, up to the *previous* "SUMMARY^1: ..." message.
      // so for the next level, we just delete/ignore the ^0 messages (i.e. the *actual* messages), and do exactly the same thing - i.e. treat "SUMMARY^1: ..." as if they were "messages" and "SUMMARY^2: ..." are the summaries of those "messages".

      let summaryLevelToMessageBlocks = new Map();
      let summaryLevelBeingProcessed = 1;
      while(1) {
        // grab messages that are relevant to this 'level' (i.e. only this level and lower one):
        const thisLevelAndPreviousLevelMessageObjs = allMessageObjs.filter(m => m.level === summaryLevelBeingProcessed || m.level === summaryLevelBeingProcessed-1);

        if(thisLevelAndPreviousLevelMessageObjs.length === 0) {
          console.log("Finished creating summaryLevelToMessageBlocks.");
          break;
        }

        // get all summary 'blocks' (i.e. groups of messages ending with a summary message of this `level` that summarizes them, except for final block which doesn't have a summary at the end)
        const blocks = [];
        let currentBlock = [];
        currentBlock.globalMessageIndices = [];
        for(let m of thisLevelAndPreviousLevelMessageObjs) {
          currentBlock.push(m.text);
          currentBlock.globalMessageIndices.push(m.index); // this is for use in determining summary injection/placement
          if(m.level === summaryLevelBeingProcessed) {
            blocks.push(currentBlock);
            currentBlock = [];
            currentBlock.globalMessageIndices = [];
          }
        }
        if(summaryLevelBeingProcessed === 1 && currentBlock.length === 0) {
          console.warn("final block for summaryLevel==1 should have messages? if it doesn't, then we're maybe summarizing too close to the end of the chat log?");
        }
        blocks.push(currentBlock); // final block doesn't have a summary at the end
        summaryLevelToMessageBlocks.set(summaryLevelBeingProcessed, blocks);

        summaryLevelBeingProcessed++;
      }

      const summaryLevelBlockEntries = [...summaryLevelToMessageBlocks.entries()].sort((a,b) => a[0]-b[0]); // ascending order
      for(let [summaryLevel, blocks] of summaryLevelBlockEntries) {

        // note: a block is just an array of messages, and all of them have a summary message (i.e. higher-level message) at the end EXCEPT the last block - we're in the process of adding that summary message here.
        // but also note: the block has a globalMessageIndices property which is also an array (see above)
        let messagesToSummarizeFromFinalBlock = blocks[blocks.length-1];

        // note that we can use numCharsToSummarizeAtATime here even for the first level without worrying about summarizing too close to the end of the chat because we have a currentlyUsedContextLength check before running this summarization process.
        let numCharsInFinalBlock = messagesToSummarizeFromFinalBlock.reduce((a,v) => a+v.length, 0);
        if(numCharsInFinalBlock < numCharsToSummarizeAtATime) {
          console.log(`summaryLevel=${summaryLevel} doesn't need summarizing yet. numCharsInFinalBlock=${numCharsInFinalBlock}`);
          continue;
        }

        // remove messages from last block (which contains all messages after the last summary) until it's a good size for summarization:
        while(1) {
          if(messagesToSummarizeFromFinalBlock.length <= 2) break;
          let numChars = messagesToSummarizeFromFinalBlock.reduce((a,v) => a+v.length, 0);
          if(numChars < numCharsToSummarizeAtATime) break;

          // to speed things up, drop latter half if it's way too big:
          if(numChars > numCharsToSummarizeAtATime*10) {
            let halfOfMessagesCount = Math.floor(messagesToSummarizeFromFinalBlock.length/2);
            for(let j = 0; j < halfOfMessagesCount; j++) {
              messagesToSummarizeFromFinalBlock.pop();
              messagesToSummarizeFromFinalBlock.globalMessageIndices.pop();
            }
          } else {
            messagesToSummarizeFromFinalBlock.pop();
            messagesToSummarizeFromFinalBlock.globalMessageIndices.pop(); // this is an array of indices aligned with the messages array, for detemining summary injection location
          }
        }

        if(messagesToSummarizeFromFinalBlock.length === 0) {
          console.error("No messages to summarize??");
          continue;
        }

        let existingSummary = window.summariesReadyToInject.filter(s => s.summarizedMessages.join("\n\n") === messagesToSummarizeFromFinalBlock.join("\n\n"))[0];
        if(existingSummary) {
          console.error("Existing summary hasn't been injected yet?? Should have happened before this code ran.");
          return;
        }

        // Note: It may seem brittle to choose an *index* to inject the summary at, but we also check to ensure the previous message matches.
        // And if the text has since been edited, that's fine - the summary just gets thrown away and we re-do it next time the send button is clicked.
        let lastMessageSummarizedIndex = messagesToSummarizeFromFinalBlock.globalMessageIndices[messagesToSummarizeFromFinalBlock.length-1];
        if(messagesToSummarizeFromFinalBlock.globalMessageIndices.length !== messagesToSummarizeFromFinalBlock.length) { console.error("should be one index per message"); return; }

        let exampleBlocksForStartWith = blocks.slice(-3, -1);
        let exampleBlockSummaries = exampleBlocksForStartWith.map(b => b[b.length-1]);

        // we get all messages for this summary level and above for placement in instruction (i.e. as context to help with summarization):
        let instructionSummaries = getMessagesWithSummaryReplacements(storySoFarElText, {minimumMessageLevel:summaryLevel});

        // note that we can't just remove the last two instruction summaries here - they aren't necessarily the same as the summaries from the `exampleBlocksForStartWith` because they may have been 'compressed' into a higher level, so there can actually be no overlap at all.
        // so we need to pop the instructionSummaries off based on the ones that are actually in the example blocks:
        while(1) {
          if(instructionSummaries.length === 0) break;
          if(exampleBlockSummaries.includes(instructionSummaries[instructionSummaries.length-1])) {
            instructionSummaries.pop();
            continue;
          }
          break;
        }
        instructionSummaries = instructionSummaries.map(m => m.replace(/SUMMARY\^[0-9]+:/, "").trim());

        let startWithBlocks = exampleBlocksForStartWith.map((block) => ({messages:block.slice(0, -1), summary:block.slice(-1)[0]}));
        startWithBlocks.push({messages:messagesToSummarizeFromFinalBlock, summary:""});

        if(messagesToSummarizeFromFinalBlock.join("\n").replaceAll(`SUMMARY^${summaryLevel-1}:`, "").includes("SUMMARY^")) {
          console.error("Should have only been summaryLevel-1 summaries in messagesToSummarizeText. messagesToSummarizeFromFinalBlock:", messagesToSummarizeFromFinalBlock);
        }

        let startWith = startWithBlocks.map(({messages, summary}, blockI) => {
          let letterLabel = "";
          if(blockI===0) letterLabel = "[A]";
          if(blockI===1) letterLabel = "[B]";
          if(blockI===2) letterLabel = "[C]";

          let messagesText = messages.map((message, mi) => {
            message = message.replace(`SUMMARY\^${summaryLevel-1}:`, "").replace(`SUMMARY\^${summaryLevel}:`, "").replace(/\n/g, " ").trim();
            return `${summaryLevel === 1 ? `(${mi+1}) ` : ""}${message}`; // we prefix bottom-level messages with numbers, but not SUMMARY^N messages.
          }).join(" ");

          summary = summary.replace(`SUMMARY\^${summaryLevel-1}:`, "").replace(`SUMMARY\^${summaryLevel}:`, "").replace(/\n/g, " ").trim();

          return `FULL TEXT of ${letterLabel}: ${messagesText}\nSUMMARY of ${letterLabel}: ${summary}`;
        }).join("\n\n");

        // since possible for there to be no blocks before the messages to summarize
        startWith = startWith.trim(); // this is also important to prevent whitespace at end of startWith

        window.summaryMessagesForInstruction = instructionSummaries.length > 0 ? instructionSummaries : ["(None.)"]; // used in summaryPromptInstruction
        let instruction = root.summaryPromptInstruction.evaluateItem;
        window.summaryMessagesForInstruction = null;

        let promptOptions = {
          instruction,
          startWith,
          stopSequences: ["\n\n", "\n---", "FULL TEXT"],
        };

        let data = await root.ai(promptOptions);

        if(data.stopReason === "error") continue; // could retry a few times, but this is no big deal, since every message sent triggers another attempt

        let summary = data.generatedText.trim().replace(/\n+/g, " ").trim().replace(/---$/, "").replace("FULL TEXT", "").trim();
        if(!summary.trim() || (instructionSummaries[instructionSummaries.length-1] || "").trim() === summary.trim()) {
          // AI has copied the previous summary, which sometimes happens.
          console.warn("AI copied previous summary or gave blank summary. Skipping this summary level for this 'round'. Summary:", summary);
          continue;
        }

        console.log("----------------");
        console.log("----------------");
        console.log("----------------");
        console.log("𝗟𝗘𝗩𝗘𝗟:", summaryLevel);
        console.log("𝗜𝗡𝗦𝗧𝗥𝗨𝗖𝗧𝗜𝗢𝗡:", instruction);
        console.log("𝗦𝗧𝗔𝗥𝗧𝗪𝗜𝗧𝗛:", startWith);
        console.log("𝗦𝗨𝗠𝗠𝗔𝗥𝗬:", summary);
        console.log("----------------");
        console.log("----------------");
        console.log("----------------");

        window.summariesReadyToInject.push({summarizedMessages:messagesToSummarizeFromFinalBlock, lastMessageSummarizedIndex, summary, level:summaryLevel});
      }
    } catch(e) {
      console.error(e);
    } finally {
      window.alreadyDoingSummary = false;
    }
  })();


