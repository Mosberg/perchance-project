// Character Output Template
[character]
  identity = {
    name: {identity.firstName} {identity.lastName}
    age: {identity.ageCategories}
    gender: {identity.gender}
  }
  appearance = {
    skin: {appearance.skinTone}
    eyes: {appearance.eyeColor}
    hair: {appearance.hair.color} {appearance.hair.style}
    body: {
      height: {appearance.body.height}
      build: {appearance.body.build}
      genitals: {appearance.genitals}
    }
  }
  adult = {
    kinks: {adult.kinks}
    fetishes: {adult.fetishes}
    acts: {adult.sexualActs}
    equipment: {adult.equipment}
  }

