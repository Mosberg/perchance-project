// Vagina Categories and Shapes
      vagina
        vulva_shape
          asymmetrical_inner_lips
            description = One inner lip is longer or larger than the other; a very common natural variation.
          prominent_inner_lips
            description = Inner lips extend beyond the outer lips; may be subtle or pronounced.
          prominent_outer_lips
            description = Outer lips are fuller or lower-set, usually covering the inner lips.
          curved_outer_lips
            description = Outer lips form a gentle horseshoe shape, with the inner lips visible toward the front.
          visible_inner_lips
            description = Inner and outer lips are similar in size, with the inner lips naturally peeking through.
          small_open_outer_lips
            description = Outer lips lie flat against the pubic area with a slight separation, showing the inner lips.
          small_closed_outer_lips
            description = Outer lips meet fully in the center, concealing the inner lips completely.
          long_inner_lips
            description = Inner lips extend noticeably beyond the outer lips, sometimes with additional folds.
          long_outer_lips
            description = Outer lips are longer or looser, sometimes extending downward and exposing the inner lips.
          custom
            description = A unique natural variation not covered by the categories above.

// Both Genital Sets
      both
        combined_anatomy
          distinct_structures
            description = External traits from both sets are present as separate structures.
          partially_fused
            description = Some tissues blend or overlap, forming intermediate structures.
          asymmetric_combination
            description = One side presents traits from one set, the other from another.
          reduced_structures
            description = One or more structures are present in smaller or simplified form.
          prominent_structures
            description = Both sets of external traits are well‑defined and visible.
          custom
            description = A unique combination not covered above.

// Intersex Variations
      intersex
        intersex_variation
          atypical_lip_development
            description = Outer or inner folds develop in patterns outside typical ranges.
          atypical_phallic_development
            description = External phallic structure varies in size or shape.
          partially_fused_folds
            description = Outer folds meet or fuse to varying degrees.
          prominent_clitoral_structure
            description = Clitoral tissue is larger or more pronounced than average.
          reduced_phallic_structure
            description = External phallic tissue is smaller or less defined.
          mixed_characteristics
            description = Combination of traits typically associated with different sexes.
          variable_urethral_position
            description = Urethral opening appears in a non‑typical location.
          custom
            description = A unique natural variation not covered above.

// None/Absent Genitalia
      none
        no_external_genitalia
          smooth_surface
            description = No external structures; surface is continuous and unbroken.
          minimal_ridge
            description = Slight contour or ridge without defined anatomy.
          recessed_opening
            description = A small, non‑sexual opening for biological functions.
          sealed_surface
            description = Fully smooth with no visible openings.
          custom
            description = A unique configuration not covered above.


