// Build Categories and Ranges
    build
      slender
        description = Narrow frame, delicate proportions, minimal body mass.
      slim
        description = Lean build with light muscle definition and low body fat.
      average
        description = Balanced proportions with typical muscle and fat distribution.
      athletic
        description = Toned physique with visible muscle definition and strong posture.
      muscular
        description = Broad, powerful build with pronounced muscle mass.
      curvy
        description = Soft contours with fuller hips, chest, or thighs.
      chubby
        description = Rounder shape with noticeable softness and extra body mass.
      obese
        description = Large, heavyset build with significant body mass and fullness.
      stocky
        description = Shorter, thick build with dense muscle and solid frame.
      petite
        description = Small, compact frame with delicate proportions.
      lanky
        description = Tall, thin build with long limbs and minimal mass.
      burly
        description = Large, rugged build with heavy muscle and imposing presence.
      wiry
        description = Lean but strong, with ropey muscles and low fat.
      broad
        description = Wide shoulders and chest, sturdy and powerful silhouette.
      barrel_chested
        description = Thick torso with strong ribcage and heavy upper‑body mass.
      soft
        description = Gentle, rounded build with minimal muscle definition.
      toned
        description = Lean with clear muscle lines and athletic conditioning.
      hulking
        description = Massive, intimidating build with extreme muscle bulk.
      delicate
        description = Fine‑boned, fragile‑looking frame with subtle proportions.
      towering
        description = Exceptionally tall build with long limbs and commanding presence.
      stout
        description = Short, wide, and solidly built with dense mass.
      rotund
        description = Round, full-bodied shape with pronounced belly and softness.
      sinewy
        description = Thin but strong, with visible tendons and wiry muscle.
      rugged
        description = Weathered, sturdy build with hardened muscle and rough edges.
      imposing
        description = Physically dominant build that commands attention.
      custom
        description = A unique body type defined by the player.

// Genital Categories and Ranges
    genitals

// Penis Categories, Shapes and Ranges
      penis
        penis_shape
          straight
            description = Shaft aligns vertically without noticeable curvature.
          upward_curve
            description = Natural upward curvature when erect; a common variation.
          downward_curve
            description = Natural downward curvature; typically mild and harmless.
          left_curve
            description = Shaft curves gently to the left.
          right_curve
            description = Shaft curves gently to the right.
          tapered
            description = Narrower toward the tip with a gradual taper.
          cylindrical
            description = Even thickness along most of the shaft.
          wide_base
            description = Thicker at the base with a narrower mid‑shaft.
          wide_tip
            description = Slightly broader near the glans.
          foreskin_present
            description = Foreskin fully or partially covers the glans when flaccid.
          foreskin_retracted
            description = Foreskin naturally rests behind the glans.
          prominent_ridge
            description = Well‑defined coronal ridge around the glans.
          smooth_glans
            description = Glans has a more uniform, rounded shape.
          prominent_veins
            description = Visible superficial veins along the shaft.
          minimal_veins
            description = Smooth appearance with fewer visible veins.
          custom
            description = A unique natural variation not covered above.

